<style>
    .icon-box {
        width: 35px;
        height: 35px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .device-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0,0,0,0.05) !important;
    }

        .device-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .transition-all {
        transition: all 0.5s ease;
    }

    @@keyframes pulsing {
        0% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.7);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(25, 135, 84, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }

    .pulse-green {
        animation: pulsing 2s infinite;
    }

    .pulse-red {
        animation: pulsing 1s infinite;
        background-color: #dc3545 !important;
        box-shadow: 0 0 0 rgba(220, 53, 69, 0.4);
    }
</style>

<script>
    // --- GIỮ NGUYÊN CÁC HÀM JS MÔ PHỎNG CỦA BẠN ---
    let currentRamBase = 75;
    function startServerSimulation() {
        setInterval(() => {
            let cpu = Math.floor(Math.random() * 25) + 35;
            if(document.getElementById('cpuText')) {
                document.getElementById('cpuText').innerText = cpu + '%';
                document.getElementById('cpuBar').style.width = cpu + '%';
            }
        }, 2000);
    }
    document.addEventListener("DOMContentLoaded", startServerSimulation);
    function pingDevice(ip) { Swal.fire('Ping', `Gói tin ICMP gửi tới ${ip} ổn định (12ms)`, 'success'); }
    function rebootDevice(name) { Swal.fire('Reboot', `Đang khởi động lại ${name}...`, 'info'); }
</script>