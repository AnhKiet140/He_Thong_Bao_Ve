@{
    ViewData["Title"] = "Các Chức Năng Khác";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-3 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm border-start border-5 border-primary">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-grid-3x3-gap-fill text-primary"></i> HỆ SINH THÁI CHK-IN PRO</h4>
            <small class="text-muted fw-bold">CÁC PHÂN HỆ VÀ CHỨC NĂNG NÂNG CAO DÀNH CHO DOANH NGHIỆP</small>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/BaoCao/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-primary bg-opacity-10 text-primary mx-auto mb-3">
                        <i class="bi bi-graph-up-arrow fs-1"></i>
                    </div>
