        </div>

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/BaiDoXe/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-success bg-opacity-10 text-success mx-auto mb-3">
                        <i class="bi bi-p-square-fill fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Quản Lý Bãi Đỗ Xe</h5>
                    <p class="text-muted small mb-4">Kiểm soát biển số xe</p>
                    <button class="btn btn-outline-success w-100 fw-bold rounded-pill mt-auto">Mở</button>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/BanDoAnNinh/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-info bg-opacity-10 text-info mx-auto mb-3">
                        <i class="bi bi-map-fill fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Bản Đồ An Ninh</h5>
                    <p class="text-muted small mb-4">Định vị trạm trực ban</p>
                    <button class="btn btn-outline-info w-100 fw-bold rounded-pill mt-auto">Mở</button>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/ThietBiAI/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-warning bg-opacity-10 text-warning mx-auto mb-3">
                        <i class="bi bi-cpu-fill fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Quản Lý Thiết Bị</h5>
                    <p class="text-muted small mb-4">Trung tâm điều khiển IoT</p>
                    <button class="btn btn-outline-warning w-100 fw-bold rounded-pill mt-auto">Mở</button>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/SuCoCanhBao/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-danger bg-opacity-10 text-danger mx-auto mb-3">
                        <i class="bi bi-megaphone-fill fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Cảnh Báo Khẩn Cấp</h5>
                    <p class="text-muted small mb-4">SOS & Sơ tán</p>
                    <button class="btn btn-outline-danger w-100 fw-bold rounded-pill mt-auto">Mở</button>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/NhatKyHeThong/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-secondary bg-opacity-10 text-secondary mx-auto mb-3">
                        <i class="bi bi-terminal-fill fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Lịch Sử Máy Chủ</h5>
                    <p class="text-muted small mb-4">Theo dõi thao tác hệ thống</p>
                    <button class="btn btn-outline-secondary w-100 fw-bold rounded-pill mt-auto">Mở</button>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-lg-4 col-xl-3">
            <a href="/CauHinhHeThong/Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm rounded-4 extension-card text-center p-4">
                    <div class="icon-wrapper bg-dark bg-opacity-10 text-dark mx-auto mb-3">
                        <i class="bi bi-sliders fs-1"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Cài Đặt</h5>
                    <p class="text-muted small mb-4">Cấu hình & Hệ thống</p>
                    <button class="btn btn-outline-dark w-100 fw-bold rounded-pill mt-auto">Mở</button>
                </div>
            </a>
        </div>

    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Hiệu ứng Hover Card */
    .extension-card {
        transition: all 0.3s ease;
    }

        .extension-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

            /* Đổi màu nút khi hover card */
            .extension-card:hover .btn-outline-primary {
                background-color: #0d6efd;
                color: white;
            }

            .extension-card:hover .btn-outline-success {
                background-color: #198754;
                color: white;
            }

            .extension-card:hover .btn-outline-info {
                background-color: #0dcaf0;
                color: black;
            }

            .extension-card:hover .btn-outline-warning {
                background-color: #ffc107;
                color: black;
            }

            .extension-card:hover .btn-outline-danger {
                background-color: #dc3545;
                color: white;
            }

            .extension-card:hover .btn-outline-secondary {
                background-color: #6c757d;
                color: white;
            }

            .extension-card:hover .btn-outline-dark {
                background-color: #212529;
                color: white;
            }
</style>