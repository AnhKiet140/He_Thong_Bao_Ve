@{
    ViewData["Title"] = "Trạm Giám Sát Sinh Trắc Học";
    int occupied = ViewBag.OccupiedOto ?? 0;
    int available = 240 - occupied;
}

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid mt-2 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-3 rounded-4 shadow-sm border-start border-5 border-primary">
        <div>
            <h4 class="fw-bold text-primary mb-1"><i class="bi bi-shield-lock-fill"></i> HỆ THỐNG KIỂM SOÁT TỔNG HỢP</h4>
            <small class="text-muted fw-bold">QUY TRÌNH KIỂM DUYỆT 2 LỚP: FACE ID <i class="bi bi-arrow-right"></i> ALPR BIỂN SỐ</small>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <button id="btnScanAI" onclick="startSequentialScan()" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm disabled">
                <span class="spinner-border spinner-border-sm me-2"></span> ĐANG KHỞI ĐỘNG AI...
            </button>
            <span class="badge bg-dark fs-5 py-2 px-3 rounded-pill shadow-sm font-monospace" id="liveClock">--:--:--</span>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6 d-flex flex-column gap-3">
            <div class="card bg-black border-0 shadow-sm rounded-4 overflow-hidden position-relative" style="height: 38vh;">
                <div class="position-absolute top-0 start-0 p-2 text-white fw-bold small bg-primary bg-opacity-75 rounded-bottom-end-3 shadow" style="z-index:10">
                    <i class="bi bi-1-circle-fill"></i> LỚP 1: FACE ID SCANNER
                </div>
                <video id="webcam" class="w-100 h-100" style="object-fit: cover; transform: scaleX(-1);" autoplay muted></video>
                <canvas id="faceCanvas" class="position-absolute top-0 start-0 w-100 h-100" style="z-index:9; transform: scaleX(-1);"></canvas>
                <div id="ai-scanner-line" class="scan-overlay d-none"><div class="scan-line"></div></div>
                <div id="faceDoneOverlay" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center text-white bg-dark bg-opacity-75 d-none" style="z-index: 11;">
                    <div class="text-center p-4">
                        <i class="bi bi-check-circle-fill d-block mb-2 text-primary" style="font-size: 3rem;"></i>
                        <h5 class="fw-bold text-primary letter-spacing-1 mb-0">KHUÔN MẶT HỢP LỆ</h5>
                        <small class="text-muted">Chuyển sang quét phương tiện...</small>
                    </div>
                </div>
            </div>

            <div class="card bg-black border-0 shadow-sm rounded-4 overflow-hidden position-relative" style="height: 38vh;">
                <div class="position-absolute top-0 start-0 p-2 text-white fw-bold small bg-success bg-opacity-75 rounded-bottom-end-3 shadow" style="z-index:10">
                    <i class="bi bi-2-circle-fill"></i> LỚP 2: ALPR BIỂN SỐ
                </div>
                <video id="alprVideo" class="w-100 h-100" style="object-fit: cover; transform: scaleX(-1); filter: grayscale(30%) contrast(130%) brightness(90%);" autoplay muted></video>
                <canvas id="alprCanvas" class="position-absolute top-0 start-0 w-100 h-100" style="z-index:9; transform: scaleX(-1);"></canvas>
                <div id="alprWaiting" class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center text-secondary bg-dark bg-opacity-50" style="z-index: 8;">
                    <div class="text-center pulse-bg-slow p-4 rounded-circle">
                        <i class="bi bi-car-front fs-1 text-success opacity-50"></i>
                        <p class="small mt-2 fw-bold text-success opacity-75 letter-spacing-1">ĐANG CHỜ LỆNH TỪ LỚP 1...</p>
                    </div>
                </div>
                <div id="alprOverlay" class="position-absolute top-0 start-0 w-100 h-100 d-none" style="z-index: 9;">
                    <div class="focus-box"></div>
                    <div class="laser-beam" id="alprLaser"></div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4 p-4 bg-white">
                <div class="row h-100">
                    <div class="col-md-5 text-center border-end pe-4 d-flex flex-column">
                        <div class="avatar-container border border-3 border-primary border-opacity-25 rounded-4 bg-white mb-3 d-flex align-items-center justify-content-center overflow-hidden shadow-inner position-relative p-2" style="height: 260px;">
                            <img id="resAvatar" src="/images/face-id.png" onerror="this.src='/images/no-avatar.png'" class="img-fluid w-100 h-100" style="object-fit: contain;">
                            <div class="position-absolute top-0 start-0 w-100 h-100 border border-4 border-primary rounded-4 pulse-border d-none" id="scanningBorder"></div>
                        </div>
                        <h6 class="text-muted text-uppercase fw-bold small mb-1">Kết quả định danh</h6>
                        <h2 id="resName" class="fw-bold text-dark mb-1">ĐANG CHỜ...</h2>
                        <p id="resChucVu" class="text-primary fs-5 mb-auto fw-bold">-----</p>
                        <div id="resLoaiXe" class="badge bg-dark fs-6 w-100 py-3 mt-3 text-uppercase shadow-sm rounded-pill letter-spacing-1">LOẠI XE: ---</div>
                    </div>

                    <div class="col-md-7 ps-4 d-flex flex-column justify-content-between">
                        <div class="row g-3 p-3 bg-light rounded-4 border shadow-sm mb-3">
                            <div class="col-6 mb-2">
                                <small class="text-muted d-block fw-bold small text-uppercase"><i class="bi bi-tag-fill"></i> Phân Loại</small>
                                <div id="resLoaiXeText" class="fw-bold fs-5 text-dark mt-1">---</div>
                            </div>
                            <div class="col-6 mb-2 text-end">
                                <small class="text-muted d-block fw-bold small text-uppercase"><i class="bi bi-123"></i> Biển Số</small>
                                <span id="resPlate" class="fw-bold fs-3 text-dark font-monospace d-inline-block border-bottom border-3 border-primary pb-1">---------</span>
                            </div>
                            <div class="col-12"><hr class="m-0 text-muted opacity-25"></div>
                            <div class="col-6 mt-3">
                                <small class="text-muted d-block fw-bold small text-uppercase"><i class="bi bi-sign-turn-right-fill"></i> Hướng</small>
                                <span id="resHuong" class="fw-bold fs-4 text-primary">--</span>
                            </div>
                            <div class="col-6 mt-3 text-end">
                                <small class="text-muted d-block fw-bold small text-uppercase"><i class="bi bi-clock-fill"></i> Tình Trạng</small>
                                <div id="resLateStatus" class="badge fs-6 mt-1 bg-secondary text-white shadow-sm rounded-pill px-3">CHỜ DỮ LIỆU</div>
                            </div>
                        </div>

                        <div class="p-3 bg-success bg-opacity-10 rounded-4 border border-2 shadow-sm border-success border-opacity-25 text-center mb-3 position-relative overflow-hidden">
                            <h6 id="parkingTitle" class="fw-bold text-success text-uppercase mb-2"><i class="bi bi-p-circle-fill"></i> BÃI ĐỖ XE TỔNG HỢP</h6>
                            <div class="d-flex justify-content-center align-items-baseline gap-3 mb-2">
                                <h1 id="resParkingCount" class="display-3 fw-bold text-success mb-0">@available</h1>
                                <span class="text-success fw-bold">CHỖ TRỐNG</span>
                            </div>
                            <div class="progress bg-white shadow-inner" style="height: 10px; border-radius: 10px;">
                                <div id="parkingBar" class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: @((available / 240.0) * 100)%"></div>
                            </div>
                            <div class="position-absolute top-0 end-0 p-2">
                                <span id="resParkingSlot" class="badge bg-danger fs-5 shadow-sm rounded-pill px-3">--</span>
                            </div>
                        </div>
                        <button id="gateButton" class="btn btn-secondary py-3 fw-bold disabled fs-4 shadow-sm rounded-4 letter-spacing-1">
                            <i class="bi bi-door-closed-fill"></i> CỔNG ĐANG ĐÓNG
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f0f2f5;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .scan-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(13, 110, 253, 0.15);
        z-index: 12;
    }

    .scan-line {
        position: absolute;
        width: 100%;
        height: 4px;
        background: #0d6efd;
        box-shadow: 0 0 20px #0d6efd, 0 0 40px #0d6efd;
        animation: scanFaceMove 1.2s infinite linear;
    }

    @@keyframes scanFaceMove {
        0% {
            top: 0;
        }

        100% {
            top: 100%;
        }
    }

    .pulse-bg-slow {
        animation: pulseSlow 3s infinite;
    }

    @@keyframes pulseSlow {
        0%, 100% {
            transform: scale(1);
            opacity: 0.8;
        }

        50% {
            transform: scale(1.05);
            opacity: 1;
        }
    }

    #webcam, #alprVideo {
        position: absolute;
        top: 0;
        left: 0;
    }

    .focus-box {
        position: absolute;
        top: 25%;
        left: 20%;
        width: 60%;
        height: 50%;
        border: 2px solid rgba(25, 135, 84, 0.3);
    }

        .focus-box::before, .focus-box::after {
            content: '';
            position: absolute;
            width: 25px;
            height: 25px;
            border-color: #198754;
            border-style: solid;
        }

        .focus-box::before {
            top: -2px;
            left: -2px;
            border-width: 3px 0 0 3px;
        }

        .focus-box::after {
            bottom: -2px;
            right: -2px;
            border-width: 0 3px 3px 0;
        }

    .laser-beam {
        position: absolute;
        top: 25%;
        left: 20%;
        width: 60%;
        height: 2px;
        background: #198754;
        box-shadow: 0 0 12px 2px rgba(25, 135, 84, 0.8);
        animation: scanMove 1.5s infinite linear;
    }

    @@keyframes scanMove {
        0%, 100% {
            top: 25%;
        }

        50% {
            top: 75%;
        }
    }
</style>

<script>
    let faceMatcher = null;
    let totalSlots = 240;
    let occupiedOto = @occupied;
    let scanState = 'IDLE';

    const video = document.getElementById('webcam');
    const alprVideo = document.getElementById('alprVideo');
    const canvas = document.getElementById('faceCanvas');
    const alprCanvas = document.getElementById('alprCanvas');

    setInterval(() => {
        const liveClockDashboard = document.getElementById('liveClock');
        if(liveClockDashboard) liveClockDashboard.innerText = new Date().toLocaleTimeString('vi-VN');
    }, 1000);

    navigator.mediaDevices.getUserMedia({ video: true }).then(stream => {
        video.srcObject = stream;
        alprVideo.srcObject = stream;
        video.onloadedmetadata = () => {
            video.play();
            alprVideo.play();
            initAI();
        };
    });

    async function initAI() {
        let btn = document.getElementById('btnScanAI');
        try {
            await Promise.all([
                faceapi.nets.tinyFaceDetector.loadFromUri('https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights'),
                faceapi.nets.faceLandmark68Net.loadFromUri('https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights'),
                faceapi.nets.faceRecognitionNet.loadFromUri('https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights')
            ]);

            const response = await fetch('/Home/GetFaceData');
            const users = await response.json();

            const labeledFaceDescriptors = await Promise.all(
                users.map(async (user) => {
                    const img = new Image();
                    img.src = user.image;
                    return new Promise((resolve) => {
                        img.onload = async () => {
                            try {
                                const det = await faceapi.detectSingleFace(img, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();
                                if (det) {
                                    const bs = (user.bienso && user.bienso !== 'null') ? user.bienso : "---";
                                    const lx = (user.loaixe && user.loaixe !== 'null') ? user.loaixe : "KHÔNG CÓ";
                                    const cv = (user.role && user.role !== 'null') ? user.role : "Nhân viên";
                                    const gv = (user.gioVaoCa && user.gioVaoCa !== 'null') ? user.gioVaoCa : "";
                                    const gm = (user.gioXinDiMuon && user.gioXinDiMuon !== 'null') ? user.gioXinDiMuon : "";
                                    const labelStr = `${user.name}|${cv}|${user.manv}|${bs}|${lx}|${gv}|${gm}`;
                                    resolve(new faceapi.LabeledFaceDescriptors(labelStr, [det.descriptor]));
                                } else resolve(null);
                            } catch(e) { resolve(null); }
                        };
                        img.onerror = () => resolve(null);
                    });
                })
            );

            const validDescriptors = labeledFaceDescriptors.filter(d => d !== null);
            if(validDescriptors.length > 0) {
                faceMatcher = new faceapi.FaceMatcher(validDescriptors, 0.5);
                btn.innerHTML = '<i class="bi bi-shield-lock-fill"></i> BẮT ĐẦU QUY TRÌNH QUÉT';
                btn.classList.replace('btn-primary', 'btn-success');
                btn.classList.remove('disabled');
            }

            const displaySize = { width: video.clientWidth, height: video.clientHeight };
            faceapi.matchDimensions(canvas, displaySize);
            faceapi.matchDimensions(alprCanvas, displaySize);

            setInterval(async () => {
                const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions());
                const ctx = canvas.getContext('2d');
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                const alprCtx = alprCanvas.getContext('2d');
                alprCtx.clearRect(0, 0, alprCanvas.width, alprCanvas.height);

                faceapi.resizeResults(detections, displaySize).forEach(d => {
                    if (scanState === 'IDLE' || scanState === 'FACE_SCAN') {
                        ctx.strokeStyle = '#0d6efd'; ctx.lineWidth = 3;
                        ctx.strokeRect(d.box.x, d.box.y, d.box.width, d.box.height);
                    }
                    if (scanState === 'ALPR_SCAN') {
                        const plateWidth = 140; const plateHeight = 45;
                        const plateX = d.box.x + (d.box.width / 2) - (plateWidth / 2);
                        const plateY = Math.min(d.box.y + d.box.height + 120, displaySize.height - plateHeight - 15);
                        alprCtx.strokeStyle = '#198754'; alprCtx.lineWidth = 3;
                        alprCtx.strokeRect(plateX, plateY, plateWidth, plateHeight);
                    }
                });
            }, 100);
        } catch (e) { console.error(e); }
    }

    async function startSequentialScan() {
        if(!faceMatcher) return;
        let btn = document.getElementById('btnScanAI');
        btn.classList.add('disabled');

        scanState = 'FACE_SCAN';
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> [1/2] ĐANG QUÉT KHUÔN MẶT...';
        document.getElementById('ai-scanner-line').classList.remove('d-none');
        document.getElementById('faceDoneOverlay').classList.add('d-none');

        setTimeout(async () => {
            const detection = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();
            document.getElementById('ai-scanner-line').classList.add('d-none');

            if(detection) {
                const match = faceMatcher.findBestMatch(detection.descriptor);
                if(match.label !== 'unknown') {
                    const info = match.label.split('|');
                    const snapshot = captureSnapshot();
                    document.getElementById('resAvatar').src = snapshot;
                    document.getElementById('resAvatar').style.objectFit = "cover";
                    document.getElementById('resName').innerText = info[0].toUpperCase();
                    document.getElementById('resChucVu').innerText = info[1];
                    document.getElementById('faceDoneOverlay').classList.remove('d-none');

                    scanState = 'ALPR_SCAN';
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> [2/2] ĐANG QUÉT BIỂN SỐ...';
                    document.getElementById('alprWaiting').classList.add('d-none');
                    document.getElementById('alprOverlay').classList.remove('d-none');

                    setTimeout(() => {
                        document.getElementById('alprOverlay').classList.add('d-none');
                        document.getElementById('alprWaiting').classList.remove('d-none');
                        processCheckInOut({
                            hoTen: info[0], chucVu: info[1], maNV: info[2], bienSo: info[3], loaiXe: info[4], gioVaoCa: info[5], gioXinDiMuon: info[6], hinhAnh: snapshot
                        });
                        btn.innerHTML = '<i class="bi bi-shield-lock-fill"></i> BẮT ĐẦU QUY TRÌNH QUÉT';
                        btn.classList.remove('disabled');
                        scanState = 'IDLE';
                    }, 2500);
                } else {
                    // ==========================================
                    // ĐÃ CẬP NHẬT: KÍCH HOẠT SECURITY AI KHI PHÁT HIỆN NGƯỜI LẠ
                    // ==========================================
                    if (window.triggerSecurityAIAlert) {
                        window.triggerSecurityAIAlert("CẢNH BÁO: Trạm giám sát phát hiện <b>đối tượng không xác định</b> đang cố gắng truy cập cổng chính. Yêu cầu tổ bảo vệ tăng cường quan sát!");
                    } else {
                        Swal.fire('Cảnh báo', 'Phát hiện đối tượng không có trong CSDL!', 'error');
                    }
                    resetState(btn);
                }
            } else {
                Swal.fire('Lỗi', 'Không nhận diện được khuôn mặt!', 'warning');
                resetState(btn);
            }
        }, 1500);
    }

    function resetState(btn) {
        btn.innerHTML = '<i class="bi bi-shield-lock-fill"></i> BẮT ĐẦU QUY TRÌNH QUÉT';
        btn.classList.remove('disabled');
        scanState = 'IDLE';
        document.getElementById('faceDoneOverlay').classList.add('d-none');
        document.getElementById('alprOverlay').classList.add('d-none');
        document.getElementById('alprWaiting').classList.remove('d-none');
    }

    function processCheckInOut(data) {
        const payload = { HoTen: data.hoTen, BienSoXe: data.bienSo, LoaiXe: data.loaiXe, HinhAnh: data.hinhAnh, ViTriDo: "" };
        fetch('/LichSuCheckIn/GhiNhatKy', {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
        })
        .then(res => res.json())
        .then(result => {
            document.getElementById('resPlate').innerText = data.bienSo || "---";
            document.getElementById('resHuong').innerText = result.huong.toUpperCase();

            let loaiXeBadge = document.getElementById('resLoaiXeText');
            loaiXeBadge.innerText = (data.loaiXe || "---").toUpperCase();
            loaiXeBadge.className = "badge bg-primary rounded-pill px-3 py-2 fs-6 mt-1 shadow-sm";

            openGate();
        });
    }

    function openGate() {
        const gate = document.getElementById('gateButton');
        gate.className = "btn btn-success py-3 fw-bold fs-4 shadow pulse-bg rounded-4 letter-spacing-1";
        gate.innerHTML = "<i class='bi bi-unlock-fill'></i> MỜI VÀO - CỔNG MỞ";
        setTimeout(resetResult, 5000);
    }

    function captureSnapshot() {
        let c = document.createElement('canvas');
        c.width = video.videoWidth; c.height = video.videoHeight;
        let ctx = c.getContext('2d');
        ctx.translate(c.width, 0); ctx.scale(-1, 1);
        ctx.drawImage(video, 0, 0, c.width, c.height);
        return c.toDataURL('image/jpeg');
    }

    function resetResult() {
        document.getElementById('gateButton').className = "btn btn-secondary py-3 fw-bold disabled fs-4 rounded-4 letter-spacing-1";
        document.getElementById('gateButton').innerHTML = "<i class='bi bi-door-closed-fill'></i> CỔNG ĐANG ĐÓNG";
        document.getElementById('resName').innerText = "ĐANG CHỜ...";
        document.getElementById('resAvatar').src = "/images/face-id.png";
        document.getElementById('faceDoneOverlay').classList.add('d-none');
    }
</script>