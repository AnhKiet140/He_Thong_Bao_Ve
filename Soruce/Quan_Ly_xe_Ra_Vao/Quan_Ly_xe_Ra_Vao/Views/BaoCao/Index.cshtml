@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.LichSuCheckIn>
@{
    ViewData["Title"] = "Báo Cáo Chấm Công & An Ninh";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-2 animate__animated animate__fadeIn">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm border-start border-5 border-primary">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-bar-chart-line-fill text-primary"></i> BÁO CÁO TỔNG QUAN HỆ THỐNG</h4>
            <small class="text-muted fw-bold">KỲ BÁO CÁO: <strong>@ViewBag.SelectedDate</strong></small>
        </div>

        <div class="d-flex gap-3 align-items-center mt-3 mt-md-0">
            <form id="reportDateForm" method="get" asp-action="Index" class="m-0">
                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                    <span class="input-group-text bg-white border-0 text-primary"><i class="bi bi-calendar-event-fill"></i></span>
                    <input type="date" name="selectedDate" id="selectedDate" value="@ViewBag.SelectedDate"
                           class="form-control border-0 fw-bold text-dark shadow-none"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")"
                           onchange="document.getElementById('reportDateForm').submit();" style="cursor: pointer;" />
                </div>
            </form>

            <button onclick="exportToExcel()" class="btn btn-success fw-bold shadow-sm rounded-pill px-4 pulse-button">
                <i class="bi bi-file-earmark-excel-fill"></i> XUẤT EXCEL
            </button>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 rounded-4 shadow-sm text-white stat-card h-100" style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);">
                <div class="card-body p-4 position-relative overflow-hidden d-flex justify-content-between align-items-center">
                    <div class="z-1 position-relative">
                        <p class="text-uppercase fw-bold mb-1 opacity-75 small">Tổng Lượt Xe Ra Vào</p>
                        <h1 class="display-4 fw-bolder mb-0">@(ViewBag.TongVaoRa ?? 0)</h1>
                        <span class="badge bg-white text-primary rounded-pill mt-2 fw-bold"><i class="bi bi-activity"></i> Hoạt động ổn định</span>
                    </div>
                    <i class="bi bi-car-front-fill position-absolute stat-bg-icon"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 rounded-4 shadow-sm text-dark stat-card h-100" style="background: linear-gradient(135deg, #0dcaf0 0%, #0bacce 100%);">
                <div class="card-body p-4 position-relative overflow-hidden d-flex justify-content-between align-items-center">
                    <div class="z-1 position-relative">
                        <p class="text-uppercase fw-bold mb-1 opacity-75 small">Khách Ngoài Đăng Ký</p>
                        <h1 class="display-4 fw-bolder mb-0 text-white">@(ViewBag.KhachNgoai ?? 0)</h1>
                        <span class="badge bg-dark bg-opacity-25 text-white rounded-pill mt-2 fw-bold"><i class="bi bi-funnel-fill"></i> Đã được duyệt</span>
                    </div>
                    <i class="bi bi-people-fill position-absolute stat-bg-icon text-white opacity-25"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 rounded-4 shadow-sm text-white stat-card h-100" style="background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);">
                <div class="card-body p-4 position-relative overflow-hidden d-flex justify-content-between align-items-center">
                    <div class="z-1 position-relative">
                        <p class="text-uppercase fw-bold mb-1 opacity-75 small">Cảnh Báo An Ninh</p>
                        <h1 class="display-4 fw-bolder mb-0">@(ViewBag.CanhBao ?? 0)</h1>
                        <span class="badge bg-white text-danger rounded-pill mt-2 fw-bold"><i class="bi bi-shield-lock-fill"></i> Cần lưu ý đối tượng lạ</span>
                    </div>
                    <i class="bi bi-exclamation-triangle-fill position-absolute stat-bg-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100 rounded-4 p-4 card-hover">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-3 me-3"><i class="bi bi-graph-up-arrow fs-4"></i></div>
                    <h6 class="fw-bold text-dark mb-0 text-uppercase">SƠ ĐỒ LƯU LƯỢNG 7 NGÀY QUA</h6>
                </div>
                <div style="position: relative; height:300px; width:100%">
                    <canvas id="lineChartCanvas"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card shadow-sm border-0 h-100 rounded-4 p-4 card-hover">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded-3 me-3"><i class="bi bi-pie-chart-fill fs-4"></i></div>
                    <h6 class="fw-bold text-dark mb-0 text-uppercase">TỶ LỆ CHẤM CÔNG HÔM NAY</h6>
                </div>
                <div style="position: relative; height:300px; width:100%">
                    <canvas id="pieChartCanvas"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 card-hover">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
            <div class="icon-box bg-dark text-white rounded-3 me-3" style="width: 35px; height: 35px;"><i class="bi bi-list-columns-reverse"></i></div>
            <h6 class="fw-bold text-dark mb-0 text-uppercase">CHI TIẾT RA VÀO (NGÀY @ViewBag.SelectedDate)</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table id="reportTable" class="table table-hover align-middle mb-0 custom-table-font">
                    <thead class="table-light text-muted fw-bold text-uppercase sticky-top" style="font-size: 0.8rem; z-index: 2;">
                        <tr>
                            <th class="ps-4">Thời Gian</th>
                            <th>Họ Tên</th>
                            <th>Đối Tượng</th>
                            <th>Phương Thức / Biển Số</th>
                            <th>Hướng</th>
                            <th class="text-center pe-4">Trạng Thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 font-monospace text-muted">@item.ThoiGian.ToString("HH:mm:ss")</td>
                                    <td class="fw-bold text-dark text-capitalize">@item.HoTen</td>
                                    <td><span class="badge bg-secondary bg-opacity-10 text-dark border">@item.LoaiDoiTuong</span></td>
                                    <td>
                                        <span class="d-block fw-bold text-primary font-monospace">@item.BienSoXe</span>
                                        <small class="text-muted" style="font-size: 0.72rem;">@item.PhuongThuc</small>
                                    </td>
                                    <td>
                                        @if (item.Huong == "Đi Vào")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-box-arrow-in-right"></i> Đi Vào</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-box-arrow-left"></i> Đi Ra</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        @if (item.TrangThai == "Thành Công")
                                        {
                                            <span class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> OK</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="bi bi-exclamation-triangle-fill"></i> CẢNH BÁO LẠ</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block opacity-50 mb-3"></i>
                                    <b>Không có dữ liệu ra vào trong ngày này.</b>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    /* CSS Icon Box */
    .icon-box {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* CSS Bảng */
    .custom-table-font tbody tr {
        transition: background-color 0.2s ease;
        cursor: pointer;
    }

        .custom-table-font tbody tr:hover {
            background-color: #f8f9fa;
        }

    .sticky-top {
        top: 0;
    }

    /* Card hiệu ứng nảy */
    .card-hover {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
        }

    /* Card Thống kê màu Gradient */
    .stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .stat-bg-icon {
        font-size: 6rem;
        right: -10px;
        bottom: -20px;
        opacity: 0.2;
        transform: rotate(-15deg);
        transition: transform 0.3s ease;
    }

    .stat-card:hover .stat-bg-icon {
        transform: rotate(0deg) scale(1.1);
    }

    /* Nút Excel nhấp nháy */
    .pulse-button {
        animation: pulse 2.5s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.6);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(25, 135, 84, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // --- Vẽ biểu đồ Line (Đã custom lại màu cho đẹp) ---
        const lineCtx = document.getElementById('lineChartCanvas').getContext('2d');
        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.LabelsCot ?? "'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'")],
                datasets: [{
                    label: 'Số Lượt Ra/Vào',
                    data: [@Html.Raw(ViewBag.DataCot ?? "0,0,0,0,0,0,0")],
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    pointBackgroundColor: '#0d6efd',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // --- Vẽ biểu đồ Doughnut (Giữ nguyên logic của bạn, custom màu) ---
        const pieCtx = document.getElementById('pieChartCanvas').getContext('2d');
        new Chart(pieCtx, {
            type: 'doughnut',
            data: {
                labels: ['Đúng giờ', 'Đi Trễ', 'Chưa Check-in'],
                datasets: [{
                    data: [@(ViewBag.DungGio ?? 0), @(ViewBag.DiTre ?? 0), @(ViewBag.ChuaCheckIn ?? 0)],
                    backgroundColor: ['#198754', '#ffc107', '#dc3545'],
                    borderWidth: 0
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { position: 'bottom' } } }
        });
    });

    // --- HÀM XUẤT EXCEL (Giữ nguyên code cực xịn của bạn) ---
    function exportToExcel() {
        let table = document.getElementById("reportTable");
        if (!table) return;

        let ws = XLSX.utils.table_to_sheet(table);
        const borderStyle = {
            top: { style: "thin", color: { rgb: "000000" } }, bottom: { style: "thin", color: { rgb: "000000" } },
            left: { style: "thin", color: { rgb: "000000" } }, right: { style: "thin", color: { rgb: "000000" } }
        };

        const range = XLSX.utils.decode_range(ws['!ref']);
        for (let R = range.s.r; R <= range.e.r; ++R) {
            for (let C = range.s.c; C <= range.e.c; ++C) {
                let cell_address = { c: C, r: R };
                let cell_ref = XLSX.utils.encode_cell(cell_address);
                if (!ws[cell_ref]) continue;
                if (!ws[cell_ref].s) ws[cell_ref].s = {};

                ws[cell_ref].s.border = borderStyle;
                ws[cell_ref].s.alignment = { horizontal: "center", vertical: "center" };
                ws[cell_ref].s.font = { name: "Arial", sz: 11 };

                if (R === 0) {
                    ws[cell_ref].s.fill = { fgColor: { rgb: "0D6EFD" } };
                    ws[cell_ref].s.font = { color: { rgb: "FFFFFF" }, bold: true, sz: 12 };
                }
            }
        }

        ws['!cols'] = [ {wch: 15}, {wch: 25}, {wch: 15}, {wch: 30}, {wch: 12}, {wch: 15} ];
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Bao_Cao_An_Ninh");
        let reportDate = document.getElementById("selectedDate").value || 'today';
        XLSX.writeFile(wb, "BaoCao_AnNinh_" + reportDate + ".xlsx");
    }
</script>