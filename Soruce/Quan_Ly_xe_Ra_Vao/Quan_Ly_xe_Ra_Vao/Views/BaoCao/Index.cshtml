@{
    ViewData["Title"] = "Báo Cáo Chấm Công & An Ninh";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .square-box { border-radius: 0 !important; }
    .stat-card { border-left: 5px solid; transition: 0.3s; }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>

<div class="container-fluid mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-dark border-2">
        <h3 class="fw-bold text-uppercase mb-0">TỔNG QUAN HỆ THỐNG - @DateTime.Now.ToString("MM/yyyy")</h3>
        <button class="btn btn-success square-box fw-bold px-4"><i class="bi bi-file-earmark-spreadsheet"></i> XUẤT BÁO CÁO TỔNG</button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card square-box stat-card border-primary shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">TỔNG LƯỢT XE RA VÀO (HÔM NAY)</h6>
                    <h2 class="fw-bold text-dark mb-0">@ViewBag.TongRaVao <span class="text-success fs-6"><i class="bi bi-arrow-up"></i> Hoạt động</span></h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card square-box stat-card border-info shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">KHÁCH NGOÀI ĐĂNG KÝ</h6>
                    <h2 class="fw-bold text-info mb-0">@ViewBag.KhachNgoai</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card square-box stat-card border-danger shadow-sm h-100">
                <div class="card-body">
                    <h6 class="text-muted fw-bold text-uppercase">CẢNH BÁO AN NINH (SAI MẶT/LẠ)</h6>
                    <h2 class="fw-bold text-danger mb-0">@ViewBag.CanhBao</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card square-box border-dark shadow-sm h-100">
                <div class="card-header bg-dark text-white square-box fw-bold py-2 text-uppercase">
                    <i class="bi bi-bar-chart-fill"></i> SƠ ĐỒ LƯU LƯỢNG RA VÀO (7 NGÀY QUA)
                </div>
                <div class="card-body p-4">
                    <canvas id="barChart" height="100"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card square-box border-dark shadow-sm h-100">
                <div class="card-header bg-dark text-white square-box fw-bold py-2 text-uppercase">
                    <i class="bi bi-pie-chart-fill"></i> TỶ LỆ CHẤM CÔNG SÁNG NAY
                </div>
                <div class="card-body d-flex justify-content-center align-items-center p-4">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. VẼ BIỂU ĐỒ BẬC THANG (CỘT)
    const ctxBar = document.getElementById('barChart').getContext('2d');
    new Chart(ctxBar, {
        type: 'bar',
        data: {
            labels: [@Html.Raw(ViewBag.LabelsCot)], // Lấy mảng ngày từ C#
            datasets: [{
                label: 'Lượt Check-in/out',
                data: [@ViewBag.DataCot], // Lấy mảng dữ liệu từ C#
                backgroundColor: '#0d6efd',
                borderColor: '#0a58ca',
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });

    // 2. VẼ BIỂU ĐỒ TRÒN (CHẤM CÔNG)
    const ctxPie = document.getElementById('pieChart').getContext('2d');
    new Chart(ctxPie, {
        type: 'doughnut', // doughnut là biểu đồ tròn khoét lỗ ở giữa
        data: {
            labels: ['Đúng giờ', 'Đi Trễ', 'Chưa Check-in'],
            datasets: [{
                data: [@ViewBag.DungGio, @ViewBag.DiTre, @ViewBag.ChuaCheckIn],
                backgroundColor: ['#198754', '#ffc107', '#dc3545'], // Xanh, Vàng, Đỏ
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });
</script>