@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.DangKyKhach>

@{
    var isGiamDoc = ViewBag.UserRole == "GiamDoc";
    ViewData["Title"] = isGiamDoc ? "Hộp Thư Giám Đốc" : "Bảo Vệ - Duyệt Khách Vãng Lai";
    
    // ĐÃ FIX: Dùng ToLower() và Contains để bắt chính xác dù lưu trong DB là "Chờ duyệt" hay "Chờ Duyệt"
    var choDuyetList = Model.Where(x => !string.IsNullOrEmpty(x.TrangThaiDuyet) && x.TrangThaiDuyet.ToLower().Contains("chờ")).ToList();
    var daDuyetList = Model.Where(x => !string.IsNullOrEmpty(x.TrangThaiDuyet) && x.TrangThaiDuyet.ToLower().Contains("đã")).ToList();
}

<div class="container mt-4 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-uppercase fw-bold text-primary mb-0">
            @if (isGiamDoc) {
                <i class="bi bi-bell-fill text-warning pulse-animation"></i> <span>HỘP THƯ GIÁM ĐỐC: YÊU CẦU XIN GẶP</span>
            } else {
                <i class="bi bi-shield-lock"></i> <span>DANH SÁCH KHÁCH TRONG NGÀY</span>
            }
        </h2>
    </div>

    <form method="get" asp-action="DanhSachChoDuyet" class="mb-4 bg-white p-3 rounded-4 shadow-sm border border-2 border-primary border-opacity-10">
        <div class="row g-2">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-light border-secondary"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control border-secondary" placeholder="Tìm theo tên khách..." />
                </div>
            </div>
            <div class="col-md-5">
                <select name="filterBoPhan" class="form-select border-secondary">
                    <option value="">-- Tất cả phòng ban cần gặp --</option>
                    @if(ViewBag.BoPhanList != null)
                    {
                        foreach (var bp in ViewBag.BoPhanList)
                        {
                            if (ViewBag.FilterBoPhan == bp) {
                                <option value="@bp" selected>@bp</option>
                            } else {
                                <option value="@bp">@bp</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm"><i class="bi bi-funnel-fill"></i> LỌC</button>
                <a asp-action="DanhSachChoDuyet" class="btn btn-secondary shadow-sm" title="Làm mới"><i class="bi bi-arrow-clockwise"></i></a>
            </div>
        </div>
    </form>

    <ul class="nav nav-tabs fs-5 fw-bold mb-4" id="guestTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active text-warning bg-light rounded-top-3" id="cho-duyet-tab" data-bs-toggle="tab" data-bs-target="#choDuyet" type="button" role="tab">
                <i class="bi bi-hourglass-split"></i> CHỜ DUYỆT (@choDuyetList.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link text-success bg-light rounded-top-3" id="da-duyet-tab" data-bs-toggle="tab" data-bs-target="#daDuyet" type="button" role="tab">
                <i class="bi bi-check-circle-fill"></i> ĐÃ DUYỆT (@daDuyetList.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content" id="guestTabsContent">
        
        <div class="tab-pane fade show active" id="choDuyet" role="tabpanel">
            @if (!choDuyetList.Any()) {
                <div class="alert alert-success fs-5 shadow-sm border-0 bg-success bg-opacity-10 text-success fw-bold p-4 rounded-4 text-center">
                    <i class="bi bi-emoji-smile fs-3 d-block mb-2"></i> Không có yêu cầu chờ duyệt nào!
                </div>
            } else {
                <div class="row">
                    @foreach (var item in choDuyetList) {
                        RenderGuestCard(item, true); 
                    }
                </div>
            }
        </div>

        <div class="tab-pane fade" id="daDuyet" role="tabpanel">
            @if (!daDuyetList.Any()) {
                <div class="alert alert-secondary fs-5 shadow-sm border-0 p-4 rounded-4 text-center text-muted fw-bold">
                    <i class="bi bi-info-circle fs-3 d-block mb-2"></i> Chưa có khách nào được duyệt trong hôm nay.
                </div>
            } else {
                <div class="row">
                    @foreach (var item in daDuyetList) {
                        RenderGuestCard(item, false);
                    }
                </div>
            }
        </div>
    </div>
</div>

@functions {
    void RenderGuestCard(Quan_Ly_xe_Ra_Vao.Models.DangKyKhach item, bool isPending)
    {
        var userRole = ViewBag.UserRole as string;
        var isBaoVe = userRole == "BaoVe";

        <div class="col-md-6 col-xl-4 mb-4" id="card-@item.Id">
            <div class="card shadow-sm border-0 rounded-4 h-100 overflow-hidden custom-card">
                <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center py-3">
                    <span class="text-truncate me-2 fs-5">@item.HoTen</span>
                    @if(isPending) { 
                        <span class="badge bg-warning text-dark pulse-animation rounded-pill px-3 py-2 shadow-sm">Chờ duyệt</span> 
                    }
                    else { 
                        <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">Đã duyệt</span> 
                    }
                </div>
                <div class="card-body bg-white text-center position-relative">
                    <span class="position-absolute top-0 start-0 m-3 badge bg-danger rounded-pill shadow-sm fs-6">
                        <i class="bi bi-people-fill"></i> @item.SoLuongNguoi người
                    </span>

                    <img src="@item.FaceDataPath" onerror="this.src='/images/no-avatar.png'" class="img-thumbnail rounded-circle mb-3 shadow border-3 border-primary border-opacity-25" style="width: 120px; height: 120px; object-fit: cover;" />
                    
                    <table class="table table-sm table-borderless text-start mb-0">
                        <tr><td class="text-muted fw-bold" width="35%"><i class="bi bi-clock-history text-secondary"></i> Giờ hẹn:</td><td class="fw-bold text-danger">@item.ThoiGianHen.ToString("dd/MM/yyyy HH:mm")</td></tr>
                        
                        <tr>
                            <td class="text-muted fw-bold"><i class="bi bi-person-lines-fill text-secondary"></i> Cần gặp:</td>
                            <td class="fw-bold text-primary">
                                @(string.IsNullOrEmpty(item.NhanVienCanGap) ? "Chưa rõ" : item.NhanVienCanGap)
                                <br><small class="text-muted">(@item.BoPhanCanGap)</small>
                            </td>
                        </tr>
                        
                        <tr><td class="text-muted fw-bold"><i class="bi bi-card-text text-secondary"></i> Lý do:</td><td class="text-dark">@item.LyDo</td></tr>
                        <tr><td class="text-muted fw-bold"><i class="bi bi-car-front-fill text-secondary"></i> Xe cộ:</td><td class="text-dark font-monospace fw-bold">@item.LoaiXe (@item.BienSoXe)</td></tr>
                    </table>
                </div>
                
                @if(isPending) {
                    <div class="card-footer bg-light border-top-0 p-3 d-flex justify-content-between gap-2">
                        @if (isBaoVe && (item.BoPhanCanGap == "BOD" || item.BoPhanCanGap == "Ban Giám Đốc" || item.BoPhanCanGap == "HR")) {
                            <span class="w-100 text-center text-warning fw-bold p-2 border border-warning rounded-3 bg-white shadow-sm" style="font-size: 0.9em;">
                                <i class="bi bi-lock-fill"></i> CHỜ XÉT DUYỆT
                            </span>
                        } else {
                            <button onclick="xuLyKhach(@item.Id, 'TuChoi')" class="btn btn-outline-danger fw-bold w-50 rounded-pill shadow-sm"><i class="bi bi-x-circle-fill"></i> TỪ CHỐI</button>
                            <button onclick="xuLyKhach(@item.Id, 'Duyet')" class="btn btn-success fw-bold w-50 rounded-pill shadow-sm"><i class="bi bi-check-circle-fill"></i> DUYỆT</button>
                        }
                    </div>
                } else {
                    @if(isBaoVe) {
                        <div class="card-footer bg-light border-top-0 p-3">
                            <button onclick="checkInKhach(@item.Id)" class="btn btn-primary w-100 fw-bold shadow-sm rounded-pill py-2">
                                <i class="bi bi-box-arrow-in-right fs-5 align-middle me-1"></i> XÁC NHẬN VÀO CỔNG
                            </button>
                        </div>
                    } else {
                        <div class="card-footer bg-success bg-opacity-10 border-top-0 text-center text-success fw-bold p-3">
                            <i class="bi bi-shield-check fs-5 align-middle me-1"></i> ĐÃ CẤP QUYỀN TRUY CẬP
                        </div>
                    }
                }
            </div>
        </div>
    }
}

<style>
    .pulse-animation { animation: pulse 1.5s infinite; display: inline-block; }
    @@keyframes pulse {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.7); }
        50% { transform: scale(1.05); box-shadow: 0 0 10px 0 rgba(255, 193, 7, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 193, 7, 0); }
    }
    .nav-tabs .nav-link { color: #495057; border: none; padding: 12px 20px; transition: 0.3s; }
    .nav-tabs .nav-link.active { border-bottom: 3px solid #0d6efd; color: #0d6efd !important; background-color: transparent !important; }
    .custom-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .custom-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function xuLyKhach(id, hanhDong) {
        let title = hanhDong === 'Duyet' ? "Cấp quyền cho khách vào?" : "Từ chối yêu cầu này?";
        let textInfo = hanhDong === 'Duyet' ? "Khách sẽ được đẩy xuống cổng bảo vệ để Check-in." : "Hồ sơ của khách sẽ bị từ chối.";
        
        Swal.fire({
            title: title, 
            text: textInfo,
            icon: hanhDong === 'Duyet' ? 'question' : 'warning', 
            showCancelButton: true,
            confirmButtonColor: hanhDong === 'Duyet' ? '#198754' : '#dc3545',
            confirmButtonText: '<i class="bi bi-check-lg"></i> Đồng ý', 
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch(`/DangKyKhach/XuLyDuyet?id=${id}&hanhDong=${hanhDong}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        Swal.fire({ title: 'Thành công', text: data.message, icon: 'success', timer: 1500, showConfirmButton: false });
                        setTimeout(() => { location.reload(); }, 1500); 
                    } else {
                        Swal.fire('Lỗi', data.message, 'error'); 
                    }
                });
            }
        });
    }

    function checkInKhach(id) {
        Swal.fire({
            title: 'Xác nhận khách vào?',
            text: 'Thông tin sẽ được ghi vào Sổ Trực Ban ngay lập tức!',
            icon: 'info',
            showCancelButton: true,
            confirmButtonColor: '#0d6efd',
            confirmButtonText: '<i class="bi bi-box-arrow-in-right"></i> Xác nhận',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch(`/DangKyKhach/CheckInTaiCong?id=${id}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        Swal.fire({ title: 'Đã vào cổng!', text: data.message, icon: 'success', timer: 1500, showConfirmButton: false });
                        setTimeout(() => { location.reload(); }, 1500); 
                    } else {
                        Swal.fire('Lỗi', data.message, 'error');
                    }
                });
            }
        });
    }
</script>