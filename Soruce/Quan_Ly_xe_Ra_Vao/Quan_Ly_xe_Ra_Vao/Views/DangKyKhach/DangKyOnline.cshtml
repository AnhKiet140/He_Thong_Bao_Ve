@model Quan_Ly_xe_Ra_Vao.Models.DangKyKhach
@{
    Layout = null; // Trang đăng ký online thường đứng độc lập, không dùng chung Layout Sidebar
    ViewData["Title"] = "Đăng Ký Khách Hẹn Online";
}

<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - CHK-IN PRO</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        body {
            background-color: #f0f2f5;
            font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .form-container {
            max-width: 550px;
            margin: 0 auto;
            background: #fff;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border-radius: 0 0 20px 20px;
        }

        .header-bg {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            padding: 20px 15px;
            text-align: center;
            color: white;
            border-bottom-left-radius: 20px;
            border-bottom-right-radius: 20px;
        }

        .step-title {
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }

            .step-title i {
                margin-right: 8px;
                font-size: 1.2rem;
            }

        /* Camera Box */
        .camera-wrapper {
            width: 100%;
            max-width: 250px;
            height: 250px;
            background-color: #212529;
            margin: 0 auto;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 4px dashed #ced4da;
            overflow: hidden;
            position: relative;
        }

        /* Form Customization */
        .form-label {
            font-weight: 600;
            font-size: 0.85rem;
            color: #495057;
            margin-bottom: 6px;
        }

        .input-group-text {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }

        .form-control, .form-select {
            padding: 12px 15px;
            font-size: 1rem;
            border-color: #dee2e6;
            background-color: #ffffff;
        }

            .form-control:focus, .form-select:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
            }

            .form-control:disabled {
                background-color: #e9ecef;
                cursor: not-allowed;
                font-weight: bold;
                color: #6c757d;
            }

        .required-star {
            color: #dc3545;
            margin-left: 3px;
        }

        .btn-submit {
            background: #198754;
            border: none;
            padding: 14px;
            font-size: 1.1rem;
            font-weight: bold;
            transition: 0.2s;
        }

            .btn-submit:hover {
                background: #146c43;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="form-container animate__animated animate__fadeInUp pb-4 mb-5 min-vh-100">

        <div class="header-bg mb-4 shadow-sm">
            <h4 class="fw-bold mb-1"><i class="bi bi-person-vcard me-2"></i>ĐĂNG KÝ KHÁCH HẸN</h4>
            <small class="opacity-75">Vui lòng điền thông tin để nhận mã QR Check-in</small>
        </div>

        <form id="guestForm" class="px-4">

            <div class="mb-5">
                <div class="step-title text-danger"><i class="bi bi-camera-fill"></i> BƯỚC 1: CHỤP ẢNH NHẬN DIỆN <span class="required-star">*</span></div>
                <div class="camera-wrapper shadow-sm mb-3">
                    <video id="guestWebcam" autoplay playsinline style="width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1);"></video>
                    <img id="guestSnapshot" style="display: none; width: 100%; height: 100%; object-fit: cover;" />
                </div>
                <div class="text-center">
                    <button type="button" class="btn btn-warning fw-bold rounded-pill px-4 shadow-sm" id="btnCapture" onclick="takeSnapshot()">
                        <i class="bi bi-camera me-1"></i> CHỤP ẢNH FACE-ID
                    </button>
                    <button type="button" class="btn btn-secondary fw-bold rounded-pill px-4 shadow-sm" id="btnRetake" style="display: none;" onclick="retakeSnapshot()">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> CHỤP LẠI
                    </button>
                </div>
            </div>

            <hr class="text-muted opacity-25 mb-4">

            <div>
                <div class="step-title text-primary"><i class="bi bi-card-checklist"></i> BƯỚC 2: THÔNG TIN ĐĂNG KÝ</div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">HỌ VÀ TÊN ĐẠI DIỆN <span class="required-star">*</span></label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light"><i class="bi bi-person text-secondary"></i></span>
                            <input type="text" id="HoTen" name="HoTen" class="form-control border-start-0" placeholder="Nhập tên của bạn" required>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">SỐ LƯỢNG NGƯỜI ĐI CÙNG <span class="required-star">*</span></label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light"><i class="bi bi-people text-secondary"></i></span>
                            <input type="number" id="SoLuongNguoi" name="SoLuongNguoi" class="form-control border-start-0" value="1" min="1" max="10" oninput="validateGuestCount(this)" required>
                        </div>
                        <small class="text-danger fw-bold mt-1 d-block" id="guestCountError"></small>
                    </div>

                    <div class="col-12">
                        <label class="form-label">PHƯƠNG TIỆN DI CHUYỂN <span class="required-star">*</span></label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light" id="vehicle-icon">
                                <i class="bi bi-person-walking text-success fs-5"></i>
                            </span>
                            <select id="LoaiXe" name="LoaiXe" class="form-select border-start-0 fw-bold" onchange="updateVehicleLogic()">
                                <option value="Không đi phương tiện" selected>Không có xe (Đi bộ/Grab)</option>
                                <option value="Đi xe máy">Xe máy</option>
                                <option value="Đi ô tô / bán tải">Ô tô / Bán tải</option>
                                <option value="Đi xe tải">Xe tải</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">BIỂN SỐ XE</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light"><i class="bi bi-123 text-secondary"></i></span>
                            <input type="text" id="BienSoXe" name="BienSoXe" class="form-control border-start-0 font-monospace text-uppercase" placeholder="Không cần điền" disabled>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">BỘ PHẬN CẦN GẶP <span class="required-star">*</span></label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light"><i class="bi bi-building text-secondary"></i></span>
                            <select id="BoPhanCanGap" name="BoPhanCanGap" class="form-select border-start-0" onchange="loadEmployees()" required>
                                <option value="" selected disabled>-- Chọn phòng ban --</option>
                                <option value="BOD">Ban Giám Đốc</option>
                                <option value="HR">Phòng Nhân Sự</option>
                                <option value="ACC">Phòng Kế Toán</option>
                                <option value="IT">Phòng Công Nghệ</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">NGƯỜI CẦN GẶP <span class="required-star">*</span></label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light"><i class="bi bi-person-badge text-secondary"></i></span>
                            <select id="NhanVienCanGap" name="NhanVienCanGap" class="form-select border-start-0" disabled required>
                                <option value="" selected disabled>-- Chọn bộ phận trước --</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">THỜI GIAN ĐẾN HẸN <span class="required-star">*</span></label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <span class="input-group-text border-end-0 bg-light"><i class="bi bi-calendar-event text-secondary"></i></span>
                            <input type="datetime-local" id="ThoiGianHen" name="ThoiGianHen" class="form-control border-start-0" required>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">LÝ DO VÀO CÔNG TY <span class="required-star">*</span></label>
                        <textarea id="LyDo" name="LyDo" class="form-control rounded-3 shadow-sm" rows="3" placeholder="Ghi rõ lý do (VD: Phỏng vấn, Giao hàng, Gặp đối tác...)" required></textarea>
                    </div>

                    <div class="col-12 mt-4 pt-2">
                        <button type="button" onclick="submitForm()" class="btn btn-submit text-white w-100 rounded-pill shadow">
                            <i class="bi bi-send-fill me-2"></i> GỬI ĐĂNG KÝ HỒ SƠ
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // --- 1. DỮ LIỆU BỘ PHẬN ---
        const departmentData = {
            "BOD": ["Sếp (Test Giám Đốc)"],
            "HR": ["Quản Lý (Test Nhân Sự)"],
            "ACC": ["Kế toán trưởng"],
            "IT": ["Admin System"]
        };

        function loadEmployees() {
            const dept = document.getElementById('BoPhanCanGap').value;
            const empSelect = document.getElementById('NhanVienCanGap');
            empSelect.innerHTML = '<option value="" selected disabled>-- Chọn người cần gặp --</option>';

            if (dept && departmentData[dept]) {
                departmentData[dept].forEach(name => {
                    empSelect.innerHTML += `<option value="${name}">${name}</option>`;
                });
                empSelect.disabled = false;
            } else {
                empSelect.disabled = true;
            }
        }

        function validateGuestCount(input) {
            const errorSpan = document.getElementById('guestCountError');
            let val = parseInt(input.value);
            if (val > 10) {
                input.value = 10;
                errorSpan.innerText = "Giới hạn tối đa 10 người/lượt đăng ký!";
            } else if (val < 1 || isNaN(val)) {
                input.value = 1;
                errorSpan.innerText = "Phải có ít nhất 1 người!";
            } else {
                errorSpan.innerText = "";
            }
        }

        // --- 2. LOGIC BIỂN SỐ THÔNG MINH ---
        function updateVehicleLogic() {
            var selectedVehicle = document.getElementById("LoaiXe").value;
            var licensePlateInput = document.getElementById("BienSoXe");
            var iconSpan = document.getElementById("vehicle-icon");

            if (selectedVehicle === "Không đi phương tiện") {
                iconSpan.innerHTML = '<i class="bi bi-person-walking text-success fs-5"></i>';
                licensePlateInput.disabled = true;
                licensePlateInput.value = "";
                licensePlateInput.placeholder = "Không cần điền";
                licensePlateInput.required = false;
            }
            else {
                licensePlateInput.disabled = false;
                licensePlateInput.required = true;

                if (selectedVehicle === "Đi xe máy") {
                    iconSpan.innerHTML = '<i class="bi bi-bicycle text-warning fs-5"></i>';
                    licensePlateInput.placeholder = "VD: 59A1-123.45";
                }
                else if (selectedVehicle === "Đi ô tô / bán tải") {
                    iconSpan.innerHTML = '<i class="bi bi-car-front-fill text-primary fs-5"></i>';
                    licensePlateInput.placeholder = "VD: 51H-999.99";
                }
                else if (selectedVehicle === "Đi xe tải") {
                    iconSpan.innerHTML = '<i class="bi bi-truck-front-fill text-danger fs-5"></i>';
                    licensePlateInput.placeholder = "VD: 51C-888.88";
                }
            }
        }
        document.addEventListener("DOMContentLoaded", updateVehicleLogic);

        // --- 3. CAMERA FACE ID ---
        const video = document.getElementById('guestWebcam');
        const imgSnapshot = document.getElementById('guestSnapshot');
        let faceBase64 = "";

        navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } })
            .then(stream => { video.srcObject = stream; })
            .catch(err => { Swal.fire("Lỗi Camera", "Vui lòng cấp quyền truy cập Camera để đăng ký!", "error"); });

        function takeSnapshot() {
            let canvas = document.createElement('canvas');
            canvas.width = video.videoWidth; canvas.height = video.videoHeight;
            let ctx = canvas.getContext('2d');
            ctx.translate(canvas.width, 0); ctx.scale(-1, 1);
            ctx.drawImage(video, 0, 0);

            faceBase64 = canvas.toDataURL('image/jpeg');
            imgSnapshot.src = faceBase64;

            video.style.display = 'none';
            imgSnapshot.style.display = 'block';
            document.getElementById('btnCapture').style.display = 'none';
            document.getElementById('btnRetake').style.display = 'inline-block';
        }

        function retakeSnapshot() {
            faceBase64 = "";
            video.style.display = 'block';
            imgSnapshot.style.display = 'none';
            document.getElementById('btnCapture').style.display = 'inline-block';
            document.getElementById('btnRetake').style.display = 'none';
        }

        // --- 4. GỬI DỮ LIỆU ĐĂNG KÝ VỀ C# ---
        function submitForm() {
            if (!faceBase64) {
                Swal.fire('Lỗi', 'Vui lòng chụp ảnh khuôn mặt!', 'error'); return;
            }

            let isVehicleRequire = document.getElementById('BienSoXe').required;
            if (isVehicleRequire && !document.getElementById('BienSoXe').value) {
                Swal.fire('Thiếu thông tin', 'Vui lòng nhập Biển số xe để bảo vệ cấp phép qua cổng!', 'warning'); return;
            }

            let hoten = document.getElementById('HoTen').value;
            let soluong = document.getElementById('SoLuongNguoi').value;
            let bophan = document.getElementById('BoPhanCanGap').value;
            let nhanvien = document.getElementById('NhanVienCanGap').value;
            let thoigian = document.getElementById('ThoiGianHen').value;
            let lydo = document.getElementById('LyDo').value;

            if(!hoten || !bophan || !nhanvien || !thoigian || !lydo) {
                Swal.fire('Thiếu thông tin', 'Vui lòng điền đầy đủ các ô có dấu *', 'warning'); return;
            }

            let data = {
                HoTen: hoten,
                FaceDataPath: faceBase64,
                LoaiXe: document.getElementById('LoaiXe').value,
                BienSoXe: document.getElementById('BienSoXe').value,
                BoPhanCanGap: bophan,  // <-- CHỖ NÀY ĐÃ ĐƯỢC SỬA CHO KHỚP VỚI C#
                NhanVienCanGap: nhanvien,
                SoLuongNguoi: parseInt(soluong),
                ThoiGianHen: thoigian,
                LyDo: lydo
            };

            Swal.fire({
                title: 'Đang xử lý hồ sơ...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); }
            });

            fetch('/DangKyKhach/SubmitDangKy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(result => {
                if(result.success) {
                    Swal.fire({
                        title: 'ĐĂNG KÝ THÀNH CÔNG!',
                        html: `
                            <p class="text-muted mb-3">Hồ sơ của bạn đã được gửi đến bộ phận liên quan để chờ phê duyệt.</p>
                            <div class="bg-danger bg-opacity-10 p-3 rounded-3 border border-danger mb-3">
                                <h6 class="fw-bold text-danger mb-2"><i class="bi bi-camera"></i> CHỤP LẠI MÀN HÌNH NÀY!</h6>
                                <p class="small text-dark fw-bold mb-0">Hãy chụp lại màn hình đăng ký này và xuất trình cho bảo vệ khi đến công ty.</p>
                            </div>
                        `,
                        icon: 'success',
                        confirmButtonText: '<i class="bi bi-arrow-repeat"></i> Xong & Đăng ký mới',
                        confirmButtonColor: '#198754',
                        allowOutsideClick: false
                    }).then((res) => {
                        if (res.isConfirmed) { window.location.reload(); }
                    });
                } else {
                    Swal.fire('Lỗi', result.message, 'error');
                }
            })
            .catch(err => {
                console.error(err);
                Swal.fire('Lỗi Trình Duyệt', 'Không thể kết nối đến máy chủ', 'error');
            });
        }
    </script>
</body>
</html>