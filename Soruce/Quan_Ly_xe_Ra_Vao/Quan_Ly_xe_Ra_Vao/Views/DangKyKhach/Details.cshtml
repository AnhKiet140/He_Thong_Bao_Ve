@model Quan_Ly_xe_Ra_Vao.Models.DangKyKhach
@{
    ViewData["Title"] = "Chi Tiết Hồ Sơ";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-person-vcard"></i> HỒ SƠ: @Model.HoTen.ToUpper()</h5>
            <a asp-action="Index" class="btn btn-sm btn-light fw-bold"><i class="bi bi-arrow-return-left"></i> Quay lại</a>
        </div>
        <div class="card-body row p-4">
            <div class="col-md-5 text-center mb-3">
                <img src="@Model.FaceDataPath" class="img-fluid rounded-3 shadow border border-3 border-light" style="max-height: 300px; object-fit: cover;" />
                <div class="mt-3">
                    <span class="badge fs-6 @(Model.TrangThaiDuyet == "Đã duyệt" ? "bg-success" : Model.TrangThaiDuyet == "Chờ duyệt" ? "bg-warning text-dark" : "bg-danger")">
                        Trạng thái: @Model.TrangThaiDuyet
                    </span>
                </div>
            </div>

            <div class="col-md-7">
                <table class="table table-borderless fs-5">
                    <tr><td class="text-muted" width="40%">Họ và Tên:</td><td class="fw-bold">@Model.HoTen</td></tr>
                    <tr><td class="text-muted">Bộ phận gặp:</td><td class="fw-bold text-primary">@Model.BoPhanCanGap</td></tr>
                    <tr><td class="text-muted">Giờ hẹn:</td><td class="fw-bold text-danger">@Model.ThoiGianHen.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr><td class="text-muted">Loại xe:</td><td>@Model.LoaiXe</td></tr>
                    <tr><td class="text-muted">Biển số:</td><td>@(string.IsNullOrEmpty(Model.BienSoXe) ? "Không có" : Model.BienSoXe)</td></tr>
                </table>
                <hr />
                <div class="bg-light p-3 rounded">
                    <span class="text-muted d-block mb-1">Lý do vào công ty:</span>
                    <span class="fw-bold">@Model.LyDo</span>
                </div>
            </div>
        </div>
    </div>
</div>