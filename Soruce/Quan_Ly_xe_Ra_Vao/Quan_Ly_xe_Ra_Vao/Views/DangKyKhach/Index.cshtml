@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.DangKyKhach>
@{
    ViewData["Title"] = "Quản Lý Hồ Sơ Khách";
}

<div class="container-fluid mt-3">
    <div class="card shadow-sm border-0 rounded-3 bg-card-custom">

        <div class="card-header bg-transparent border-bottom p-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <h4 class="fw-bold text-primary mb-0">
                <i class="bi bi-folder2-open me-2"></i> HỒ SƠ KHÁCH HÀNG
            </h4>

            <form id="filterForm" method="get" asp-action="Index" class="d-flex flex-wrap gap-2 align-items-center mb-0">

                <div class="input-group shadow-sm rounded-3 input-custom-group" style="width: 250px;">
                    <span class="input-group-text bg-transparent text-muted border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control border-start-0 bg-transparent text-body shadow-none" placeholder="Nhập tên khách..." />
                </div>

                <div class="input-group shadow-sm rounded-3 input-custom-group" style="width: 200px;">
                    <span class="input-group-text bg-transparent text-muted border-end-0"><i class="bi bi-calendar-check"></i></span>
                    <input type="date" name="selectedDate" id="selectedDate" value="@ViewBag.SelectedDate" class="form-control border-start-0 bg-transparent text-body shadow-none" onchange="document.getElementById('filterForm').submit();" style="cursor: pointer;" />
                </div>

                <button type="submit" class="btn btn-dark fw-bold shadow-sm rounded-3 px-3">Lọc</button>
                <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-3 me-2" title="Làm mới bộ lọc (Xóa bộ lọc)"><i class="bi bi-arrow-clockwise"></i></a>

                <button type="submit" asp-action="ExportExcel" formmethod="get" class="btn btn-success fw-bold shadow-sm rounded-3 px-3 d-flex align-items-center">
                    <i class="bi bi-file-earmark-excel-fill me-2"></i> Xuất Excel
                </button>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-table">
                    <thead class="table-light text-muted text-uppercase small fw-bold custom-thead">
                        <tr>
                            <th class="ps-4">Khách Hẹn</th>
                            <th>Thời Gian Hẹn</th>
                            <th>Bộ Phận / Lý Do</th>
                            <th class="text-center">Trạng Thái</th>
                            <th class="text-end pe-4">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody class="text-body">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var khach in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            @if (!string.IsNullOrEmpty(khach.FaceDataPath))
                                            {
                                                <img src="@khach.FaceDataPath" class="rounded-circle me-3 shadow-sm border border-secondary" style="width: 45px; height: 45px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/45'" />
                                            }
                                            else
                                            {
                                                <div class="rounded-circle me-3 bg-light d-flex align-items-center justify-content-center border border-secondary" style="width: 45px; height: 45px;">
                                                    <i class="bi bi-person text-secondary fs-4"></i>
                                                </div>
                                            }
                                            <div>
                                                <span class="fw-bold text-body text-capitalize">@khach.HoTen</span><br>
                                                <small class="text-muted"><i class="bi bi-car-front"></i> @(string.IsNullOrEmpty(khach.BienSoXe) ? "Không đi xe" : khach.BienSoXe)</small>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="fw-bold text-danger">@khach.ThoiGianHen.ToString("HH:mm")</div>
                                        <small class="text-muted">@khach.ThoiGianHen.ToString("dd/MM/yyyy")</small>
                                    </td>

                                    <td>
                                        <div class="fw-bold text-primary">@khach.BoPhanCanGap</div>
                                        <small class="text-muted text-truncate d-inline-block" style="max-width: 200px;" title="@khach.LyDo">@khach.LyDo</small>
                                    </td>

                                    <td class="text-center">
                                        @if (khach.TrangThaiDuyet == "Đã duyệt")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-check-circle"></i> Đã duyệt</span>
                                        }
                                        else if (khach.TrangThaiDuyet == "Từ chối")
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-x-circle"></i> Bị từ chối</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning border border-warning rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-hourglass-split"></i> Chờ duyệt</span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-1">
                                            <a asp-action="Details" asp-route-id="@khach.Id" class="btn btn-sm btn-outline-info shadow-sm" title="Xem chi tiết"><i class="bi bi-eye"></i></a>

                                            <form asp-action="Delete" asp-route-id="@khach.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa hồ sơ này?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i> Không tìm thấy hồ sơ khách hàng nào phù hợp.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS CHUNG (Light Mode mặc định) */
    .bg-card-custom {
        background-color: #ffffff;
    }

    .input-custom-group {
        background-color: #ffffff;
        border: 1px solid #dee2e6;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
    }

        .custom-table tbody tr:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

    .custom-table td {
        padding: 15px 10px;
        border-bottom: 1px solid #f1f3f5;
    }

    /* =========================================
           CSS TƯƠNG THÍCH DARK MODE
        ========================================= */
    [data-bs-theme="dark"] .bg-card-custom {
        background-color: #1e1e1e !important;
        border-color: #333 !important;
    }

    [data-bs-theme="dark"] .text-body {
        color: #e0e0e0 !important;
    }

    /* Ô input tìm kiếm / ngày */
    [data-bs-theme="dark"] .input-custom-group {
        background-color: #2c2c2c !important;
        border-color: #444 !important;
    }

    [data-bs-theme="dark"] input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(1);
    }

    [data-bs-theme="dark"] .form-control::placeholder {
        color: #888 !important;
    }

    /* Bảng dữ liệu */
    [data-bs-theme="dark"] .custom-table {
        color: #e0e0e0;
    }

    [data-bs-theme="dark"] .custom-thead {
        background-color: #2c2c2c !important;
        color: #ccc !important;
    }

        [data-bs-theme="dark"] .custom-thead th {
            border-bottom: 1px solid #444 !important;
            background-color: transparent !important;
        }

    [data-bs-theme="dark"] .custom-table td {
        border-bottom: 1px solid #333 !important;
    }

    [data-bs-theme="dark"] .custom-table tbody tr:hover {
        background-color: rgba(255,255,255,0.05);
    }

    /* Avatar Placeholder (Khi không có ảnh) */
    [data-bs-theme="dark"] .bg-light {
        background-color: #2c2c2c !important;
    }
</style>