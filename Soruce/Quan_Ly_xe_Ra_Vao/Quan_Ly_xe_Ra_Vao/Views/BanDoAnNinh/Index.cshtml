                    zoneInput.value = 'Tầng Hầm - Khu A (VIP & Khách)';
                    idInput.value = 'A-' + (dbCounters.vip + 1).toString().padStart(2, '0');
                    idInput.className = 'form-control fw-bold text-warning font-monospace fs-5 rounded-end-1';
                    iconSpan.innerHTML = '<i class="bi bi-star-fill text-warning"></i>';
                } else if (type === 'Khach') {
                    zoneInput.value = 'Tầng Hầm - Khu A (VIP & Khách)';
                    idInput.value = 'A-' + (dbCounters.guest + 1).toString().padStart(2, '0');
                    idInput.className = 'form-control fw-bold text-info font-monospace fs-5 rounded-end-1';
                    iconSpan.innerHTML = '<i class="bi bi-person-badge text-info"></i>';
                } else {
                    zoneInput.value = 'Tầng Hầm - Khu B (Nhân Viên)';
                    idInput.value = 'B-' + (dbCounters.emp + 1).toString().padStart(2, '0');
                    idInput.className = 'form-control fw-bold text-secondary font-monospace fs-5 rounded-end-1';
                    iconSpan.innerHTML = '<i class="bi bi-person-vcard text-secondary"></i>';
                }
            }

            function submitCreateParking() {
                const type = document.querySelector('input[name="parkType"]:checked').value;
                const slotId = document.getElementById('autoSlotId').value;
                let floor = type === 'NhanVien' ? 'B' : 'A';

                let processCreation = () => {
                    let textColor = type === 'Sep' ? 'text-warning' : (type === 'Khach' ? 'text-info' : 'text-secondary');
                    let borderClass = type === 'Sep' ? 'slot-vip' : (type === 'Khach' ? 'slot-customer' : 'slot-employee');
                    let typeLabel = type === 'Sep' ? 'VIP/SẾP' : (type === 'Khach' ? 'KHÁCH' : 'NHÂN VIÊN');
                    let typeIcon = type === 'Sep' ? '<i class="bi bi-star-fill mb-1"></i>' : (type === 'Khach' ? '<i class="bi bi-person-badge mb-1"></i>' : '<i class="bi bi-person-vcard mb-1"></i>');

                    const html = `
                        <div class="parking-slot ${borderClass} position-relative animate__animated animate__bounceIn">
                            <button class="btn btn-danger position-absolute top-0 end-0 p-0 rounded-circle d-flex align-items-center justify-content-center btn-delete-slot" onclick="deleteSlot('${slotId}', event)" title="Xóa bãi đỗ này">
                                <i class="bi bi-x" style="font-size: 14px; margin: 0;"></i>
                            </button>
                            <span class="${textColor}">${typeIcon}</span>
                            <span style="font-size: 0.5rem; opacity: 0.8" class="${textColor}">${typeLabel}</span>
                            <span class="fw-bold mt-1 ${textColor}">${slotId}</span>
                        </div>
                    `;

                    const container = document.getElementById(`dynamic-parking-${floor}`);
                    if (container) {
                        const grids = container.querySelectorAll('.parking-grid');
                        if(grids.length > 0) {
                            const lastGrid = grids[grids.length - 1];
                            if(lastGrid.children.length >= 24) {
                                // Chèn đường đi nội bộ
                                container.insertAdjacentHTML('beforeend', `<div class="mini-driveway my-2 text-center text-warning opacity-50 small font-monospace"><i class="bi bi-arrows-expand"></i> LỐI ĐI NỘI BỘ (LÙI XE) <i class="bi bi-arrows-expand"></i></div>`);
                                container.insertAdjacentHTML('beforeend', `<div class="parking-block mb-1"><div class="parking-grid">${html}</div></div>`);
                                // Kích hoạt lại Drag Drop cho grid mới
                                const newGrid = container.querySelectorAll('.parking-grid');
                                sortableParkingGrids.push(new Sortable(newGrid[newGrid.length - 1], { group: 'shared-parking', animation: 150, ghostClass: 'sortable-ghost' }));
                            } else {
                                lastGrid.insertAdjacentHTML('beforeend', html);
                            }
                        } else {
                            container.insertAdjacentHTML('beforeend', `<div class="parking-block mb-1"><div class="parking-grid">${html}</div></div>`);
                        }
                    }

                    // ĐỒNG BỘ CAMERA NGAY LẬP TỨC CHO Ô MỚI
                    const camContainer = document.getElementById(`cam-container-basement_${floor}`);
                    if(camContainer) {
                        camContainer.insertAdjacentHTML('beforeend', `
                        <div style="display:inline-block;" class="dynamic-cam-item animate__animated animate__fadeIn" data-slot="${slotId}">
                            <div class="cam-feed rounded-2" style="width: 350px; height: 220px;">
                                <div class="cam-content"><i class="bi bi-car-front text-white opacity-25"></i></div>
                                <div class="cam-status rounded-1"><i class="bi bi-circle-fill text-white small me-1"></i> REC</div>
                                <div class="cam-title"><i class="bi bi-geo-alt-fill text-info me-1"></i>Cam Ô ${slotId}</div>
                                <button class="btn-fullscreen rounded-1" onclick="toggleFullscreen(this.parentElement)" title="Phóng to"><i class="bi bi-arrows-fullscreen"></i></button>
                                <div class="cam-overlay"><span>CHK-IN // ${slotId}</span><span class="live-clock-cam text-info fw-bold"></span></div>
                            </div>
                        </div>`);
                    }

                    // Tự động đóng Form (YÊU CẦU 3)
                    closeFloatingWindow('window-manage-parking');
                    Swal.fire('Hoàn tất!', `Đã tạo vị trí <b>${slotId}</b>.`, 'success');

                    if(type === 'Khach') dbCounters.guest++;
                    if(type === 'NhanVien') dbCounters.emp++;
                };

                if (type === 'Sep') {
                    Swal.fire({
                        title: 'Tái cấu trúc Bãi Đỗ...', html: 'Hệ thống đang <b>dời các xe Khách xuống 1 vị trí</b> để nhường không gian cho VIP/Sếp.',
                        allowOutsideClick: false, didOpen: () => { Swal.showLoading() }
