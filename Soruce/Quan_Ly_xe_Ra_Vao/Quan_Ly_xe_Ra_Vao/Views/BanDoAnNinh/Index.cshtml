<script>
    const isAdmin = '@userRole' === 'Admin';
    let rawData = @Html.Raw(Json.Serialize(danhSachXeDangDau));
    let parkedCars = {};
    if (rawData) { rawData.forEach(car => { if(car.viTri) { let slotNormalized = car.viTri.replace(/\s+/g, '').toUpperCase(); parkedCars[slotNormalized] = { role: car.loai, plate: car.bienSo, name: car.ten }; } }); }
    let totalViolations = 0;

    let sortableParkingGrids = [];
    let sortableCameraGrid1 = null, sortableCameraGridA = null, sortableCameraGridB = null;

    // ==========================================
    // 1. ZOOM & PAN ENGINE BẢN ĐỒ
    // ==========================================
    let scale = 1; let panning = false; let pointX = 0; let pointY = 0; let startX, startY;
    const frame = document.getElementById('blueprint-frame');
    const zoomWrapper = document.getElementById('map-zoom-wrapper');
    function setTransform() { zoomWrapper.style.transform = `translate(${pointX}px, ${pointY}px) scale(${scale})`; }
    frame.addEventListener('mousedown', (e) => { if (e.target.closest('button') || e.target.closest('.cam-marker') || e.target.closest('.slot-cam') || e.target.closest('.parking-slot')) return; e.preventDefault(); panning = true; frame.style.cursor = 'grabbing'; startX = e.clientX - pointX; startY = e.clientY - pointY; });
    frame.addEventListener('mousemove', (e) => { if (!panning) return; pointX = e.clientX - startX; pointY = e.clientY - startY; setTransform(); });
    frame.addEventListener('mouseup', () => { panning = false; frame.style.cursor = 'grab'; });
    frame.addEventListener('mouseleave', () => { panning = false; frame.style.cursor = 'grab'; });
    frame.addEventListener('wheel', (e) => {
        e.preventDefault();
        const xs = (e.clientX - frame.getBoundingClientRect().left - pointX) / scale; const ys = (e.clientY - frame.getBoundingClientRect().top - pointY) / scale;
        const delta = (e.wheelDelta ? e.wheelDelta : -e.deltaY); (delta > 0) ? (scale *= 1.1) : (scale /= 1.1);
        scale = Math.max(0.5, Math.min(scale, 3));
        pointX = e.clientX - frame.getBoundingClientRect().left - xs * scale; pointY = e.clientY - frame.getBoundingClientRect().top - ys * scale;
        setTransform();
    });
    window.zoomMap = function(amount) { scale += amount; scale = Math.max(0.5, Math.min(scale, 3)); setTransform(); }
    window.resetZoom = function() { scale = 1; pointX = 0; pointY = 0; setTransform(); }

    // ==========================================
    // 2. THUẬT TOÁN SINH BÃI XE (ĐƯỜNG NỘI BỘ 2 DÒNG)
    // ==========================================
    function generateBasementLayout(prefix, totalSlots, targetParkingId, targetCamId) {
        const container = document.getElementById(targetParkingId);
        const camContainer = document.getElementById(targetCamId);
        if (!container || !camContainer) return;
        container.innerHTML = ''; camContainer.innerHTML = '';
        let html = ''; let camHtml = '';

        const slotsPerRow = 12;
        const rowsPerBlock = 2; // Cứ 2 dòng (24 ô) là 1 block
        let currentSlot = 1;

        while (currentSlot <= totalSlots) {
            let endSlot = Math.min(currentSlot + (slotsPerRow * rowsPerBlock) - 1, totalSlots);
            html += `<div class="parking-block"><div class="parking-grid">`;

            for (let i = currentSlot; i <= endSlot; i++) {
                let slotId = `${prefix}-${i}`;
                let parkedCarInfo = parkedCars[slotId];
                let isOccupied = !!parkedCarInfo;
                let isViolation = false;

                let roleClass = ''; let roleLabel = ''; let roleIcon = ''; let intendedRole = '';
                if (prefix === 'A') {
                    if (i <= 24) { intendedRole = 'VIP'; roleClass = 'slot-vip'; roleLabel = 'VIP/SẾP'; roleIcon = '<i class="bi bi-star-fill mb-1"></i>'; }
                    else { intendedRole = 'Khách'; roleClass = 'slot-customer'; roleLabel = 'KHÁCH'; roleIcon = '<i class="bi bi-person-badge mb-1"></i>'; }
                } else if (prefix === 'B') {
                    intendedRole = 'Nhân Viên'; roleClass = 'slot-employee'; roleLabel = 'NHÂN VIÊN'; roleIcon = '<i class="bi bi-person-vcard mb-1"></i>';
                }

                if (isOccupied) {
                    let actualRole = parkedCarInfo.role.toLowerCase();
                    if (intendedRole === 'VIP' && !actualRole.includes('giám đốc') && !actualRole.includes('vip')) isViolation = true;
                    if (intendedRole === 'Khách' && actualRole.includes('nhân viên')) isViolation = true;
                    if (intendedRole === 'Nhân Viên' && actualRole.includes('khách')) isViolation = true;
                    if (isViolation) totalViolations++;
                }

                let cssClass = isOccupied ? (isViolation ? 'slot-violation' : 'slot-occupied') : roleClass;
                let content = '';
                if (isOccupied) {
                    if (isViolation) {
                        content = `<i class="bi bi-exclamation-triangle-fill text-danger fs-3 mb-1" title="Vi phạm: Biển số ${parkedCarInfo.plate} đỗ sai"></i><span style="font-size:0.55rem; color:#fff" class="bg-danger px-1 rounded">${parkedCarInfo.plate}</span>`;
                    } else {
                        content = `<i class="bi bi-car-front-fill car-icon animate__animated animate__zoomIn text-success"></i><span style="font-size:0.55rem">${parkedCarInfo.plate}</span>`;
                    }
                } else {
                    content = `${roleIcon}<span style="font-size: 0.5rem; opacity: 0.8">${roleLabel}</span><span class="fw-bold mt-1">${slotId}</span>`;
                }

                let adminDeleteBtn = isAdmin ? `<button class="btn btn-danger position-absolute top-0 end-0 p-0 rounded-circle d-flex align-items-center justify-content-center btn-delete-slot" onclick="deleteSlot('${slotId}', event)" title="Xóa bãi đỗ này"><i class="bi bi-x" style="font-size: 14px; margin: 0;"></i></button>` : '';
                let camIcon = `<i class="bi bi-webcam-fill slot-cam text-info" title="Xem Camera ô ${slotId}" onclick="openSlotCamera(event, '${slotId}')"></i>`;
                html += `<div class="parking-slot ${cssClass}">${adminDeleteBtn}${camIcon}${content}</div>`;

                camHtml += `
                <div style="display:inline-block;" class="dynamic-cam-item" data-slot="${slotId}">
                    <div class="cam-feed rounded-2" style="width: 350px; height: 220px;">
                        <div class="cam-content"><i class="bi bi-car-front text-white opacity-25"></i></div>
                        <div class="cam-status rounded-1"><i class="bi bi-circle-fill text-white small me-1"></i> REC</div>
                        <div class="cam-title"><i class="bi bi-geo-alt-fill text-info me-1"></i>Cam Ô ${slotId}</div>
                        <button class="btn-fullscreen rounded-1" onclick="toggleFullscreen(this.parentElement)" title="Phóng to"><i class="bi bi-arrows-fullscreen"></i></button>
                        <div class="cam-overlay"><span>CHK-IN // ${slotId}</span><span class="live-clock-cam text-info fw-bold"></span></div>
                    </div>
                </div>`;
            }
            html += `</div></div>`;
            currentSlot = endSlot + 1;

            // Chèn đường đi sau khi vẽ đủ 2 dòng
            if (currentSlot <= totalSlots) {
                if (currentSlot === 49) {
                    html += `<div class="driveway-clean"><i class="bi bi-chevron-double-left fs-3 driveway-arrow left"></i><span><i class="bi bi-car-front"></i> LÀN LƯU THÔNG CHÍNH <i class="bi bi-car-front"></i></span><i class="bi bi-chevron-double-right fs-3 driveway-arrow right"></i></div>`;
                } else {
                    html += `<div class="mini-driveway my-2 text-center text-warning opacity-50 small font-monospace"><i class="bi bi-arrows-expand"></i> LỐI ĐI NỘI BỘ (LÙI XE) <i class="bi bi-arrows-expand"></i></div>`;
                }
            }
        }
        html += `<div class="d-flex justify-content-end mt-4"><div class="zone-badge bg-danger animate__animated animate__pulse animate__infinite rounded-1">LỐI RA (EXIT) <i class="bi bi-arrow-right-square-fill"></i></div></div>`;
        container.innerHTML = html;
        camContainer.innerHTML = camHtml;
    }

    function initParking() {
        totalViolations = 0;
        generateBasementLayout('A', 120, 'dynamic-parking-A', 'cam-container-basement_A');
        generateBasementLayout('B', 120, 'dynamic-parking-B', 'cam-container-basement_B');

        let occupiedCount = Object.keys(parkedCars).length;
        document.getElementById('occupiedCount').innerText = occupiedCount;
        document.getElementById('emptyCount').innerText = 240 - occupiedCount;
        document.getElementById('violationCount').innerText = totalViolations;

        // Kích hoạt Drag & Drop Ô Đỗ Xe
        if(isAdmin) {
            document.querySelectorAll('.parking-grid').forEach(grid => {
                sortableParkingGrids.push(new Sortable(grid, {
                    group: 'shared-parking', animation: 150, ghostClass: 'sortable-ghost'
                }));
            });
        }
    }

    // ==========================================
    // 3. TẠO KHUNG CAMERA TỰ ĐỘNG ĐỒNG BỘ VÀ DRAG/DROP
    // ==========================================
    function renderCameraFeeds() {
        const currentFloor = document.getElementById('floorSelector').value;
        const mainGrid = document.getElementById('main-camera-grid');
        mainGrid.innerHTML = '';

        const mapContainer = document.getElementById('map-' + currentFloor);
        if(mapContainer) {
            const markers = mapContainer.querySelectorAll('.cam-marker');
            markers.forEach((marker, index) => {
                const labelEl = marker.querySelector('.cam-label');
                const name = labelEl ? labelEl.innerText : 'Unknown Cam';

                // Mặc định khung to, admin có thể kéo giãn
                const camHtml = `
                    <div style="display:inline-block;" class="dynamic-main-cam">
                        <div class="cam-feed rounded-2" style="width: 500px; height: 280px;">
                            <div class="cam-content"><i class="bi bi-camera-video text-white opacity-25"></i></div>
                            <div class="cam-status rounded-1"><i class="bi bi-circle-fill text-white small me-1"></i> ONLINE</div>
                            <div class="cam-title"><i class="bi bi-geo-alt-fill text-danger me-1"></i><span>${name}</span></div>
