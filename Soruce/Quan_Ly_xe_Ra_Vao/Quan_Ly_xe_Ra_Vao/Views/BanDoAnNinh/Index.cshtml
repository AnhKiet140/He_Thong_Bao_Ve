    function moveRowDown(btn) { const row = btn.closest('tr'); const next = row.nextElementSibling; if (next) { row.parentNode.insertBefore(next, row); saveGlobalData(); } }

    function saveCameraLayout() {
        Swal.fire({ title: 'Đang lưu cấu hình...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
        setTimeout(() => { closeFloatingWindow('window-manage-camera'); Swal.fire('Hoàn tất!', 'Tên mới và cấu hình đã được lưu thành công.', 'success'); }, 1000);
    }

    function resetAllData() {
        Swal.fire({
            title: 'Khôi phục CSDL Gốc?', text: "Hành động này sẽ xóa toàn bộ cài đặt ô đỗ xe và Camera đã thêm. Về trạng thái 240 chỗ mặc định. Bạn chắc chắn?",
            icon: 'warning', showCancelButton: true, confirmButtonText: 'KHÔI PHỤC NGAY', confirmButtonColor: '#dc3545'
        }).then((result) => {
            if(result.isConfirmed) {
                localStorage.removeItem('chkIn_dbCounters');
                localStorage.removeItem('chkIn_cameraList');
                localStorage.removeItem('chkIn_deletedSlots');
                localStorage.removeItem('chkIn_slotOrder_A');
                localStorage.removeItem('chkIn_slotOrder_B');
                localStorage.removeItem('chkIn_cameraOrder');
                localStorage.removeItem('chkIn_motoCount');
                localStorage.removeItem('chkIn_parkedCars');
                location.reload();
            }
        });
    }

    function showSlotInfo(id, name, plate, img) {
        document.getElementById('slotDetailCard').classList.remove('d-none');
        document.getElementById('lblSlotId').innerText = id;
        if (name && name !== 'null' && name !== '') { document.getElementById('slotUser').innerText = name; document.getElementById('slotPlate').innerText = plate; document.getElementById('slotImg').src = img || '/images/no-avatar.png'; }
        else { resetSlot(); Swal.fire({ title: 'Vị trí ' + id, text: 'Vị trí này hiện đang trống.', icon: 'info', timer: 1500, showConfirmButton: false }); }
    }
    function resetSlot() { document.getElementById('slotDetailCard').classList.add('d-none'); }
</script>