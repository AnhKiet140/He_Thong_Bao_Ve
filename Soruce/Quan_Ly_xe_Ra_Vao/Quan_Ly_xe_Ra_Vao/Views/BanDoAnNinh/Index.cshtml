            function syncCameraTableFromMap() {
                const tbody = document.querySelector('#cameraAdminTable tbody');
                tbody.innerHTML = '';

                const mainMarkers = document.querySelectorAll('.cam-marker');
                mainMarkers.forEach((marker, index) => {
                    const labelEl = marker.querySelector('.cam-label');
                    if(!labelEl) return;
                    const name = labelEl.innerText;

                    const container = marker.closest('.blueprint-container') || marker.closest('.basement-clean-layout');
                    let floorName = 'Chưa phân loại';
                    if(container) {
                        if(container.id === 'map-ground') floorName = 'Tầng Trệt';
                        if(container.id === 'map-floor1') floorName = 'Tầng 1';
                        if(container.id === 'map-floor2') floorName = 'Tầng 2';
                        if(container.id === 'map-floor3') floorName = 'Tầng 3';
                        if(container.id === 'map-basement_A') floorName = 'Hầm A';
                        if(container.id === 'map-basement_B') floorName = 'Hầm B';
                    }
                    marker.id = `map-cam-main-${index}`;
                    addCamRowToTable(tbody, name, floorName, marker.id, 'main');
                });

                // Đồng bộ toàn bộ 240 Camera bãi đỗ vào bảng (YÊU CẦU 4)
                const parkingCams = document.querySelectorAll('.dynamic-cam-item');
                parkingCams.forEach((cam) => {
                    const slotId = cam.getAttribute('data-slot');
                    const currentName = cam.querySelector('.cam-title').innerText.replace('Cam Ô ', 'Camera Ô Đỗ ');
                    let floorName = slotId.startsWith('A') ? 'Hầm A' : 'Hầm B';
                    addCamRowToTable(tbody, currentName, floorName, slotId, 'parking');
                });
            }

            function filterAdminCameras() {
                const filterVal = document.getElementById('adminCamFilter').value;
                const rows = document.querySelectorAll('#cameraAdminTable tbody tr');
                rows.forEach(row => {
                    if (filterVal === 'all' || row.getAttribute('data-floor') === filterVal) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }

            function renameCameraInMap(inputEl, refId, type) {
                if(type === 'main') {
                    const marker = document.getElementById(refId);
                    if(marker) {
                        const label = marker.querySelector('.cam-label');
                        if(label) label.innerText = inputEl.value;
                    }
                } else if (type === 'parking') {
                    const camItem = document.querySelector(`.dynamic-cam-item[data-slot="${refId}"]`);
                    if (camItem) {
                        const title = camItem.querySelector('.cam-title');
                        if (title) title.innerHTML = `<i class="bi bi-geo-alt-fill text-info me-1"></i>${inputEl.value}`;
                    }
                }
                renderCameraFeeds();
            }

            function deleteCameraFromBoth(btn, refId, type) {
                const row = btn.closest('tr');
                row.classList.add('animate__animated', 'animate__fadeOutRight');

                if(type === 'main') {
                    const marker = document.getElementById(refId);
                    if(marker) marker.classList.add('animate__animated', 'animate__zoomOut');
                    setTimeout(() => { row.remove(); if(marker) marker.remove(); renderCameraFeeds(); }, 500);
                } else if (type === 'parking') {
                    const slotCamIcon = document.querySelector(`.parking-slot i.slot-cam[onclick="openSlotCamera(event, '${refId}')"]`);
                    if(slotCamIcon) slotCamIcon.remove();

                    const camItem = document.querySelector(`.dynamic-cam-item[data-slot="${refId}"]`);
                    if(camItem) camItem.classList.add('animate__animated', 'animate__zoomOut');
                    setTimeout(() => { row.remove(); if(camItem) camItem.remove(); renderCameraFeeds(); }, 500);
                }
            }

            function addNewCameraRow() {
                Swal.fire({
                    title: 'Nhập tên Camera Mới', input: 'text', inputPlaceholder: 'VD: Cam Góc Khuất Tầng 1',
                    showCancelButton: true, confirmButtonText: 'Gắn Lên Bản Đồ'
                }).then((result) => {
                    if(result.isConfirmed && result.value) {
                        const name = result.value;
                        const currentFloorVal = document.getElementById('floorSelector').value;
                        const targetMap = document.getElementById('map-' + currentFloorVal);

                        if(!targetMap || currentFloorVal.includes('basement')) {
                            Swal.fire('Lỗi', 'Chỉ hỗ trợ thả Camera tự do trực tiếp trên Tầng Lầu/Trệt.', 'error'); return;
                        }

                        const html = `
                            <div class="cam-marker animate__animated animate__bounceIn" style="top: 50%; left: 50%; transform: translate(-50%, -50%);" onclick="switchTab('camera')">
                                <button class="btn btn-sm btn-danger position-absolute rounded-1 btn-delete-cam" onclick="deleteMapElement(this, event, '${name}')"><i class="bi bi-x"></i></button>
                                <div class="cam-pulse bg-info"></div><i class="bi bi-webcam-fill text-info fs-3"></i><div class="cam-label border-info text-info">${name}</div>
                            </div>
                        `;
                        targetMap.insertAdjacentHTML('beforeend', html);

                        // Tự động đóng Form (YÊU CẦU 3)
                        closeFloatingWindow('window-manage-camera');
                        syncCameraTableFromMap();
                        renderCameraFeeds();
                        Swal.fire('Thành công', 'Đã gắn Camera vào chính giữa bản đồ.', 'success');
                    }
                });
            }

            function deleteMapElement(btnElement, event, name) {
                event.stopPropagation();
                Swal.fire({
                    title: 'Gỡ Camera?', html: `Xóa Camera <b>${name}</b> khỏi Bản đồ giám sát?`, icon: 'warning',
                    showCancelButton: true, confirmButtonColor: '#d33', cancelButtonColor: '#6c757d', confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const cam = btnElement.closest('.cam-marker');
                        cam.classList.add('animate__animated', 'animate__zoomOut');
                        setTimeout(() => { cam.remove(); syncCameraTableFromMap(); renderCameraFeeds(); }, 500);
                    }
                });
            }

            function deleteSlot(slotId, event) {
                event.stopPropagation();
                Swal.fire({
                    title: 'Xóa vị trí đỗ?', text: `Bạn có chắc chắn muốn gỡ bỏ ô đỗ ${slotId}?`, icon: 'warning',
                    showCancelButton: true, confirmButtonColor: '#d33', cancelButtonColor: '#6c757d', confirmButtonText: 'Xóa ngay', cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        const slotEl = event.target.closest('.parking-slot');
                        if(slotEl) {
                            slotEl.classList.add('animate__animated', 'animate__zoomOut');
                            setTimeout(() => { slotEl.remove(); }, 500);
                        }
                    }
                });
            }

            function moveRowUp(btn) {
                const row = btn.closest('tr'); const prev = row.previousElementSibling;
                if (prev) { row.parentNode.insertBefore(row, prev); }
            }
            function moveRowDown(btn) {
                const row = btn.closest('tr'); const next = row.nextElementSibling;
                if (next) { row.parentNode.insertBefore(next, row); }
            }
            function saveCameraLayout() {
                Swal.fire({ title: 'Đang lưu cấu hình...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                setTimeout(() => {
                    closeFloatingWindow('window-manage-camera'); // TỰ ĐÓNG FORM
                    Swal.fire('Hoàn tất!', 'Tên mới và cấu hình đã được lưu thành công.', 'success');
                }, 1000);
            }
            </text>
    }
</script>