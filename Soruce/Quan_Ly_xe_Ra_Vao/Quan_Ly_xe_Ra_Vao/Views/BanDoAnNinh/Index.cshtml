@using Quan_Ly_xe_Ra_Vao.Data
@inject ApplicationDbContext DbContext

@{
    ViewData["Title"] = "Bản Đồ An Ninh Tổng Hợp";
    string userRole = User.Identity.IsAuthenticated ? User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value : "Guest";

    var danhSachXeDangDau = DbContext.LichSuCheckIns
        .Where(x => x.ViTriDo != null && x.TrangThai != null && x.TrangThai.Contains("đậu"))
        .Select(x => new { ViTri = x.ViTriDo, Loai = x.LoaiDoiTuong ?? "Khách", BienSo = x.BienSoXe ?? "N/A", Ten = x.HoTen ?? "Khách" })
        .ToList();
}

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid mt-2 animate__animated animate__fadeIn" id="main-container">

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 p-3 rounded-2 shadow-sm border-start border-5 border-info bg-card-custom">
        <div class="mb-3 mb-xl-0">
            <h4 class="fw-bold text-body mb-1"><i class="bi bi-geo-alt-fill text-info"></i> BẢN ĐỒ AN NINH TỔNG THỂ</h4>
            <small class="text-muted fw-bold">GIÁM SÁT CHI TIẾT LƯU LƯỢNG, VỊ TRÍ ĐỖ VÀ CAMERA KHU VỰC</small>
        </div>

        <div class="d-flex bg-light rounded-2 p-1 shadow-sm border tab-container mx-xl-3 mb-3 mb-xl-0" style="min-width: 350px;">
            <button id="btn-tab-blueprint" class="btn btn-primary rounded-1 fw-bold w-50 active tab-btn" onclick="switchTab('blueprint')">
                <i class="bi bi-map-fill me-1"></i> SƠ ĐỒ VỊ TRÍ
            </button>
            <button id="btn-tab-camera" class="btn btn-light rounded-1 fw-bold w-50 text-muted border-0 tab-btn" onclick="switchTab('camera')">
                <i class="bi bi-webcam-fill me-1"></i> GIÁM SÁT CAMERA
            </button>
        </div>

        <div class="d-flex gap-2 align-items-center flex-wrap">
            <div class="input-group input-group-sm w-auto shadow-sm">
                <span class="input-group-text bg-dark text-white border-dark rounded-start-2"><i class="bi bi-layers"></i> Tầng</span>
                <select id="floorSelector" class="form-select border-dark fw-bold text-body bg-transparent rounded-end-2" onchange="switchFloor()">
                    <option value="ground">Tầng Trệt (Lễ Tân/Kho)</option>
                    <option value="floor1">Tầng 1 (IT & Giám Đốc)</option>
                    <option value="floor2">Tầng 2 (Phòng Nhân Sự)</option>
                    <option value="floor3">Tầng 3 (Phòng Kế Toán)</option>
                    <option value="basement_A" selected>Tầng Hầm - Khu A (Khách & VIP)</option>
                    <option value="basement_B">Tầng Hầm - Khu B (Nhân Viên)</option>
                    <option value="basement_moto">Tầng Hầm - Xe Máy</option>
                </select>
            </div>

            @if (userRole == "Admin")
            {
                <div class="dropdown">
                    <button class="btn btn-success btn-sm fw-bold shadow-sm rounded-2 px-3 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-pencil-square"></i> Q.Trị Bản Đồ
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-2">
                        <li><a class="dropdown-item fw-bold text-primary py-2" href="#" onclick="openFloatingWindow('window-manage-camera')"><i class="bi bi-camera-video me-2"></i>Quản lý Camera Giám Sát</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item fw-bold text-success py-2" href="#" onclick="openFloatingWindow('window-manage-parking')"><i class="bi bi-p-square me-2"></i>Thiết lập Ô Đỗ Xe</a></li>
                    </ul>
                </div>
            }

            <button class="btn btn-danger btn-sm fw-bold shadow-sm rounded-2 px-4 btn-sos text-nowrap" onclick="triggerSOS()"><i class="bi bi-exclamation-triangle-fill"></i> S.O.S</button>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-9 d-flex flex-column gap-3">
            <div id="view-blueprint" class="card border-0 shadow-sm rounded-2 overflow-hidden bg-dark animate__animated animate__fadeIn">
                <div class="card-header bg-black text-white d-flex justify-content-between align-items-center py-3 border-0 z-3">
                    <span id="blueprintTitle" class="fw-bold small text-uppercase text-info"><i class="bi bi-map"></i> Blueprint - Tầng Hầm - Khu A</span>
                    <div class="d-flex gap-3 small fw-bold flex-wrap justify-content-end">
                        <span class="text-warning"><i class="bi bi-star-fill"></i> Sếp/VIP</span>
                        <span class="text-info"><i class="bi bi-person-badge"></i> Khách</span>
                        <span class="text-secondary"><i class="bi bi-person-vcard"></i> Nhân Viên</span>
                        <span class="text-danger" style="animation: pulseDanger 1s infinite;"><i class="bi bi-exclamation-triangle-fill"></i> Đỗ sai</span>
                    </div>
                </div>

                <div class="blueprint-frame" id="blueprint-frame" style="position: relative; height: 650px; width: 100%; overflow: hidden; cursor: grab;">
                    <div class="position-absolute bottom-0 end-0 m-3 d-flex flex-column gap-2 z-3">
                        <button class="btn btn-light bg-opacity-75 rounded-2 shadow fw-bold" onclick="zoomMap(0.1)"><i class="bi bi-zoom-in"></i></button>
                        <button class="btn btn-light bg-opacity-75 rounded-2 shadow fw-bold" onclick="resetZoom()"><i class="bi bi-crosshair"></i></button>
                        <button class="btn btn-light bg-opacity-75 rounded-2 shadow fw-bold" onclick="zoomMap(-0.1)"><i class="bi bi-zoom-out"></i></button>
                    </div>

                    <div id="map-zoom-wrapper" style="transform-origin: 0 0; width: 100%; height: 100%; position: relative; padding: 20px;">
                        <div id="map-ground" class="blueprint-container d-none w-100 h-100 position-relative">
                            <div class="room-box" style="top: 5%; left: 40%; width: 55%; height: 60%;">
                                <i class="bi bi-building room-bg-icon"></i><div class="room-title">SẢNH TIẾP TÂN</div>
                                <div class="cam-marker" style="top: 15px; right: 15px;" onclick="switchTab('camera')">
                                    @if (userRole == "Admin")
                                    {
                                        <button class="btn btn-sm btn-danger position-absolute rounded-1 btn-delete-cam" onclick="deleteMapElement(this, event, 'Cam Sảnh 360')"><i class="bi bi-x"></i></button>
                                    }
                                    <div class="cam-pulse bg-success"></div><i class="bi bi-webcam-fill text-success fs-3"></i><div class="cam-label">Cam Sảnh 360</div>
                                </div>
                            </div>
                            <div class="room-box border-warning text-warning" style="top: 5%; left: 5%; width: 30%; height: 40%; background: rgba(255,193,7,0.05);">
                                <i class="bi bi-box-seam room-bg-icon text-warning"></i><div class="room-title text-warning">KHO VẬT TƯ</div>
                                <div class="cam-marker" style="top: 15px; left: 15px;" onclick="switchTab('camera')">
                                    @if (userRole == "Admin")
                                    {
                                        <button class="btn btn-sm btn-danger position-absolute rounded-1 btn-delete-cam" onclick="deleteMapElement(this, event, 'Cam Nhiệt Kho')"><i class="bi bi-x"></i></button>
                                    }
                                    <div class="cam-pulse bg-warning"></div><i class="bi bi-thermometer-sun text-warning fs-3"></i><div class="cam-label border-warning text-warning">Cam Nhiệt Kho</div>
                                </div>
                            </div>
                        </div>

                        <div id="map-floor1" class="blueprint-container d-none w-100 h-100 position-relative">
                            <div class="room-box border-primary" style="top: 10%; left: 15%; width: 70%; height: 80%; background: rgba(13,110,253,0.05);">
                                <i class="bi bi-hdd-network room-bg-icon text-primary"></i><div class="room-title text-primary">TRUNG TÂM DỮ LIỆU (IT) & GIÁM ĐỐC</div>
                                <div class="cam-marker" style="top: 15px; left: 15px;" onclick="switchTab('camera')">
                                    @if (userRole == "Admin")
                                    {
                                        <button class="btn btn-sm btn-danger position-absolute rounded-1 btn-delete-cam" onclick="deleteMapElement(this, event, 'Server Room Scan')"><i class="bi bi-x"></i></button>
                                    }
                                    <div class="cam-pulse bg-primary"></div><i class="bi bi-webcam-fill text-primary fs-3"></i><div class="cam-label border-primary text-primary">Server Room Scan</div>
                                </div>
                            </div>
                        </div>
                        <div id="map-floor2" class="blueprint-container d-none w-100 h-100 position-relative"><div class="room-box" style="top: 10%; left: 15%; width: 70%; height: 80%;"><i class="bi bi-people-fill room-bg-icon"></i><div class="room-title">VĂN PHÒNG NHÂN SỰ</div></div></div>
                        <div id="map-floor3" class="blueprint-container d-none w-100 h-100 position-relative"><div class="room-box border-warning" style="top: 10%; left: 15%; width: 70%; height: 80%; background: rgba(255,193,7,0.05);"><i class="bi bi-safe-fill room-bg-icon text-warning"></i><div class="room-title text-warning">PHÒNG KẾ TOÁN & KÉT SẮT</div></div></div>

                        <div id="map-basement_A" class="basement-clean-layout w-100 position-relative">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="zone-badge bg-success animate__animated animate__pulse animate__infinite rounded-1"><i class="bi bi-arrow-down-square-fill"></i> LỐI VÀO (ENTRANCE)</div>
                                <div class="cam-static cursor-pointer text-info fw-bold border border-info px-3 py-1 rounded-1" onclick="switchTab('camera')"><i class="bi bi-camera-video-fill"></i> Xem ALPR Cổng A</div>
                            </div>
                            <div id="dynamic-parking-A" class="w-100 pb-5"></div>
                        </div>

                        <div id="map-basement_B" class="basement-clean-layout d-none w-100 position-relative">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="zone-badge bg-success animate__animated animate__pulse animate__infinite rounded-1"><i class="bi bi-arrow-down-square-fill"></i> LỐI VÀO (ENTRANCE)</div>
                                <div class="cam-static cursor-pointer text-info fw-bold border border-info px-3 py-1 rounded-1" onclick="switchTab('camera')"><i class="bi bi-camera-video-fill"></i> Xem ALPR Cổng B</div>
                            </div>
                            <div id="dynamic-parking-B" class="w-100 pb-5"></div>
                        </div>

                        <div id="map-basement_moto" class="basement-clean-layout d-none h-100 w-100 position-relative">
                            <div class="room-box w-100 position-relative rounded-2" style="min-height: 450px; border: 3px dashed rgba(13,202,240,0.4);">
                                <i class="bi bi-bicycle room-bg-icon"></i><div class="room-title fs-5" style="top: 20px; left: 50%; transform: translateX(-50%);">KHU VỰC XE MÁY TỰ DO</div>
                                <div class="zone-badge bg-success position-absolute rounded-1" style="top: 20px; left: 20px;"><i class="bi bi-arrow-down-square-fill"></i> VÀO (MOTO)</div>
                                <div class="driveway-clean position-absolute" style="top: 45%; width: 90%; left: 5%;"><span><i class="bi bi-arrow-right"></i> HƯỚNG DI CHUYỂN <i class="bi bi-arrow-right"></i></span></div>
                                <div class="zone-badge bg-danger position-absolute rounded-1" style="bottom: 20px; right: 20px;">RA (MOTO) <i class="bi bi-arrow-right-square-fill"></i></div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div id="view-camera" class="card border-0 shadow-sm rounded-2 bg-card-custom overflow-hidden d-none animate__animated animate__fadeIn h-100">
                <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0 text-body"><i class="bi bi-webcam-fill text-primary"></i> HỆ THỐNG CAMERA GIÁM SÁT - <span id="cam-zone-name" class="text-primary">ĐANG TẢI...</span></h6>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small"><i class="bi bi-arrows-move"></i> Kéo góc để chỉnh kích thước | Kéo thả để sắp xếp</span>
                        <span class="badge bg-danger pulse-btn-danger rounded-1"><i class="bi bi-record-circle me-1"></i>ĐANG GHI HÌNH</span>
                    </div>
                </div>
                <div class="card-body p-4 custom-scrollbar" style="background-color: #0a0a0a; height: 650px; overflow-y: auto; overflow-x: hidden;">
                    <div class="d-flex flex-wrap gap-3" id="main-camera-grid">
                    </div>
                    <div id="cam-container-basement_A" class="d-none mt-4 pt-4 border-top border-secondary d-flex flex-wrap gap-3"></div>
                    <div id="cam-container-basement_B" class="d-none mt-4 pt-4 border-top border-secondary d-flex flex-wrap gap-3"></div>
                </div>
            </div>

        </div>

        <div class="col-lg-3">
            <div class="card border-0 shadow-sm rounded-2 bg-card-custom p-3 h-100">
                <h6 class="fw-bold border-bottom pb-2 text-body"><i class="bi bi-info-circle-fill text-primary"></i> THÔNG TIN KHU VỰC</h6>
                <div class="mb-4">
                    <small class="text-muted d-block fw-bold">Trạng thái An Ninh:</small>
                    <span id="security-status" class="badge bg-success bg-opacity-10 text-success border border-success fw-bold px-3 py-2 mt-2 w-100 fs-6 rounded-2">
                        <i class="bi bi-shield-check me-1"></i> BÌNH THƯỜNG
                    </span>
                </div>
                <h6 class="fw-bold text-muted small mt-2">DỮ LIỆU BÃI XE TỔNG HỢP</h6>
                <div class="d-flex justify-content-between mb-2 mt-2"><span class="small text-body fw-bold">Tổng chỗ Ô tô:</span><span class="fw-bold text-body">240</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="small text-body fw-bold">Đang trống:</span><span class="fw-bold text-success fs-5" id="emptyCount">240</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="small text-body fw-bold">Đang đậu:</span><span class="fw-bold text-danger fs-5" id="occupiedCount">0</span></div>
                <div class="d-flex justify-content-between border-top pt-2 mt-2"><span class="small text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo đỗ sai:</span><span class="fw-bold text-danger fs-5 blink-text" id="violationCount">0</span></div>
            </div>
        </div>
    </div>
</div>

@if (userRole == "Admin")
{
    <div class="floating-window d-none shadow-lg animate__animated" id="window-manage-camera">
        <div class="resizer resizer-t"></div> <div class="resizer resizer-r"></div> <div class="resizer resizer-b"></div> <div class="resizer resizer-l"></div>
        <div class="resizer resizer-tl"></div> <div class="resizer resizer-tr"></div> <div class="resizer resizer-bl"></div> <div class="resizer resizer-br"></div>

        <div class="card-header bg-dark text-white p-3 border-0 d-flex justify-content-between align-items-center floating-header" id="header-manage-camera">
            <div><h6 class="fw-bold mb-0 text-uppercase"><i class="bi bi-camera-video-fill text-info me-2"></i>QUẢN TRỊ HỆ THỐNG CAMERA</h6></div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light rounded-1 border-0" onclick="toggleMaximize('window-manage-camera')" title="Phóng to / Thu nhỏ"><i class="bi bi-arrows-fullscreen"></i></button>
                <button class="btn btn-sm btn-danger rounded-1 border-0" onclick="closeFloatingWindow('window-manage-camera')" title="Đóng"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="card-body p-3 bg-card-custom d-flex flex-column" style="overflow: hidden; flex: 1;">
            <div class="d-flex justify-content-between mb-3 align-items-center flex-wrap gap-2">
                <div class="d-flex gap-2 align-items-center">
                    <label class="fw-bold text-muted text-nowrap small"><i class="bi bi-funnel-fill"></i> Lọc theo tầng:</label>
                    <select id="adminCamFilter" class="form-select form-select-sm shadow-sm border-secondary fw-bold" onchange="filterAdminCameras()" style="width: 180px;">
                        <option value="all">Hiển thị Tất Cả</option>
                        <option value="Tầng Trệt">Tầng Trệt</option>
                        <option value="Tầng 1">Tầng 1</option>
                        <option value="Tầng 2">Tầng 2</option>
                        <option value="Tầng 3">Tầng 3</option>
                        <option value="Hầm A">Tầng Hầm A (VIP)</option>
                        <option value="Hầm B">Tầng Hầm B (NV)</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm fw-bold rounded-1 shadow-sm text-white" onclick="saveCameraLayout()"><i class="bi bi-save2"></i> Lưu Đồng Bộ</button>
                    <button class="btn btn-info btn-sm fw-bold rounded-1 shadow-sm text-white" onclick="addNewCameraRow()"><i class="bi bi-plus-lg"></i> Thêm Mới</button>
                </div>
            </div>

            <div class="table-responsive rounded-2 shadow-sm border" style="flex: 1; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 text-center bg-white" id="cameraAdminTable">
                    <thead class="table-dark text-uppercase small sticky-top">
                        <tr>
                            <th style="width: 80px;">Sắp xếp</th>
                            <th class="text-start">Tên Camera (Click để sửa)</th>
                            <th>Khu vực</th>
                            <th>Trạng thái</th>
                            <th>Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="floating-window d-none shadow-lg animate__animated" id="window-manage-parking">
        <div class="resizer resizer-t"></div> <div class="resizer resizer-r"></div> <div class="resizer resizer-b"></div> <div class="resizer resizer-l"></div>
        <div class="resizer resizer-tl"></div> <div class="resizer resizer-tr"></div> <div class="resizer resizer-bl"></div> <div class="resizer resizer-br"></div>

        <div class="card-header bg-primary text-white p-3 border-0 d-flex justify-content-between align-items-center floating-header" id="header-manage-parking">
            <div><h6 class="fw-bold mb-0 text-uppercase"><i class="bi bi-p-square-fill me-2"></i>THIẾT LẬP VỊ TRÍ ĐỖ XE</h6></div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light rounded-1 border-0" onclick="toggleMaximize('window-manage-parking')"><i class="bi bi-arrows-fullscreen"></i></button>
                <button class="btn btn-sm btn-danger rounded-1 border-0" onclick="closeFloatingWindow('window-manage-parking')"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="card-body p-4 bg-card-custom" style="overflow-y: auto; flex: 1;">
            <div class="p-3 rounded-2" style="background-color: rgba(13, 110, 253, 0.05); border: 1px dashed rgba(13, 110, 253, 0.3);">
                <div class="mb-3 text-center">
                    <h6 class="fw-bold text-primary">PHÂN LOẠI ĐỐI TƯỢNG ƯU TIÊN</h6>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-4"><input type="radio" class="btn-check" name="parkType" id="typeSep" value="Sep" onchange="autoConfigParking()"><label class="btn btn-outline-warning w-100 p-2 rounded-2 fw-bold shadow-sm" for="typeSep"><i class="bi bi-star-fill fs-4 d-block"></i> VIP/SẾP</label></div>
                    <div class="col-4"><input type="radio" class="btn-check" name="parkType" id="typeKhach" value="Khach" onchange="autoConfigParking()" checked><label class="btn btn-outline-info w-100 p-2 rounded-2 fw-bold shadow-sm" for="typeKhach"><i class="bi bi-person-badge fs-4 d-block"></i> KHÁCH</label></div>
                    <div class="col-4"><input type="radio" class="btn-check" name="parkType" id="typeNV" value="NhanVien" onchange="autoConfigParking()"><label class="btn btn-outline-secondary w-100 p-2 rounded-2 fw-bold shadow-sm" for="typeNV"><i class="bi bi-person-vcard fs-4 d-block"></i> NHÂN VIÊN</label></div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">Khu vực (Cố định)</label>
                        <input type="text" class="form-control fw-bold rounded-1" id="autoZone" readonly style="background-color: #e9ecef;">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">Mã Vị Trí</label>
                        <input type="text" class="form-control fw-bold text-info font-monospace rounded-1" id="autoSlotId" readonly style="background-color: #e0f7fa;">
                    </div>
                </div>
                <div class="text-center mt-3">
                    <button class="btn btn-primary btn-sm rounded-1 px-4 fw-bold shadow" onclick="submitCreateParking()"><i class="bi bi-magic me-2"></i> KHỞI TẠO BÃI ĐỖ</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* CSS CHUNG BẢN ĐỒ */
    .custom-header-card, .bg-card-custom {
        background-color: #ffffff;
    }

    .tab-container {
        background-color: #f8f9fa;
        border-color: #dee2e6;
    }

    .tab-btn {
        transition: all 0.3s ease;
    }

        .tab-btn:hover:not(.active) {
            background-color: rgba(0,0,0,0.05);
        }

    .blink-text {
        animation: blinker 1s linear infinite;
    }
    @@keyframes blinker {
        50%

    {
        opacity: 0.3;
    }

    }

    .blueprint-frame {
        background-color: #0b132b;
        background-image: linear-gradient(rgba(59, 130, 246, 0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(59, 130, 246, 0.08) 1px, transparent 1px);
        background-size: 25px 25px;
    }

    .blueprint-container {
        position: absolute;
    }

    .room-box {
        position: absolute;
        border: 2px solid rgba(59, 130, 246, 0.4);
        background-color: rgba(30, 58, 138, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        border-radius: 8px;
        overflow: hidden;
    }

    .room-title {
        position: absolute;
        top: 10px;
        font-size: 0.8rem;
        font-weight: bold;
        color: rgba(147, 197, 253, 0.8);
        pointer-events: none;
    }

    .room-bg-icon {
        position: absolute;
        font-size: 15rem;
        color: rgba(147, 197, 253, 0.05);
        pointer-events: none;
    }

    .cam-marker {
        position: absolute;
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        z-index: 50;
        transition: transform 0.2s;
    }

        .cam-marker:hover {
