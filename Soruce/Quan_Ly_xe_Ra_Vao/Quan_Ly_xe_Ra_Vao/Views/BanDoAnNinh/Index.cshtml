    @if (userRole == "Admin")
    {
            <text>
            let dbCounters = { vip: 24, guest: 60, emp: 120 };

            function openFloatingWindow(winId) {
                const win = document.getElementById(winId);
                win.classList.remove('d-none', 'animate__zoomOut');
                win.classList.add('animate__zoomIn');

                // Xóa transform do drag để lại, thiết lập lại căn giữa
                win.style.left = "50%";
                win.style.top = "50%";
                win.style.transform = "translate(-50%, -50%)";
                win.style.width = "850px";
                win.style.height = "600px";

                if(winId === 'window-manage-camera') {
                    document.getElementById('adminCamFilter').value = 'all';
                    syncCameraTableFromMap();
                }
                if(winId === 'window-manage-parking') {
                    autoConfigParking();
                }

                makeDraggableWindow(win);
            }

            // TỰ ĐỘNG ĐÓNG WINDOW (YÊU CẦU 3)
            function closeFloatingWindow(winId) {
                const win = document.getElementById(winId);
                win.classList.remove('animate__zoomIn', 'floating-maximized');
                win.classList.add('animate__zoomOut');
                setTimeout(() => { win.classList.add('d-none'); }, 300);
            }

            function toggleMaximize(winId) {
                const win = document.getElementById(winId);
                if (win.classList.contains('floating-maximized')) {
                    win.classList.remove('floating-maximized');
                } else {
                    win.classList.add('floating-maximized');
                }
            }

            // THUẬT TOÁN RESIZE 8 HƯỚNG VÀ DRAG
            function makeDraggableWindow(win) {
                const header = win.querySelector('.floating-header');
                const resizers = win.querySelectorAll('.resizer');
                let isResizing = false;

                // Drag
                let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
                header.onmousedown = function(e) {
                    if (e.target.closest('button') || win.classList.contains('floating-maximized')) return;
                    e.preventDefault(); pos3 = e.clientX; pos4 = e.clientY;
                    document.onmouseup = closeDragElement; document.onmousemove = elementDrag;
                };
                function elementDrag(e) {
                    e.preventDefault(); pos1 = pos3 - e.clientX; pos2 = pos4 - e.clientY; pos3 = e.clientX; pos4 = e.clientY;

                    if (win.style.transform.includes('translate')) {
                        // Chuyển đổi translate thành Top Left tuyệt đối để drag không bị giật
                        const rect = win.getBoundingClientRect();
                        win.style.transform = "none";
                        win.style.top = rect.top + "px";
                        win.style.left = rect.left + "px";
                    }
                    win.style.top = (win.offsetTop - pos2) + "px"; win.style.left = (win.offsetLeft - pos1) + "px";
                }
                function closeDragElement() { document.onmouseup = null; document.onmousemove = null; }

                // Resize 8 hướng
                let original_width = 0, original_height = 0, original_x = 0, original_y = 0, original_mouse_x = 0, original_mouse_y = 0;
                for (let i = 0; i < resizers.length; i++) {
                    const currentResizer = resizers[i];
                    currentResizer.onmousedown = function(e) {
                        e.preventDefault();
                        isResizing = true;
                        original_width = parseFloat(getComputedStyle(win, null).getPropertyValue('width').replace('px', ''));
                        original_height = parseFloat(getComputedStyle(win, null).getPropertyValue('height').replace('px', ''));
                        original_x = win.getBoundingClientRect().left;
                        original_y = win.getBoundingClientRect().top;
                        original_mouse_x = e.pageX;
                        original_mouse_y = e.pageY;

                        if (win.style.transform.includes('translate')) {
                            win.style.transform = "none"; win.style.left = original_x + "px"; win.style.top = original_y + "px";
                        }

                        window.addEventListener('mousemove', resize);
                        window.addEventListener('mouseup', stopResize);
                    };

                    function resize(e) {
                        if (currentResizer.classList.contains('resizer-br')) {
                            win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px';
                            win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px';
                        } else if (currentResizer.classList.contains('resizer-bl')) {
                            win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px';
                            win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px';
                            win.style.left = original_x + (e.pageX - original_mouse_x) + 'px';
                        } else if (currentResizer.classList.contains('resizer-tr')) {
                            win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px';
                            win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px';
                            win.style.top = original_y + (e.pageY - original_mouse_y) + 'px';
                        } else if (currentResizer.classList.contains('resizer-tl')) {
                            win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px';
                            win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px';
                            win.style.left = original_x + (e.pageX - original_mouse_x) + 'px';
                            win.style.top = original_y + (e.pageY - original_mouse_y) + 'px';
                        } else if (currentResizer.classList.contains('resizer-r')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px';
                        } else if (currentResizer.classList.contains('resizer-l')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px';
                        } else if (currentResizer.classList.contains('resizer-b')) { win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px';
                        } else if (currentResizer.classList.contains('resizer-t')) { win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                    }
                    function stopResize() { window.removeEventListener('mousemove', resize); isResizing = false; }
                }
            }

            function autoConfigParking() {
                const type = document.querySelector('input[name="parkType"]:checked').value;
                const zoneInput = document.getElementById('autoZone');
                const idInput = document.getElementById('autoSlotId');
                const iconSpan = document.getElementById('autoIcon');

