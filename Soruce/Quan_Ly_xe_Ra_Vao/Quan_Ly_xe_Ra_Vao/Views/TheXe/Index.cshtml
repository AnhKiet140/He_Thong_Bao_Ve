@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.TheXe>
@{
    ViewData["Title"] = "Quản Lý Thẻ Cứng";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-2 animate__animated animate__fadeIn">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm border-start border-5 border-primary">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-credit-card-2-front-fill text-primary"></i> QUẢN LÝ THẺ VẬT LÝ</h4>
            <small class="text-muted fw-bold">QUẢN TRỊ THẺ RFID CHO NHÂN VIÊN VÀ KHÁCH</small>
        </div>
        <div class="d-flex align-items-center mt-3 mt-lg-0">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <select name="searchTrangThai" class="form-select border-0 bg-light shadow-none fw-bold text-secondary rounded-pill px-3" style="width: 170px;">
                    <option value="">-- Mọi trạng thái --</option>
                    <option value="0" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "0")">Sẵn sàng</option>
                    <option value="1" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "1")">Đang sử dụng</option>
                    <option value="2" selected="@(ViewData["CurrentTrangThai"]?.ToString() == "2")">Đã Khóa / Mất</option>
                </select>
                <button type="submit" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm"><i class="bi bi-funnel-fill"></i> LỌC</button>
                <a asp-action="Create" class="btn btn-dark fw-bold rounded-pill px-4 shadow-sm ms-2 pulse-btn"><i class="bi bi-plus-circle-fill"></i> TẠO THẺ MỚI</a>
            </form>
        </div>
    </div>

    <ul class="nav nav-pills mb-4 bg-white p-2 rounded-pill shadow-sm d-inline-flex" id="cardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill fw-bold px-4" data-bs-toggle="pill" data-bs-target="#tab-nhanvien" type="button">
                <i class="bi bi-person-vcard-fill me-1"></i> THẺ NHÂN VIÊN
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill fw-bold px-4" data-bs-toggle="pill" data-bs-target="#tab-khach" type="button">
                <i class="bi bi-person-badge-fill me-1"></i> THẺ KHÁCH
            </button>
        </li>
    </ul>

    <div class="tab-content" id="cardTabsContent">
        @functions {
            public void RenderCardGrid(IEnumerable<Quan_Ly_xe_Ra_Vao.Models.TheXe> cards, string icon)
            {
                if (!cards.Any())
                {
                    <div class="text-center py-5 mt-4"><i class="bi bi-inbox text-muted opacity-25" style="font-size: 4rem;"></i><h5 class="text-muted fw-bold mt-3">KHU VỰC NÀY CHƯA CÓ THẺ</h5></div>
                    return;
                }
                <div class="row g-4">
                    @foreach (var the in cards)
                    {
                        string borderColor = the.TrangThai == 2 ? "border-danger" : (the.TrangThai == 1 ? "border-success" : "border-primary");
                        string badgeColor = the.TrangThai == 2 ? "bg-danger" : (the.TrangThai == 1 ? "bg-success" : "bg-primary");
                        string statusText = the.TrangThai == 2 ? "Đã Khóa" : (the.TrangThai == 1 ? "Đang Sử Dụng" : "Sẵn Sàng");

                        <div class="col-xl-3 col-lg-4 col-md-6">
                            <div class="card border-0 rounded-4 shadow-sm card-hover h-100 position-relative overflow-hidden">
                                <div class="position-absolute top-0 start-0 w-100 border-top border-4 @borderColor"></div>
                                <div class="card-body p-4 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div class="bg-light p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;"><i class="bi @icon fs-2 text-secondary"></i></div>
                                        <span class="badge @badgeColor rounded-pill px-3 py-2 fw-bold shadow-sm">@statusText</span>
                                    </div>
                                    <h4 class="fw-bold text-dark mb-1 font-monospace letter-spacing-1">@the.MaThe</h4>
                                    <p class="text-muted small fw-bold text-uppercase mb-3"><i class="bi bi-tag-fill me-1"></i> @the.LoaiThe</p>
                                    @if (!string.IsNullOrEmpty(the.NguoiGiu))
                                    {
                                        <div class="mt-auto p-3 bg-light rounded-4 border">
                                            <small class="text-muted d-block mb-1" style="font-size: 0.7rem;">NGƯỜI ĐANG GIỮ THẺ</small>
                                            <h6 class="fw-bold text-primary mb-0 text-truncate"><i class="bi bi-person-check-fill me-1"></i> @the.NguoiGiu</h6>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mt-auto p-3 rounded-4 border border-dashed text-center"><small class="text-muted fw-bold"><i class="bi bi-inbox me-1"></i> Thẻ đang rỗng</small></div>
                                    }
                                    <div class="action-overlay position-absolute w-100 h-100 top-0 start-0 d-flex align-items-center justify-content-center gap-3">
                                        <a href="/TheXe/Edit/@the.Id" class="btn btn-light text-primary btn-lg rounded-circle shadow fw-bold"><i class="bi bi-pencil-fill"></i></a>
                                        <a href="javascript:void(0)" class="btn btn-light text-danger btn-lg rounded-circle shadow fw-bold" onclick="confirmDelete('@the.Id', '@the.MaThe')"><i class="bi bi-trash3-fill"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        <div class="tab-pane fade show active" id="tab-nhanvien" role="tabpanel">
            @{
                RenderCardGrid(Model.Where(t => t.LoaiThe == "Thẻ Nhân Viên"), "bi-person-vcard-fill");
            }
        </div>
        <div class="tab-pane fade" id="tab-khach" role="tabpanel">
            @{
                RenderCardGrid(Model.Where(t => t.LoaiThe == "Thẻ Khách"), "bi-person-badge-fill");
            }
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .border-dashed {
        border-style: dashed !important;
        border-color: #dee2e6 !important;
    }

    .card-hover {
        transition: all 0.3s;
        cursor: pointer;
    }

        .card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .action-overlay {
        background-color: rgba(0,0,0,0.5);
        backdrop-filter: blur(3px);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s;
    }

    .card-hover:hover .action-overlay {
        opacity: 1;
        visibility: visible;
    }

    .action-overlay .btn {
        transform: translateY(20px);
        transition: transform 0.3s;
    }

    .card-hover:hover .action-overlay .btn {
        transform: translateY(0);
    }

    .action-overlay .btn:hover {
        transform: scale(1.1);
    }

    .pulse-btn {
        animation: pulseButton 2s infinite;
    }

    @@keyframes pulseButton {
        0% {
            box-shadow: 0 0 0 0 rgba(33,37,41,0.5);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(33,37,41,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(33,37,41,0);
        }
    }

    .nav-pills .nav-link {
        color: #6c757d;
    }

        .nav-pills .nav-link.active {
            background-color: #0d6efd;
            color: white;
            box-shadow: 0 4px 10px rgba(13,110,253,0.3);
        }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(id, maThe) {
        Swal.fire({
            title: 'Xóa thẻ ' + maThe + '?',
            text: "Dữ liệu thẻ vật lý này sẽ bị xóa hoàn toàn khỏi hệ thống!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Vâng, xóa ngay!',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/TheXe/Delete/' + id;
            }
        })
    }

    document.addEventListener("DOMContentLoaded", function() {
        var successMsg = '@Html.Raw(TempData["Success"])';
        if (successMsg !== "") {
            Swal.fire({ title: 'Thành công!', text: successMsg, icon: 'success', timer: 2000, showConfirmButton: false });
        }
    });
</script>