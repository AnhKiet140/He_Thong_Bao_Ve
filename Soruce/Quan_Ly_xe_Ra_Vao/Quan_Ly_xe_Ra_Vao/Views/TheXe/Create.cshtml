@model Quan_Ly_xe_Ra_Vao.Models.TheXe
@{
    ViewData["Title"] = "Nhập Thẻ Mới";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-2 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm border-start border-5 border-dark">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-plus-circle-fill text-dark"></i> KHỞI TẠO THẺ VẬT LÝ MỚI</h4>
            <small class="text-muted fw-bold">HỆ THỐNG TỰ ĐỘNG CẤP MÃ VÀ CẬP NHẬT HÌNH ẢNH</small>
        </div>
        <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 shadow-sm border"><i class="bi bi-arrow-left"></i> QUAY LẠI</a>
    </div>

    <div class="card border-0 rounded-4 shadow-sm bg-white overflow-hidden">
        <div class="card-body p-4 p-md-5">
            <form asp-action="Create" method="post" id="createCardForm">
                <div class="row g-5">
                    <div class="col-lg-7 border-end pe-lg-5">
                        <h6 class="fw-bold text-primary mb-4 text-uppercase border-bottom pb-2"><i class="bi bi-credit-card-2-front"></i> THÔNG TIN THẺ CỨNG</h6>

                        <div class="mb-4">
                            <label class="fw-bold text-dark small text-uppercase mb-2">Mã Thẻ (Cấp tự động) <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                                <span class="input-group-text bg-dark border-0 text-white"><i class="bi bi-lock-fill"></i></span>
                                <input asp-for="MaThe" id="MaTheInput" class="form-control border-0 ps-3 fw-bold text-danger font-monospace bg-light" readonly />
                            </div>
                            <small class="text-muted mt-2 d-block" style="font-size: 0.75rem;">*Mã thẻ được hệ thống tạo tự động để chống trùng lặp dữ liệu.</small>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="fw-bold text-dark small text-uppercase mb-2">Phân Loại Thẻ</label>
                                <select asp-for="LoaiThe" id="LoaiTheSelect" class="form-select form-select-lg border rounded-3 shadow-sm text-dark fw-bold">
                                    <option value="Thẻ Nhân Viên">Thẻ Nhân Viên</option>
                                    <option value="Thẻ Khách">Thẻ Khách</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold text-dark small text-uppercase mb-2">Trạng Thái Khởi Tạo</label>
                                <select asp-for="TrangThai" class="form-select form-select-lg border rounded-3 shadow-sm text-dark fw-bold">
                                    <option value="0">Sẵn sàng (Lưu kho)</option>
                                    <option value="1">Đang sử dụng (Giao ngay)</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold text-dark small text-uppercase mb-2">Họ Tên Người Giữ (Tùy chọn)</label>
                            <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
                                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-person-badge"></i></span>
                                <input asp-for="NguoiGiu" class="form-control border-0 ps-0 text-dark fw-bold" placeholder="Nhập tên người đang giữ thẻ..." />
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5 ps-lg-4 d-flex flex-column">
                        <h6 class="fw-bold text-primary mb-4 text-uppercase border-bottom pb-2"><i class="bi bi-camera-fill"></i> HỒ SƠ NHẬN DIỆN (TÙY CHỌN)</h6>
                        <div class="border border-3 border-dashed rounded-4 bg-light d-flex align-items-center justify-content-center overflow-hidden position-relative mb-3 shadow-sm" style="height: 280px; width: 100%;">
                            <video id="cameraFeed" class="w-100 h-100 d-none" autoplay muted style="object-fit: cover; transform: scaleX(-1);"></video>
                            <img id="photoPreview" src="/images/face-id.png" onerror="this.src='/images/no-avatar.png'" class="img-fluid w-100 h-100 p-3" style="object-fit: contain;" />
                            <div id="flashEffect" class="position-absolute top-0 start-0 w-100 h-100 bg-white d-none" style="z-index: 10; opacity: 0.8;"></div>
                        </div>

                        <div class="d-flex gap-2 justify-content-center mb-4">
                            <button type="button" id="btnStartCamera" class="btn btn-outline-primary fw-bold rounded-pill px-3" onclick="startCamera()"><i class="bi bi-camera-video-fill"></i> Bật Camera</button>
                            <button type="button" id="btnCapture" class="btn btn-danger fw-bold rounded-pill px-3 d-none" onclick="takePhoto()"><i class="bi bi-record-circle"></i> Chụp Ngay</button>
                            <button type="button" class="btn btn-outline-dark fw-bold rounded-pill px-3" onclick="document.getElementById('fileUpload').click()"><i class="bi bi-upload"></i> Tải Ảnh Lên</button>
                            <input type="file" id="fileUpload" class="d-none" accept="image/*" onchange="handleFileUpload(event)">
                            <input type="hidden" name="HinhAnhBase64" id="HinhAnhBase64" />
                        </div>

                        <div class="mt-auto text-end">
                            <hr class="text-muted opacity-25">
                            <button type="button" onclick="confirmSave()" class="btn btn-success btn-lg fw-bold rounded-pill px-5 shadow"><i class="bi bi-floppy-fill me-2"></i> LƯU VÀO HỆ THỐNG</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .border-dashed {
        border-style: dashed !important;
        border-color: #ced4da !important;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    const nextKH = '@ViewBag.NextKH';
    const nextNV = '@ViewBag.NextNV';

    document.getElementById('LoaiTheSelect').addEventListener('change', function() {
        const input = document.getElementById('MaTheInput');
        if (this.value === 'Thẻ Khách') { input.value = nextKH; }
        else { input.value = nextNV; }

        input.parentElement.classList.add('border-success', 'border-2');
        setTimeout(() => input.parentElement.classList.remove('border-success', 'border-2'), 500);
    });
    document.getElementById('LoaiTheSelect').dispatchEvent(new Event('change'));

    document.addEventListener("DOMContentLoaded", function() {
        var errorMsg = '@Html.Raw(TempData["Error"])';
        if (errorMsg !== "") {
            Swal.fire({ title: 'Thẻ này bị trùng!', text: errorMsg, icon: 'error', confirmButtonColor: '#0d6efd', borderRadius: '15px' });
        }
    });

    let streamRef = null;
    async function startCamera() {
        const video = document.getElementById('cameraFeed');
        const img = document.getElementById('photoPreview');
        try {
            streamRef = await navigator.mediaDevices.getUserMedia({ video: true });
            video.srcObject = streamRef;
            video.classList.remove('d-none'); img.classList.add('d-none');
            document.getElementById('btnStartCamera').classList.add('d-none'); document.getElementById('btnCapture').classList.remove('d-none');
        } catch (err) { Swal.fire('Lỗi Camera', 'Vui lòng cấp quyền sử dụng Camera.', 'error'); }
    }

    function takePhoto() {
        const video = document.getElementById('cameraFeed');
        const canvas = document.createElement('canvas');
        canvas.width = video.videoWidth; canvas.height = video.videoHeight;
        const ctx = canvas.getContext('2d');
        ctx.translate(canvas.width, 0); ctx.scale(-1, 1);
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

        const dataUrl = canvas.toDataURL('image/jpeg');
        document.getElementById('photoPreview').src = dataUrl;
        document.getElementById('photoPreview').style.objectFit = 'cover';
        document.getElementById('photoPreview').classList.remove('p-3');
        document.getElementById('HinhAnhBase64').value = dataUrl;
        stopCamera();
    }

    function handleFileUpload(event) {
        const file = event.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('photoPreview').src = e.target.result;
            document.getElementById('photoPreview').style.objectFit = 'cover';
            document.getElementById('photoPreview').classList.remove('p-3');
            document.getElementById('HinhAnhBase64').value = e.target.result;
            stopCamera();
        }
        reader.readAsDataURL(file);
    }

    function stopCamera() {
        if (streamRef) { streamRef.getTracks().forEach(track => track.stop()); streamRef = null; }
        document.getElementById('cameraFeed').classList.add('d-none');
        document.getElementById('photoPreview').classList.remove('d-none');
        document.getElementById('btnStartCamera').classList.remove('d-none');
        document.getElementById('btnCapture').classList.add('d-none');
    }

    function confirmSave() {
        Swal.fire({
            title: 'LƯU THÔNG TIN THẺ?',
            text: "Thẻ mới sẽ được cấp mã: " + document.getElementById('MaTheInput').value,
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Tạo Thẻ Ngay',
            confirmButtonColor: '#198754'
        }).then((result) => {
            if (result.isConfirmed) document.getElementById('createCardForm').submit();
        });
    }
</script>