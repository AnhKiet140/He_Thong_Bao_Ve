@model Quan_Ly_xe_Ra_Vao.Models.TheXe
@{
    ViewData["Title"] = "Nhập Thẻ Mới";
}

<style>
    .square-box, .form-control, .form-select, .btn {
        border-radius: 0 !important;
    }
</style>

<div class="container mt-5">
    <div class="card square-box border-dark shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-header bg-dark text-white square-box py-3">
            <h5 class="mb-0 fw-bold text-uppercase"><i class="bi bi-credit-card"></i> NHẬP THÔNG TIN THẺ CỨNG</h5>
        </div>
        <div class="card-body p-4 bg-light">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Mã Thẻ / UID (*)</label>
                    <input asp-for="MaThe" class="form-control form-control-lg border-dark" placeholder="VD: THE-KHACH-001" required />
                </div>
                <div class="mb-3">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Loại Thẻ</label>
                    <select asp-for="LoaiThe" class="form-select form-select-lg border-dark">
                        <option value="Thẻ Khách">Thẻ Khách</option>
                        <option value="Thẻ Nhân Viên">Thẻ Nhân Viên</option>
                        <option value="Thẻ Quản Trị">Thẻ Quản Trị (Master)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Trạng Thái Thẻ</label>
                    <select asp-for="TrangThai" class="form-select form-select-lg border-dark">
                        <option value="0">Sẵn sàng (Đang ở quầy)</option>
                        <option value="1">Đang sử dụng (Đã giao khách)</option>
                        <option value="2">Đã Khóa / Báo Mất</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Người đang giữ (Nếu có)</label>
                    <input asp-for="NguoiGiu" class="form-control form-control-lg border-dark" placeholder="Nhập tên người giữ..." />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-dark square-box fw-bold px-4">HỦY BỎ</a>
                    <button type="submit" class="btn btn-primary square-box fw-bold px-4">LƯU DỮ LIỆU</button>
                </div>
            </form>
        </div>
    </div>
</div>