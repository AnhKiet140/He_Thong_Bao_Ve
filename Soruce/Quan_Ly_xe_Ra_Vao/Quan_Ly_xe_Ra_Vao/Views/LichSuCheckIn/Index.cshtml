@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.LichSuCheckIn>

@{
    ViewData["Title"] = "Nhật Ký Lịch Sử Ra Vào";
}

<style>
    .rounded-0 {
        border-radius: 0 !important;
    }

    .table-custom th {
        background-color: #f8f9fa;
        color: #333;
        font-weight: bold;
        border-bottom: 2px solid #000;
        padding: 12px;
    }

    .table-custom td {
        padding: 12px;
        vertical-align: middle;
        border-bottom: 1px solid #eee;
    }

    .avatar-sm {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border: 2px solid #ccc;
        border-radius: 4px;
    }
</style>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold border-start border-5 border-dark ps-3 text-uppercase">NHẬT KÝ RA VÀO CHI TIẾT</h3>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark rounded-0 fw-bold"><i class="bi bi-file-earmark-excel"></i> Xuất Excel</button>
        </div>
    </div>

    <div class="card rounded-0 border shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-custom mb-0 text-center">
                <thead>
                    <tr>
                        <th class="text-start">Thời Gian</th>
                        <th class="text-start">Đối Tượng Kiểm Soát</th>
                        <th>Biển Số Xe</th>
                        <th>Phương Thức</th>
                        <th>Hướng</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td class="text-start fw-bold">@log.ThoiGian.ToString("dd/MM/yyyy HH:mm:ss")</td>

                                <td class="text-start">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(log.HinhAnh))
                                        {
                                            <img src="@log.HinhAnh" class="avatar-sm me-3 shadow-sm" />
                                        }
                                        else
                                        {
                                            <div class="avatar-sm me-3 bg-light d-flex align-items-center justify-content-center border">
                                                <i class="bi bi-person text-secondary fs-4"></i>
                                            </div>
                                        }

                                        <div>
                                            <span class="@(log.HoTen == "Không xác định" ? "text-danger fw-bold text-uppercase" : "fw-bold text-primary text-uppercase")">@log.HoTen</span><br>
                                            <small class="text-muted">@log.LoaiDoiTuong</small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="border border-dark px-2 py-1 fw-bold font-monospace">
                                        @(string.IsNullOrEmpty(log.BienSoXe) ? "Không có" : log.BienSoXe)
                                    </span>
                                </td>

                                <td>
                                    @if (log.PhuongThuc != null && (log.PhuongThuc.Contains("FaceID") || log.PhuongThuc.Contains("Vân Tay")))
                                    {
                                        <span class="badge bg-info text-dark rounded-0 px-2 py-1"><i class="bi bi-person-bounding-box"></i> @log.PhuongThuc</span>
                                    }
                                    else if (log.PhuongThuc != null && log.PhuongThuc.Contains("Cảnh báo"))
                                    {
                                        <span class="badge bg-danger rounded-0 px-2 py-1"><i class="bi bi-exclamation-triangle"></i> @log.PhuongThuc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-0 px-2 py-1"><i class="bi bi-credit-card"></i> @log.PhuongThuc</span>
                                    }
                                </td>

                                <td>
                                    @if (log.Huong == "Đi Vào")
                                    {
                                        <span class="text-success fw-bold"><i class="bi bi-arrow-right-circle"></i> Đi Vào</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning text-dark fw-bold"><i class="bi bi-arrow-left-circle"></i> Đi Ra</span>
                                    }
                                </td>

                                <td>
                                    @if (log.TrangThai == "Thành Công")
                                    {
                                        <span class="text-success fw-bold">@log.TrangThai</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">@log.TrangThai</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-muted py-5 fs-5">Hệ thống đang chờ dữ liệu quét... Chưa có ai ra vào.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>