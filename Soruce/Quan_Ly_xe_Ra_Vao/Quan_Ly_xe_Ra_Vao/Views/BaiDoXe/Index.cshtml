    }

        .cam-feed:active {
            cursor: grabbing;
        }

        .cam-feed:hover {
            border-color: #0d6efd;
            box-shadow: 0 0 15px rgba(13, 110, 253, 0.4);
        }

    .cam-content {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle, #2a2a2a 0%, #000 100%);
