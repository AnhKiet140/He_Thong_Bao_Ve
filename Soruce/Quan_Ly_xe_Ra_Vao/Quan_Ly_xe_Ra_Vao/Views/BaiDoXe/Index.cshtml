    }

    [data-bs-theme="dark"] .floating-window {
        background: #1e1e1e;
        border: 1px solid #444;
        box-shadow: 0 15px 50px rgba(0,0,0,0.8);
    }
</style>

<script>
    const isAdmin = '@userRole' === 'Admin';
    let currentFloorFilter = '@currentTang';
    let prefixCode = currentFloorFilter === 'B1' ? 'A' : 'B';

    // TÍCH HỢP LOCALSTORAGE ĐỂ ĐỒNG BỘ DATA XUYÊN TRANG
    let dbCounters = JSON.parse(localStorage.getItem('chkIn_dbCounters')) || { vip: 24, guest: 60, emp: 120 };
    let cameraList = [];

    let rawData = @Html.Raw(Json.Serialize(danhSachXeDangDau));
    let parkedCars = {};
    if (rawData) { rawData.forEach(car => { if(car.viTri) { let slotNormalized = car.viTri.replace(/\s+/g, '').toUpperCase(); parkedCars[slotNormalized] = { role: car.loai, plate: car.bienSo, name: car.ten }; } }); }
    let totalViolations = 0;
    let sortableCameraGrid = null;

    function saveCounters() { localStorage.setItem('chkIn_dbCounters', JSON.stringify(dbCounters)); }

    // ==========================================
    // 1. TẠO BÃI ĐỖ VÀ TỰ ĐỘNG CHIA LƯỚI ĐƯỜNG ĐI
    // ==========================================
    function renderMainMap() {
        const container = document.getElementById('dynamic-main-parking-grid');
        if (!container) return;
        container.innerHTML = '';

        let totalSlots = prefixCode === 'A' ? (dbCounters.vip + dbCounters.guest) : dbCounters.emp;
        let html = '';
        const slotsPerRow = 12;
        const rowsPerBlock = 2; // Cứ 2 dòng là chèn 1 đường đi
        let currentSlot = 1;

        while (currentSlot <= totalSlots) {
            let endSlot = Math.min(currentSlot + (slotsPerRow * rowsPerBlock) - 1, totalSlots);
            html += `<div class="parking-block mb-3"><div class="parking-grid">`;

            for (let i = currentSlot; i <= endSlot; i++) {
                let slotId = `${prefixCode}-${i}`;
                let parkedCarInfo = parkedCars[slotId];
                let isOccupied = !!parkedCarInfo;

                let roleClass = ''; let roleLabel = ''; let roleIcon = ''; let intendedRole = '';
                if (prefixCode === 'A') {
                    if (i <= dbCounters.vip) { intendedRole = 'VIP'; roleClass = 'slot-vip'; roleLabel = 'VIP/SẾP'; roleIcon = '<i class="bi bi-star-fill mb-1"></i>'; }
                    else { intendedRole = 'Khách'; roleClass = 'slot-customer'; roleLabel = 'KHÁCH'; roleIcon = '<i class="bi bi-person-badge mb-1"></i>'; }
                } else {
                    intendedRole = 'Nhân Viên'; roleClass = 'slot-employee'; roleLabel = 'NHÂN VIÊN'; roleIcon = '<i class="bi bi-person-vcard mb-1"></i>';
                }

                let cssClass = isOccupied ? 'slot-occupied' : roleClass;
                let content = isOccupied
                    ? `<i class="bi bi-car-front-fill car-icon animate__animated animate__zoomIn text-success"></i><span style="font-size:0.55rem; color:#fff" class="bg-success px-1 rounded mt-1">${parkedCarInfo.plate}</span>`
                    : `${roleIcon}<span style="font-size: 0.5rem; opacity: 0.8">${roleLabel}</span><span class="fw-bold mt-1" style="font-size: 0.8rem;">${slotId}</span>`;

                let adminDeleteBtn = isAdmin ? `<button class="btn btn-danger position-absolute top-0 end-0 p-0 rounded-circle d-flex align-items-center justify-content-center btn-delete-slot" onclick="deleteSlot('${slotId}', event)" title="Xóa ô đỗ này"><i class="bi bi-x" style="font-size: 14px; margin: 0;"></i></button>` : '';

                html += `<div class="parking-slot ${cssClass} animate__animated animate__fadeIn" onclick="showSlotInfo('${slotId}', '${isOccupied?parkedCarInfo.name:''}', '${isOccupied?parkedCarInfo.plate:''}', '')">${adminDeleteBtn}${content}</div>`;
            }
            html += `</div></div>`;
            currentSlot = endSlot + 1;

            if (currentSlot <= totalSlots) {
                // Chèn đường đi nội bộ
                html += `<div class="driveway-clean"><i class="bi bi-chevron-double-left fs-3 driveway-arrow left"></i><span><i class="bi bi-car-front"></i> LÀN LƯU THÔNG <i class="bi bi-car-front"></i></span><i class="bi bi-chevron-double-right fs-3 driveway-arrow right"></i></div>`;
            }
        }
        container.innerHTML = html;

        // KÍCH HOẠT DRAG & DROP Ô ĐỖ XE (CHỈ ADMIN)
        if(isAdmin) {
            document.querySelectorAll('.parking-grid').forEach(grid => {
                new Sortable(grid, { group: 'shared-parking', animation: 150, ghostClass: 'sortable-ghost' });
            });
        }
    }

    // ==========================================
    // 2. GIAO DIỆN CAMERA: ĐỒNG BỘ TỨC THÌ
    // ==========================================
    function initCameraData() {
        cameraList = [];
        let totalSlots = prefixCode === 'A' ? (dbCounters.vip + dbCounters.guest) : dbCounters.emp;
        for(let i=1; i<=totalSlots; i++){
            let id = `${prefixCode}-${i}`;
            cameraList.push({ id: id, name: `Cam Ô ${id}`, floor: currentFloorFilter });
        }
        cameraList.unshift({ id: 'MAIN-IN', name: `ALPR Lối Vào ${currentFloorFilter}`, floor: currentFloorFilter });
        cameraList.unshift({ id: 'MAIN-OUT', name: `ALPR Lối Ra ${currentFloorFilter}`, floor: currentFloorFilter });
        cameraList.unshift({ id: 'MAIN-PTZ', name: `Toàn Cảnh Bãi ${currentFloorFilter} (PTZ)`, floor: currentFloorFilter });
    }

    function renderCameras() {
        if(cameraList.length === 0) initCameraData();
        const grid = document.getElementById('cctv-grid-view');
        grid.innerHTML = '';

        cameraList.forEach(cam => {
            if(cam.floor === currentFloorFilter) {
                const isMain = cam.id.startsWith('MAIN');
                const widthStyle = isMain ? 'width: 450px; height: 280px;' : 'width: 300px; height: 200px;';

                const html = `
                    <div style="display:inline-block;" class="dynamic-cam-item" data-id="${cam.id}">
                        <div class="cam-feed rounded-2" style="${widthStyle}">
                            <div class="cam-content"><i class="bi bi-camera-video text-white opacity-25"></i></div>
                            <div class="cam-status rounded-1"><i class="bi bi-circle-fill text-white small me-1"></i> ONLINE</div>
                            <div class="cam-title"><i class="bi bi-geo-alt-fill text-info me-1"></i><span class="cam-name-text">${cam.name}</span></div>
                            <button class="btn-fullscreen rounded-1" onclick="toggleFullscreen(this.parentElement)" title="Phóng to"><i class="bi bi-arrows-fullscreen"></i></button>
                            <div class="cam-overlay"><span>CHK-IN // ${cam.id}</span><span class="live-clock-cam text-info fw-bold"></span></div>
                        </div>
                    </div>`;
                grid.insertAdjacentHTML('beforeend', html);
            }
        });

        // Kích hoạt Drag & Drop Camera
        if(isAdmin) {
            new Sortable(grid, { animation: 150, ghostClass: 'sortable-ghost', handle: '.cam-feed' });
        }
    }

    // ==========================================
    // UI TABS & FULLSCREEN
    // ==========================================
    function switchTab(tab) {
        const btnB = document.getElementById('btn-tab-blueprint'), btnC = document.getElementById('btn-tab-camera');
        const viewB = document.getElementById('content-sodo'), viewC = document.getElementById('content-cctv');
        if (tab === 'blueprint') {
            btnB.className = 'nav-link active fw-bold px-4 rounded-1 shadow-sm'; btnC.className = 'nav-link fw-bold px-4 rounded-1 shadow-sm';
            viewB.classList.add('show', 'active'); viewC.classList.remove('show', 'active');
        } else {
            btnC.className = 'nav-link active fw-bold px-4 rounded-1 shadow-sm'; btnB.className = 'nav-link fw-bold px-4 rounded-1 shadow-sm';
            viewC.classList.add('show', 'active'); viewB.classList.remove('show', 'active');
            renderCameras();
        }
    }

    window.toggleFullscreen = function(camElement) {
        if (!document.fullscreenElement) {
            camElement.classList.add('cam-fullscreen'); camElement.querySelector('.btn-fullscreen').innerHTML = '<i class="bi bi-fullscreen-exit text-danger fs-3"></i>';
            if (camElement.requestFullscreen) { camElement.requestFullscreen(); } else if (camElement.webkitRequestFullscreen) { camElement.webkitRequestFullscreen(); }
        } else {
            if (document.exitFullscreen) { document.exitFullscreen(); }
        }
    }
    document.addEventListener('fullscreenchange', () => {
        if (!document.fullscreenElement) document.querySelectorAll('.cam-fullscreen').forEach(el => { el.classList.remove('cam-fullscreen'); el.querySelector('.btn-fullscreen').innerHTML = '<i class="bi bi-arrows-fullscreen"></i>'; });
    });

    setInterval(() => {
        const now = new Date(); const timeStr = now.toLocaleTimeString('en-US', { hour12: false }) + ':' + now.getMilliseconds().toString().padStart(3, '0').substring(0,2);
        document.querySelectorAll('.live-clock-cam').forEach(el => el.innerText = timeStr);
    }, 50);

    document.addEventListener("DOMContentLoaded", () => {
        renderMainMap();
    });

    // ==========================================
    // BỘ CÔNG CỤ CỬA SỔ NỔI CHO ADMIN
    // ==========================================
    @if (userRole == "Admin")
    {
            <text>
            function openFloatingWindow(winId) {
                const win = document.getElementById(winId);
                win.classList.remove('d-none', 'animate__zoomOut');
                win.classList.add('animate__zoomIn');
                win.style.transform = "translate(-50%, -50%)"; // Căn giữa lại màn hình
                win.style.top = "50%";
                win.style.left = "50%";

                if(winId === 'window-manage-camera') {
                    document.getElementById('adminCamFilter').value = currentFloorFilter;
                    syncCameraTable();
                }
                if(winId === 'window-manage-parking') autoConfigParking();

                makeDraggableWindow(win);
            }

            // TỰ ĐỘNG ĐÓNG WINDOW KHI LÀM XONG
            function closeFloatingWindow(winId) {
                const win = document.getElementById(winId);
                win.classList.remove('animate__zoomIn', 'floating-maximized');
                win.classList.add('animate__zoomOut');
                setTimeout(() => { win.classList.add('d-none'); }, 300);
            }

            function toggleMaximize(winId) {
                const win = document.getElementById(winId);
                if (win.classList.contains('floating-maximized')) { win.classList.remove('floating-maximized'); }
                else { win.classList.add('floating-maximized'); win.style.transform = "none"; }
            }

            // THUẬT TOÁN RESIZE 8 HƯỚNG VÀ DRAG WINDOW
            function makeDraggableWindow(win) {
                const header = win.querySelector('.floating-header');
                const resizers = win.querySelectorAll('.resizer');
                let isResizing = false; let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;

                header.onmousedown = function(e) {
                    if (e.target.closest('button') || win.classList.contains('floating-maximized')) return;
                    e.preventDefault(); pos3 = e.clientX; pos4 = e.clientY;
                    document.onmouseup = closeDragElement; document.onmousemove = elementDrag;
                };
                function elementDrag(e) {
                    e.preventDefault(); pos1 = pos3 - e.clientX; pos2 = pos4 - e.clientY; pos3 = e.clientX; pos4 = e.clientY;
                    if (win.style.transform.includes('translate')) {
                        const rect = win.getBoundingClientRect(); win.style.transform = "none"; win.style.top = rect.top + "px"; win.style.left = rect.left + "px";
                    }
                    win.style.top = (win.offsetTop - pos2) + "px"; win.style.left = (win.offsetLeft - pos1) + "px";
                }
                function closeDragElement() { document.onmouseup = null; document.onmousemove = null; }

                let original_width = 0, original_height = 0, original_x = 0, original_y = 0, original_mouse_x = 0, original_mouse_y = 0;
                for (let i = 0; i < resizers.length; i++) {
                    const currentResizer = resizers[i];
                    currentResizer.onmousedown = function(e) {
                        e.preventDefault(); isResizing = true;
                        original_width = parseFloat(getComputedStyle(win, null).getPropertyValue('width').replace('px', ''));
                        original_height = parseFloat(getComputedStyle(win, null).getPropertyValue('height').replace('px', ''));
                        original_x = win.getBoundingClientRect().left; original_y = win.getBoundingClientRect().top;
                        original_mouse_x = e.pageX; original_mouse_y = e.pageY;
                        if (win.style.transform.includes('translate')) { win.style.transform = "none"; win.style.left = original_x + "px"; win.style.top = original_y + "px"; }
                        window.addEventListener('mousemove', resize); window.addEventListener('mouseup', stopResize);
                    };
                    function resize(e) {
                        if (currentResizer.classList.contains('resizer-br')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px'; }
                        else if (currentResizer.classList.contains('resizer-bl')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px'; }
                        else if (currentResizer.classList.contains('resizer-tr')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                        else if (currentResizer.classList.contains('resizer-tl')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                        else if (currentResizer.classList.contains('resizer-r')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px'; }
                        else if (currentResizer.classList.contains('resizer-l')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px'; }
                        else if (currentResizer.classList.contains('resizer-b')) { win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px'; }
                        else if (currentResizer.classList.contains('resizer-t')) { win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                    }
                    function stopResize() { window.removeEventListener('mousemove', resize); isResizing = false; }
                }
            }

            function autoConfigParking() {
                const type = document.querySelector('input[name="parkType"]:checked').value;
                const zoneInput = document.getElementById('autoZone');
                const idInput = document.getElementById('autoSlotId');
                if (type === 'Sep') { zoneInput.value = 'Tầng Hầm - Khu A (VIP & Khách)'; idInput.value = 'A-' + (dbCounters.vip + 1).toString().padStart(2, '0'); idInput.className = 'form-control fw-bold text-warning font-monospace fs-5 rounded-end-1'; }
                else if (type === 'Khach') { zoneInput.value = 'Tầng Hầm - Khu A (VIP & Khách)'; idInput.value = 'A-' + (dbCounters.vip + dbCounters.guest + 1).toString().padStart(2, '0'); idInput.className = 'form-control fw-bold text-info font-monospace fs-5 rounded-end-1'; }
                else { zoneInput.value = 'Tầng Hầm - Khu B (Nhân Viên)'; idInput.value = 'B-' + (dbCounters.emp + 1).toString().padStart(2, '0'); idInput.className = 'form-control fw-bold text-secondary font-monospace fs-5 rounded-end-1'; }
            }

            // TẠO Ô ĐỖ & ĐÓNG FORM
            function submitCreateParking() {
                const type = document.querySelector('input[name="parkType"]:checked').value;
                const slotId = document.getElementById('autoSlotId').value;

                let processCreation = () => {
                    closeFloatingWindow('window-manage-parking'); // ĐÓNG FORM NGAY LẬP TỨC

                    Swal.fire('Đồng bộ hoàn tất!', `Đã tạo vị trí <b>${slotId}</b>.`, 'success').then(() => {
                        renderMainMap(); // Dựng lại lưới kèm đường đi chuẩn 2 dòng
                    });
                };

                if (type === 'Sep') {
                    Swal.fire({ title: 'Đang dời chỗ...', html: 'Hệ thống đang tự động dời các xe Khách xuống 1 vị trí.', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                    setTimeout(() => { dbCounters.vip++; saveCounters(); processCreation(); }, 1000);
                } else if (type === 'Khach') { dbCounters.guest++; saveCounters(); processCreation(); }
                else { dbCounters.emp++; saveCounters(); processCreation(); }
            }

            function deleteSlot(slotId, event) {
                event.stopPropagation();
                Swal.fire({
                    title: 'Xóa vị trí?', text: `Gỡ bỏ ô đỗ ${slotId}?`, icon: 'warning',
                    showCancelButton: true, confirmButtonColor: '#d33', cancelButtonText: 'Hủy', confirmButtonText: 'Xóa ngay'
                }).then((result) => {
                    if (result.isConfirmed) {
                        if(slotId.startsWith('A')) { dbCounters.guest--; } else { dbCounters.emp--; }
                        saveCounters(); renderMainMap();
                    }
                });
            }

            // QUẢN TRỊ CAMERA (BẢNG)
            function syncCameraTable() {
                if(cameraList.length === 0) initCameraData();
                const tbody = document.querySelector('#cameraAdminTable tbody');
                tbody.innerHTML = '';
                const filterVal = document.getElementById('adminCamFilter').value;

                cameraList.forEach((cam) => {
                    if(filterVal === 'all' || cam.floor === filterVal) {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>
                                <div class="btn-group btn-group-sm shadow-sm">
                                    <button class="btn btn-light border text-muted" onclick="moveRowUp(this)"><i class="bi bi-chevron-up"></i></button>
                                    <button class="btn btn-light border text-muted" onclick="moveRowDown(this)"><i class="bi bi-chevron-down"></i></button>
                                </div>
                            </td>
                            <td class="text-start fw-bold">
                                <input type="text" class="form-control form-control-sm border-1 border-light bg-transparent fw-bold text-primary shadow-none" value="${cam.name}" onchange="renameCameraInDB(this, '${cam.id}')">
                            </td>
                            <td><span class="badge bg-secondary rounded-1">${cam.floor}</span></td>
                            <td><button class="btn btn-sm btn-outline-danger rounded-1" onclick="deleteCameraFromTable(this, '${cam.id}')"><i class="bi bi-trash3-fill"></i></button></td>
                        `;
                        tbody.appendChild(tr);
                    }
                });
            }

            function filterAdminCameras() { syncCameraTable(); }

            function renameCameraInDB(inputEl, id) {
                const cam = cameraList.find(c => c.id === id);
                if(cam) cam.name = inputEl.value;
                const liveCamText = document.querySelector(`.dynamic-cam-item[data-id="${id}"] .cam-name-text`);
                if(liveCamText) liveCamText.innerText = inputEl.value;
            }

            function deleteCameraFromTable(btn, id) {
                const row = btn.closest('tr');
                row.classList.add('animate__animated', 'animate__fadeOutRight');
                cameraList = cameraList.filter(c => c.id !== id);
                setTimeout(() => { row.remove(); const liveCam = document.querySelector(`.dynamic-cam-item[data-id="${id}"]`); if(liveCam) liveCam.remove(); }, 500);
            }

            function addNewCameraRow() {
                Swal.fire({
                    title: 'Tên Camera Mới', input: 'text', inputPlaceholder: 'VD: Cam Lối Vào B', showCancelButton: true, confirmButtonText: 'Lưu Camera'
                }).then((result) => {
                    if(result.isConfirmed && result.value) {
                        const name = result.value; const id = 'CUSTOM-' + Math.floor(Math.random()*1000);
                        cameraList.unshift({ id: id, name: name, floor: currentFloorFilter });
                        syncCameraTable(); renderCameras();
                        Swal.fire('Thành công', 'Đã thêm Camera vào hệ thống.', 'success');
                    }
                });
            }

            function moveRowUp(btn) { const row = btn.closest('tr'); const prev = row.previousElementSibling; if (prev) row.parentNode.insertBefore(row, prev); }
            function moveRowDown(btn) { const row = btn.closest('tr'); const next = row.nextElementSibling; if (next) row.parentNode.insertBefore(next, row); }
            </text>
    }

    function showSlotInfo(id, name, plate, img) {
        document.getElementById('slotDetailCard').classList.remove('d-none'); document.getElementById('emptySlotNotify').classList.add('d-none');
        document.getElementById('lblSlotId').innerText = id;
        if (name && name !== 'null' && name !== '') { document.getElementById('slotUser').innerText = name; document.getElementById('slotPlate').innerText = plate; document.getElementById('slotImg').src = img || '/images/no-avatar.png'; }
        else { resetSlot(); Swal.fire({ title: 'Vị trí ' + id, text: 'Vị trí này hiện đang trống.', icon: 'info', timer: 1500, showConfirmButton: false }); }
    }
    function resetSlot() { document.getElementById('slotDetailCard').classList.add('d-none'); document.getElementById('emptySlotNotify').classList.remove('d-none'); }
</script>