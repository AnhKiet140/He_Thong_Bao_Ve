                                    <a href="@Url.Action("Index", new { tang = "B2", selectedDate = selectedDate, searchName = ViewBag.SearchName })"
                                       class="btn btn-sm @(currentTang == "B2" ? "btn-info text-dark" : "btn-outline-secondary text-light") fw-bold">Khu B (NV)</a>
                                </div>
                            </div>
                        </div>

                        <div id="dynamic-main-parking-grid" class="w-100 pb-3"></div>

                    </div>
                </div>

                <div class="col-lg-4 d-flex flex-column gap-3">
                    <div id="slotDetailCard" class="card border-0 shadow-sm p-4 bg-white text-center d-none animate__animated animate__fadeInRight rounded-2">
