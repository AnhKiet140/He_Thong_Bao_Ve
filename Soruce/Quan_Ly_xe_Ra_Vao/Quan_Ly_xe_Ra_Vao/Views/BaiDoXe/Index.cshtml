    /* CAMERA FEED (RESIZE 8 HƯỚNG BẰNG CSS) */
    .cam-feed {
        background: #1a1a1a;
        border: 1px solid #333;
        position: relative;
        box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s, box-shadow 0.3s;
        cursor: grab;
        resize: both;
        overflow: hidden;
        min-width: 250px;
