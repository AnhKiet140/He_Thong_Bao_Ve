    /* FLOATING WINDOW (RESIZE MỌI GÓC) */
    .floating-window {
        position: fixed;
        z-index: 9999;
        background: #fff;
        border-radius: 4px;
        box-shadow: 0 10px 50px rgba(0,0,0,0.5);
        border: 1px solid rgba(0,0,0,0.15);
