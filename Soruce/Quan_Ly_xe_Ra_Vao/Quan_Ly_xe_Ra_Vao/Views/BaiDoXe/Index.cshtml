@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.LichSuCheckIn>
@using Quan_Ly_xe_Ra_Vao.Data
@inject ApplicationDbContext DbContext

@{
    ViewData["Title"] = "Quản Lý Bãi Xe Thông Minh";
    string userRole = User.Identity.IsAuthenticated ? User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value : "Guest";

    string currentTang = ViewBag.CurrentTang ?? "B1";
    int currentPage = ViewBag.CurrentPage ?? 1;
    string selectedDate = ViewBag.SelectedDate ?? DateTime.Today.ToString("yyyy-MM-dd");
    string filterStatus = ViewBag.FilterStatus as string ?? "Tất cả";
    string prefix = (currentTang == "B1") ? "A" : "B";

    // 1. Chuẩn hóa dữ liệu đầu vào (Chỉ lấy Ô tô)
    var cleanModel = Model.Where(x =>
        !string.IsNullOrEmpty(x.LoaiXe) &&
        (x.LoaiXe.ToLower().Contains("tô") || x.LoaiXe.ToLower().Contains("oto")) &&
        !string.IsNullOrEmpty(x.BienSoXe) &&
        x.BienSoXe.ToLower() != "undefined" &&
        x.BienSoXe.ToLower() != "null" &&
        x.BienSoXe != "---" &&
        x.BienSoXe != "N/A" &&
        !x.BienSoXe.ToLower().Contains("máy")
    ).Select(x => { x.LoaiXe = "Ô tô"; x.BienSoXe = x.BienSoXe.ToUpper(); return x; }).ToList();

    // 2. Tìm xe đang đậu trong bãi
    var xeDangTrongBai = cleanModel
        .GroupBy(x => x.HoTen + "_" + x.BienSoXe)
        .Select(g => g.OrderByDescending(x => x.ThoiGian).FirstOrDefault())
        .Where(last => last != null && last.Huong == "Đi Vào").ToList();

    // 3. Cấp vị trí ảo cho xe (ĐÃ FIX: Bỏ đuôi :D2 để tạo mã A-1 thay vì A-01 để đồng bộ với JS)
    var xeTangNay = xeDangTrongBai.Where(x => string.IsNullOrEmpty(x.ViTriDo) || x.ViTriDo.StartsWith(prefix)).ToList();
    List<string> usedSlots = xeTangNay.Where(x => !string.IsNullOrEmpty(x.ViTriDo)).Select(x => x.ViTriDo).ToList();

    foreach (var xe in xeTangNay.Where(x => string.IsNullOrEmpty(x.ViTriDo)))
    {
        int seed = $"{xe.HoTen}_{xe.BienSoXe}".GetHashCode();
        Random rnd = new Random(seed);
        bool assigned = false;
        for (int i = 0; i < 50; i++)
        {
            string slotId = $"{prefix}-{rnd.Next(1, 121)}"; // Đã xóa :D2
            if (!usedSlots.Contains(slotId)) { xe.ViTriDo = slotId; usedSlots.Add(slotId); assigned = true; break; }
        }
        if (!assigned)
        {
            for (int i = 1; i <= 120; i++)
            {
                string slotId = $"{prefix}-{i}"; // Đã xóa :D2
                if (!usedSlots.Contains(slotId)) { xe.ViTriDo = slotId; usedSlots.Add(slotId); break; }
            }
        }
    }

    // 4. ĐÃ FIX: Lấy danh sách ĐỂ GỬI CHO JS SAU KHI ĐÃ CẤP VỊ TRÍ XONG
    var danhSachXeDangDau = xeDangTrongBai
        .Where(x => !string.IsNullOrEmpty(x.ViTriDo))
        .Select(x => new
        {
            ViTri = x.ViTriDo,
            Loai = x.LoaiDoiTuong ?? "Khách",
            BienSo = x.BienSoXe ?? "N/A",
            Ten = x.HoTen ?? "Khách vãng lai"
        })
        .ToList();

    // 5. Chuẩn bị bảng hiển thị
    var tableData = cleanModel.OrderByDescending(x => x.ThoiGian).ToList();
    if (filterStatus == "Đang đậu") tableData = xeDangTrongBai.OrderByDescending(x => x.ThoiGian).ToList();
    else if (filterStatus == "Đã ra") tableData = cleanModel.Where(x => x.Huong == "Đi Ra").OrderByDescending(x => x.ThoiGian).ToList();
}

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="~/css/smart-parking.css" />

<div class="container-fluid mt-2 animate__animated animate__fadeIn" id="main-container">

    <div class="d-flex justify-content-between align-items-center mb-3 bg-white p-3 rounded-2 shadow-sm border-start border-5 border-primary">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-p-circle-fill text-primary"></i> QUẢN LÝ BÃI XE THÔNG MINH</h4>
            <small class="text-muted fw-bold">ĐIỀU HÀNH BÃI ĐỖ VÀ GIÁM SÁT AN NINH TOÀN DIỆN</small>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <ul class="nav nav-pills custom-pills me-3" id="pills-tab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold px-4 rounded-1 shadow-sm" id="tab-sodo" onclick="switchTab('sodo')">
                        <i class="bi bi-grid-3x3-gap-fill"></i> SƠ ĐỒ VỊ TRÍ & LỊCH SỬ
                    </button>
                </li>
                <li class="nav-item ms-2" role="presentation">
                    <button class="nav-link fw-bold px-4 rounded-1 shadow-sm" id="tab-cctv" onclick="switchTab('cctv')">
                        <i class="bi bi-camera-video-fill"></i> GIÁM SÁT CHI TIẾT
                    </button>
                </li>
            </ul>

            @if (userRole == "Admin")
            {
                <div class="dropdown">
                    <button class="btn btn-success fw-bold shadow-sm rounded-1 px-3 dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-pencil-square"></i> Q.Trị Bãi Đỗ
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-2">
                        <li><a class="dropdown-item fw-bold text-primary py-2" href="#" onclick="openFloatingWindow('window-manage-camera')"><i class="bi bi-camera-video me-2"></i>Thêm Camera Giám Sát</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item fw-bold text-success py-2" href="#" onclick="openFloatingWindow('window-manage-parking')"><i class="bi bi-p-square me-2"></i>Thiết lập Ô Đỗ Xe (Tự động)</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item fw-bold text-danger py-2" href="#" onclick="resetAllData()"><i class="bi bi-arrow-clockwise me-2"></i>Khôi phục CSDL Gốc</a></li>
                    </ul>
                </div>
            }
        </div>
    </div>

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="content-sodo">

            <div class="card border-0 shadow-sm mb-3 bg-white rounded-2 animate__animated animate__fadeInDown">
                <div class="card-body d-flex justify-content-between align-items-center p-3 flex-wrap gap-3">
                    <div class="text-center px-4 border-end border-2 flex-fill">
                        <h6 class="fw-bold text-muted mb-1 text-uppercase">TỔNG BÃI XE</h6>
                        <h3 class="fw-bold text-primary mb-0 font-monospace" id="ui-total-slots">240</h3>
                    </div>
                    <div class="text-center px-4 border-end border-2 flex-fill">
                        <h6 class="fw-bold text-muted mb-1 text-uppercase">ĐANG TRỐNG</h6>
                        <h3 class="fw-bold text-success mb-0 font-monospace" id="ui-empty-slots">240</h3>
                    </div>
                    <div class="text-center px-4 border-end border-2 flex-fill">
                        <h6 class="fw-bold text-muted mb-1 text-uppercase">ĐANG ĐẬU</h6>
                        <h3 class="fw-bold text-danger mb-0 font-monospace" id="occupiedCount">0</h3>
                    </div>
                    <div class="text-center px-4 border-end border-2 flex-fill">
                        <h6 class="fw-bold text-muted mb-1 text-uppercase">ĐỖ SAI QUY ĐỊNH</h6>
                        <h3 class="fw-bold text-warning mb-0 font-monospace blink-text" id="violationCount">0</h3>
                    </div>
                    <div class="flex-grow-1 px-4 min-w-200">
                        <div class="d-flex justify-content-between mb-1">
                            <small class="fw-bold text-muted">Tỉ lệ lấp đầy</small>
                            <small class="fw-bold text-success"><i class="bi bi-check-circle-fill"></i> Đã Đồng Bộ</small>
                        </div>
                        <div class="progress rounded-pill" style="height: 12px;">
                            <div id="ui-progress-bar" class="progress-bar bg-success progress-bar-striped progress-bar-animated" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12">
                    <div class="card border-0 shadow-sm p-4 bg-dark blueprint-frame">
                        <div class="d-flex justify-content-between align-items-center mb-4 bg-black p-3 rounded-2 shadow-sm border border-secondary">
                            <h5 class="fw-bold text-info mb-0 text-uppercase">
                                <i class="bi bi-grid-3x3-gap"></i> SƠ ĐỒ VỊ TRÍ - TẦNG @currentTang (TRANG @currentPage)
                            </h5>
                            <div class="d-flex gap-3 small fw-bold">
                                <span class="text-warning"><i class="bi bi-star-fill"></i> Sếp/VIP</span>
                                <span class="text-info"><i class="bi bi-person-badge"></i> Khách</span>
                                <span class="text-secondary"><i class="bi bi-person-vcard"></i> Nhân Viên</span>
                            </div>
                            <div class="d-flex gap-2">
                                <div class="btn-group shadow-sm">
                                    <a href="@Url.Action("Index", new { tang = "B1", selectedDate = selectedDate, searchName = ViewBag.SearchName })"
                                       class="btn btn-sm @(currentTang == "B1" ? "btn-info text-dark" : "btn-outline-secondary text-light") fw-bold">Khu A (Khách & VIP)</a>
                                    <a href="@Url.Action("Index", new { tang = "B2", selectedDate = selectedDate, searchName = ViewBag.SearchName })"
                                       class="btn btn-sm @(currentTang == "B2" ? "btn-info text-dark" : "btn-outline-secondary text-light") fw-bold">Khu B (NV)</a>
                                </div>
                            </div>
                        </div>

                        <div id="dynamic-main-parking-grid" class="w-100 pb-3 custom-scrollbar" style="max-height: 600px; overflow-y: auto; overflow-x: hidden; padding-right: 10px;"></div>
                    </div>
                </div>

                <div class="col-12 mt-2">
                    <div class="card border-0 shadow-sm rounded-2">
                        <div class="card-header bg-white p-3 border-bottom">
                            <form method="get" class="row g-2 align-items-end">
                                <div class="col-md-2">
                                    <label class="small fw-bold text-muted mb-1"><i class="bi bi-calendar-date"></i> Ngày xem</label>
                                    <input type="date" name="selectedDate" value="@selectedDate" class="form-control form-control-sm shadow-none rounded-1" onchange="this.form.submit()">
                                </div>
                                <div class="col-md-4">
                                    <label class="small fw-bold text-muted mb-1"><i class="bi bi-search"></i> Tìm kiếm</label>
                                    <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control form-control-sm shadow-none rounded-1" placeholder="Tên hoặc biển số...">
                                </div>
                                <div class="col-md-2">
                                    <label class="small fw-bold text-muted mb-1"><i class="bi bi-filter"></i> Trạng thái</label>
                                    <select name="filterStatus" class="form-select form-select-sm shadow-none rounded-1" onchange="this.form.submit()">
                                        <option value="Tất cả" selected="@(ViewBag.FilterStatus == "Tất cả")">Tất cả xe</option>
                                        <option value="Đang đậu" selected="@(ViewBag.FilterStatus == "Đang đậu")">Đang đậu</option>
                                        <option value="Đã ra" selected="@(ViewBag.FilterStatus == "Đã ra")">Đã ra</option>
                                    </select>
                                </div>
                                <input type="hidden" name="tang" value="@currentTang" />
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-sm btn-primary w-100 shadow-sm fw-bold rounded-1">Lọc dữ liệu</button>
                                </div>
                                <div class="col-md-2 text-end">
                                    <h5 class="fw-bold mb-0 text-primary">LỊCH SỬ</h5>
                                </div>
                            </form>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive custom-scrollbar" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-hover align-middle mb-0 text-center custom-table">
                                    <thead class="table-light small fw-bold text-uppercase sticky-top">
                                        <tr><th class="ps-4 text-start">Thời gian</th><th class="text-start">Nhân viên</th><th>Loại Xe</th><th>Biển số</th><th>Vị trí</th><th class="pe-4 text-end">Trạng thái</th></tr>
                                    </thead>
                                    <tbody>
                                        @if (!tableData.Any())
                                        {
                                            <tr><td colspan="6" class="text-center py-4 text-muted">Không tìm thấy dữ liệu.</td></tr>
                                        }
                                        else
                                        {
                                            @foreach (var item in tableData)
                                            {
                                                <tr>
                                                    <td class="ps-4 text-start"><div class="fw-bold">@item.ThoiGian.ToString("HH:mm:ss")</div><small class="text-muted">@item.ThoiGian.ToString("dd/MM")</small></td>
                                                    <td class="text-start"><div class="d-flex align-items-center"><img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-avatar.png" : item.HinhAnh)" class="rounded-circle border shadow-sm me-3" style="width: 40px; height: 40px; object-fit: cover;" onerror="this.src='/images/no-avatar.png'"><div><div class="fw-bold text-dark text-capitalize">@item.HoTen</div><small class="text-primary fw-bold" style="font-size: 0.7rem;">CHỦ XE</small></div></div></td>
                                                    <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-2 py-1">🚗 Ô TÔ</span></td>
                                                    <td class="font-monospace fw-bold">@item.BienSoXe</td>
                                                    <td class="text-danger fw-bold">@(item.Huong == "Đi Ra" ? "---" : (item.ViTriDo ?? "---"))</td>
                                                    <td class="pe-4 text-end">
                                                        @if (item.Huong == "Đi Vào")
                                                        {
                                                            <span class="badge bg-success rounded-pill px-3 shadow-sm">Đang đậu</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-warning text-dark rounded-pill px-3 shadow-sm">Đã ra</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="slotDetailCard" class="card border-0 shadow-lg p-4 bg-white text-center d-none animate__animated animate__fadeInUp rounded-3" style="position: fixed; bottom: 30px; right: 30px; width: 320px; z-index: 1050;">
            <h6 class="fw-bold text-muted border-bottom pb-2 mb-3 text-uppercase">Thông Tin Vị Trí <span id="lblSlotId" class="text-primary fs-5"></span></h6>
            <div class="position-relative d-inline-block mb-3">
                <img id="slotImg" src="/images/no-avatar.png" class="rounded-circle shadow border border-3 border-primary" style="width: 130px; height: 130px; object-fit: cover;" onerror="this.src='/images/no-avatar.png'">
            </div>
            <h4 id="slotUser" class="fw-bold text-dark mb-1 text-capitalize"></h4>
            <div id="slotPlate" class="badge bg-primary fs-5 mb-3 px-3 py-2 shadow-sm font-monospace"></div>
            <button class="btn btn-sm btn-secondary w-100 rounded-1 mt-2 fw-bold" onclick="resetSlot()">Đóng</button>
        </div>
    </div>

    <div class="tab-pane fade d-none" id="content-cctv">
        <div class="card border-0 shadow-sm rounded-2 overflow-hidden bg-dark">
            <div class="card-header bg-black text-white d-flex justify-content-between align-items-center py-3 border-0">
                <div class="d-flex align-items-center gap-3">
                    <span class="fw-bold text-danger animate__animated animate__pulse animate__infinite"><i class="bi bi-record-circle-fill"></i> LIVE MONITORING</span>
                    <span class="text-white-50 small fw-bold d-none d-md-inline">| KÉO THẢ ĐỂ SẮP XẾP ƯU TIÊN</span>
                </div>
                <div class="btn-group shadow-sm d-none d-md-flex">
                    <button class="btn btn-sm btn-primary active" id="btn-layout-grid" onclick="changeCamLayout('grid')" title="Lưới Tiêu Chuẩn (5 Cam/Dòng)"><i class="bi bi-grid-3x3-gap-fill me-1"></i> Lưới 5 Ô</button>
                    <button class="btn btn-sm btn-dark border-secondary" id="btn-layout-focus" onclick="changeCamLayout('focus')" title="Tiêu Điểm (1 Lớn, Nhiều Nhỏ)"><i class="bi bi-layout-sidebar-inset me-1"></i> Tiêu Điểm</button>
                    <button class="btn btn-sm btn-dark border-secondary" id="btn-layout-list" onclick="changeCamLayout('list')" title="Danh Sách Dọc"><i class="bi bi-view-list me-1"></i> Xếp Dọc</button>
                    <button class="btn btn-sm btn-dark border-secondary" id="btn-layout-free" onclick="changeCamLayout('free')" title="Tự Do (Kéo góc chỉnh kích thước)"><i class="bi bi-arrows-move me-1"></i> Tự Do</button>
                </div>
            </div>
            <div class="card-body p-4 custom-scrollbar" style="background-color: #0a0a0a; height: calc(100vh - 200px); min-height: 650px; overflow-y: auto; overflow-x: hidden;">
                <div class="cctv-layout-wrapper cctv-layout-grid gap-3" id="main-camera-grid"></div>
            </div>
        </div>
    </div>

</div>

@if (userRole == "Admin")
{
    <div class="floating-window d-none shadow-lg animate__animated" id="window-manage-parking">
        <div class="resizer resizer-t"></div> <div class="resizer resizer-r"></div> <div class="resizer resizer-b"></div> <div class="resizer resizer-l"></div>
        <div class="resizer resizer-tl"></div> <div class="resizer resizer-tr"></div> <div class="resizer resizer-bl"></div> <div class="resizer resizer-br"></div>

        <div class="card-header bg-primary text-white p-3 border-0 d-flex justify-content-between align-items-center floating-header" id="header-manage-parking">
            <div><h6 class="fw-bold mb-0 text-uppercase"><i class="bi bi-p-square-fill me-2"></i>THIẾT LẬP VỊ TRÍ ĐỖ XE TỰ ĐỘNG</h6></div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light rounded-1 border-0" onclick="toggleMaximize('window-manage-parking')"><i class="bi bi-arrows-fullscreen"></i></button>
                <button class="btn btn-sm btn-danger rounded-1 border-0" onclick="closeFloatingWindow('window-manage-parking')"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="card-body p-4 bg-card-custom" style="overflow-y: auto; flex: 1;">
            <div class="p-3 rounded-2" style="background-color: rgba(13, 110, 253, 0.05); border: 1px dashed rgba(13, 110, 253, 0.3);">
                <div class="mb-3 text-center">
                    <h6 class="fw-bold text-primary">PHÂN LOẠI ĐỐI TƯỢNG ƯU TIÊN</h6>
                    <p class="text-muted small mb-0">Hệ thống sẽ tự gán Tầng và ID đồng bộ CSDL.</p>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-4"><input type="radio" class="btn-check" name="parkType" id="typeSep" value="Sep" onchange="autoConfigParking()"><label class="btn btn-outline-warning w-100 p-2 rounded-2 fw-bold shadow-sm" for="typeSep"><i class="bi bi-star-fill fs-4 d-block"></i> VIP/SẾP</label></div>
                    <div class="col-4"><input type="radio" class="btn-check" name="parkType" id="typeKhach" value="Khach" onchange="autoConfigParking()" checked><label class="btn btn-outline-info w-100 p-2 rounded-2 fw-bold shadow-sm" for="typeKhach"><i class="bi bi-person-badge fs-4 d-block"></i> KHÁCH</label></div>
                    <div class="col-4"><input type="radio" class="btn-check" name="parkType" id="typeNV" value="NhanVien" onchange="autoConfigParking()"><label class="btn btn-outline-secondary w-100 p-2 rounded-2 fw-bold shadow-sm" for="typeNV"><i class="bi bi-person-vcard fs-4 d-block"></i> NHÂN VIÊN</label></div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">Khu vực (Bị Khóa Cứng)</label>
                        <div class="input-group input-group-sm shadow-sm">
                            <span class="input-group-text bg-white rounded-start-1"><i class="bi bi-geo-alt-fill text-primary"></i></span>
                            <input type="text" class="form-control fw-bold rounded-end-1" id="autoZone" readonly style="background-color: #e9ecef;">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold text-muted small">Mã Vị Trí (Tự động cấp)</label>
                        <div class="input-group input-group-sm shadow-sm">
                            <span class="input-group-text bg-white rounded-start-1" id="autoIcon"><i class="bi bi-person-badge text-info"></i></span>
                            <input type="text" class="form-control fw-bold text-info font-monospace rounded-end-1" id="autoSlotId" readonly style="background-color: #e0f7fa;">
                        </div>
                    </div>
                </div>
                <div class="text-center mt-3">
                    <button class="btn btn-primary btn-sm rounded-1 px-4 fw-bold shadow" onclick="submitCreateParking()"><i class="bi bi-magic me-2"></i> LƯU VÀ ĐỒNG BỘ</button>
                </div>
            </div>
        </div>
    </div>

    <div class="floating-window d-none shadow-lg animate__animated" id="window-manage-camera">
        <div class="resizer resizer-t"></div> <div class="resizer resizer-r"></div> <div class="resizer resizer-b"></div> <div class="resizer resizer-l"></div>
        <div class="resizer resizer-tl"></div> <div class="resizer resizer-tr"></div> <div class="resizer resizer-bl"></div> <div class="resizer resizer-br"></div>

        <div class="card-header bg-dark text-white p-3 border-0 d-flex justify-content-between align-items-center floating-header" id="header-manage-camera">
            <div><h6 class="fw-bold mb-0 text-uppercase"><i class="bi bi-camera-video-fill text-info me-2"></i>QUẢN TRỊ HỆ THỐNG CAMERA</h6></div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-light rounded-1 border-0" onclick="toggleMaximize('window-manage-camera')"><i class="bi bi-arrows-fullscreen"></i></button>
                <button class="btn btn-sm btn-danger rounded-1 border-0" onclick="closeFloatingWindow('window-manage-camera')"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div class="card-body p-3 bg-card-custom d-flex flex-column" style="overflow: hidden; flex: 1;">
            <div class="d-flex justify-content-between mb-3 align-items-center flex-wrap gap-2">
                <div class="d-flex gap-2 align-items-center">
                    <label class="fw-bold text-muted text-nowrap small"><i class="bi bi-funnel-fill"></i> Lọc Tầng:</label>
                    <select id="adminCamFilter" class="form-select form-select-sm shadow-sm border-secondary fw-bold" onchange="syncCameraTable()" style="width: 150px;">
                        <option value="all">Hiển thị Tất Cả</option>
                        <option value="basement_A">Tầng Hầm B1</option>
                        <option value="basement_B">Tầng Hầm B2</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-info btn-sm fw-bold rounded-1 shadow-sm text-white" onclick="addNewCameraRow()"><i class="bi bi-plus-lg"></i> Thêm Cam Nhanh</button>
                </div>
            </div>

            <div class="table-responsive rounded-2 shadow-sm border custom-scrollbar" style="flex: 1; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 text-center bg-white" id="cameraAdminTable">
                    <thead class="table-dark text-uppercase small sticky-top">
                        <tr><th style="width: 80px;">Sắp xếp</th><th class="text-start">Tên Camera (Click sửa)</th><th>Khu vực</th><th>Xóa</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        function openFloatingWindow(winId) {
            const win = document.getElementById(winId);
            win.classList.remove('d-none', 'animate__zoomOut');
            win.classList.add('animate__zoomIn');
            win.style.transform = "translate(-50%, -50%)";
            win.style.top = "50%"; win.style.left = "50%";

            if(winId === 'window-manage-camera') { document.getElementById('adminCamFilter').value = window.APP_CONFIG.currentFloor; syncCameraTable(); }
            if(winId === 'window-manage-parking') autoConfigParking();

            makeDraggableWindow(win);
        }

        function closeFloatingWindow(winId) {
            const win = document.getElementById(winId);
            win.classList.remove('animate__zoomIn', 'floating-maximized');
            win.classList.add('animate__zoomOut');
            setTimeout(() => { win.classList.add('d-none'); }, 300);
        }

        function toggleMaximize(winId) {
            const win = document.getElementById(winId);
            if (win.classList.contains('floating-maximized')) { win.classList.remove('floating-maximized'); }
            else { win.classList.add('floating-maximized'); win.style.top = "0"; win.style.left = "0"; win.style.transform = "none"; }
        }

        function makeDraggableWindow(win) {
            const header = win.querySelector('.floating-header');
            const resizers = win.querySelectorAll('.resizer');
            let isResizing = false; let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;

            header.onmousedown = function(e) {
                if (e.target.closest('button') || win.classList.contains('floating-maximized')) return;
                e.preventDefault(); pos3 = e.clientX; pos4 = e.clientY;
                document.onmouseup = closeDragElement; document.onmousemove = elementDrag;
            };
            function elementDrag(e) {
                e.preventDefault(); pos1 = pos3 - e.clientX; pos2 = pos4 - e.clientY; pos3 = e.clientX; pos4 = e.clientY;
                if (win.style.transform.includes('translate')) {
                    const rect = win.getBoundingClientRect(); win.style.transform = "none"; win.style.top = rect.top + "px"; win.style.left = rect.left + "px";
                }
                win.style.top = (win.offsetTop - pos2) + "px"; win.style.left = (win.offsetLeft - pos1) + "px";
            }
            function closeDragElement() { document.onmouseup = null; document.onmousemove = null; }

            let original_width = 0, original_height = 0, original_x = 0, original_y = 0, original_mouse_x = 0, original_mouse_y = 0;
            for (let i = 0; i < resizers.length; i++) {
                const currentResizer = resizers[i];
                currentResizer.onmousedown = function(e) {
                    e.preventDefault(); isResizing = true;
                    original_width = parseFloat(getComputedStyle(win, null).getPropertyValue('width').replace('px', ''));
                    original_height = parseFloat(getComputedStyle(win, null).getPropertyValue('height').replace('px', ''));
                    original_x = win.getBoundingClientRect().left; original_y = win.getBoundingClientRect().top;
                    original_mouse_x = e.pageX; original_mouse_y = e.pageY;
                    if (win.style.transform.includes('translate')) { win.style.transform = "none"; win.style.left = original_x + "px"; win.style.top = original_y + "px"; }
                    window.addEventListener('mousemove', resize); window.addEventListener('mouseup', stopResize);
                };
                function resize(e) {
                    if (currentResizer.classList.contains('resizer-br')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px'; }
                    else if (currentResizer.classList.contains('resizer-bl')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px'; }
                    else if (currentResizer.classList.contains('resizer-tr')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                    else if (currentResizer.classList.contains('resizer-tl')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                    else if (currentResizer.classList.contains('resizer-r')) { win.style.width = original_width + (e.pageX - original_mouse_x)  + 'px'; }
                    else if (currentResizer.classList.contains('resizer-l')) { win.style.width = original_width - (e.pageX - original_mouse_x)  + 'px'; win.style.left = original_x + (e.pageX - original_mouse_x) + 'px'; }
                    else if (currentResizer.classList.contains('resizer-b')) { win.style.height = original_height + (e.pageY - original_mouse_y)  + 'px'; }
                    else if (currentResizer.classList.contains('resizer-t')) { win.style.height = original_height - (e.pageY - original_mouse_y)  + 'px'; win.style.top = original_y + (e.pageY - original_mouse_y) + 'px'; }
                }
                function stopResize() { window.removeEventListener('mousemove', resize); isResizing = false; }
            }
        }

        function autoConfigParking() {
            const type = document.querySelector('input[name="parkType"]:checked').value;
            const zoneInput = document.getElementById('autoZone');
            const idInput = document.getElementById('autoSlotId');
            if (type === 'Sep') { zoneInput.value = 'Tầng Hầm B1'; idInput.value = 'A-' + (dbCounters.vip + 1).toString().padStart(2, '0'); idInput.className = 'form-control fw-bold text-warning font-monospace fs-5 rounded-end-1'; }
            else if (type === 'Khach') { zoneInput.value = 'Tầng Hầm B1'; idInput.value = 'A-' + (dbCounters.vip + dbCounters.guest + 1).toString().padStart(2, '0'); idInput.className = 'form-control fw-bold text-info font-monospace fs-5 rounded-end-1'; }
            else { zoneInput.value = 'Tầng Hầm B2'; idInput.value = 'B-' + (dbCounters.emp + 1).toString().padStart(2, '0'); idInput.className = 'form-control fw-bold text-secondary font-monospace fs-5 rounded-end-1'; }
        }

        function submitCreateParking() {
            const type = document.querySelector('input[name="parkType"]:checked').value;
            const slotId = document.getElementById('autoSlotId').value;
            let floor = type === 'NhanVien' ? 'basement_B' : 'basement_A';
            let pCode = type === 'NhanVien' ? 'B' : 'A';

            let processCreation = () => {
                closeFloatingWindow('window-manage-parking');
                cameraList.push({ id: slotId, name: `Cam Ô ${slotId}`, floor: floor });

                if (pCode === 'A') { slotOrderA.push(slotId); localStorage.setItem('chkIn_slotOrder_A', JSON.stringify(slotOrderA));}
                else { slotOrderB.push(slotId); localStorage.setItem('chkIn_slotOrder_B', JSON.stringify(slotOrderB));}

                saveGlobalData();
                Swal.fire('Thành công!', `Đã tạo vị trí <b>${slotId}</b>.`, 'success').then(() => {
                    renderMainMap(); if(!document.getElementById('view-camera').classList.contains('d-none')) renderCameras();
                });
            };

            if (type === 'Sep') {
                Swal.fire({ title: 'Đang dời chỗ...', html: 'Hệ thống đang tự động dời các xe Khách xuống 1 vị trí.', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                setTimeout(() => { dbCounters.vip++; dbCounters.guest++; processCreation(); }, 1500);
            } else if (type === 'Khach') { dbCounters.guest++; processCreation(); }
            else { dbCounters.emp++; processCreation(); }
        }

        function syncCameraTable() {
            if(cameraList.length === 0) initCameraData();
            const tbody = document.querySelector('#cameraAdminTable tbody');
            tbody.innerHTML = '';
            const filterVal = document.getElementById('adminCamFilter').value;

            cameraList.forEach((cam) => {
                if(filterVal === 'all' || cam.floor === filterVal) {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>
                            <div class="btn-group btn-group-sm shadow-sm">
                                <button class="btn btn-light border text-muted" onclick="moveRowUp(this)"><i class="bi bi-chevron-up"></i></button>
                                <button class="btn btn-light border text-muted" onclick="moveRowDown(this)"><i class="bi bi-chevron-down"></i></button>
                            </div>
                        </td>
                        <td class="text-start fw-bold">
                            <input type="text" class="form-control form-control-sm border-1 border-light bg-transparent fw-bold text-primary shadow-none" value="${cam.name}" onchange="renameCameraInDB(this, '${cam.id}')">
                        </td>
                        <td><span class="badge bg-secondary rounded-1">${cam.floor.replace('basement_A', 'Hầm A').replace('basement_B', 'Hầm B').replace('ground', 'Trệt').replace('floor1', 'Tầng 1').replace('floor2', 'Tầng 2').replace('floor3', 'Tầng 3')}</span></td>
                        <td><button class="btn btn-sm btn-outline-danger rounded-1" onclick="deleteCameraFromTable(this, '${cam.id}')"><i class="bi bi-trash3-fill"></i></button></td>
                    `;
                    tbody.appendChild(tr);
                }
            });
        }

        function renameCameraInDB(inputEl, id) {
            const cam = cameraList.find(c => c.id === id);
            if(cam) cam.name = inputEl.value;
            saveGlobalData();
            const liveCamText = document.querySelector(`.dynamic-main-cam[data-id="${id}"] .cam-name-text`);
            if(liveCamText) liveCamText.innerText = inputEl.value;
        }

        function deleteCameraFromTable(btn, id) {
            const row = btn.closest('tr');
            row.classList.add('animate__animated', 'animate__fadeOutRight');
            cameraList = cameraList.filter(c => c.id !== id);
            saveGlobalData();
            setTimeout(() => {
                row.remove();
                const liveCam = document.querySelector(`.dynamic-main-cam[data-id="${id}"]`);
                if(liveCam) liveCam.remove();
            }, 500);
        }

        function addNewCameraRow() {
            Swal.fire({
                title: 'Nhập tên Camera Mới', input: 'text', inputPlaceholder: 'VD: Cam Lối Vào B', showCancelButton: true, confirmButtonText: 'Lưu Camera'
            }).then((result) => {
                if(result.isConfirmed && result.value) {
                    const name = result.value; const id = 'CUSTOM-' + Math.floor(Math.random()*1000);
                    const floor = window.APP_CONFIG.currentFloor;
                    cameraList.unshift({ id: id, name: name, floor: floor });
                    saveGlobalData(); syncCameraTable(); if(!document.getElementById('view-camera').classList.contains('d-none')) renderCameras();
                    Swal.fire('Thành công', 'Đã thêm Camera vào hệ thống.', 'success');
                }
            });
        }

        function moveRowUp(btn) { const row = btn.closest('tr'); const prev = row.previousElementSibling; if (prev) { row.parentNode.insertBefore(row, prev); saveGlobalData(); } }
        function moveRowDown(btn) { const row = btn.closest('tr'); const next = row.nextElementSibling; if (next) { row.parentNode.insertBefore(next, row); saveGlobalData(); } }

        function resetAllData() {
            Swal.fire({
                title: 'Khôi phục CSDL Gốc?', text: "Hành động này sẽ xóa toàn bộ cài đặt ô đỗ xe và Camera đã thêm. Về trạng thái 240 chỗ mặc định. Bạn chắc chắn?",
                icon: 'warning', showCancelButton: true, confirmButtonText: 'KHÔI PHỤC NGAY', confirmButtonColor: '#dc3545'
            }).then((result) => {
                if(result.isConfirmed) {
                    localStorage.removeItem('chkIn_dbCounters');
                    localStorage.removeItem('chkIn_cameraList');
                    localStorage.removeItem('chkIn_deletedSlots');
                    localStorage.removeItem('chkIn_slotOrder_A');
                    localStorage.removeItem('chkIn_slotOrder_B');
                    localStorage.removeItem('chkIn_cameraOrder');
                    location.reload();
                }
            });
        }
    </script>
}

<script>
    let rawDataMap = @Html.Raw(Json.Serialize(danhSachXeDangDau));
    let parkedCarsMap = {};
    if (rawDataMap) {
        rawDataMap.forEach(car => {
            if(car.viTri) {
                let slotNormalized = car.viTri.replace(/\s+/g, '').toUpperCase();
                parkedCarsMap[slotNormalized] = { role: car.loai, plate: car.bienSo, name: car.ten };
            }
        });
    }

    // Truyền cấu hình cho file js dùng chung
    window.APP_CONFIG = {
        isAdmin: '@userRole' === 'Admin',
        currentFloor: '@currentTang' === 'B1' ? 'basement_A' : 'basement_B',
        prefixCode: '@currentTang' === 'B1' ? 'A' : 'B',
        parkedCars: parkedCarsMap
    };

    // ĐÃ FIX: BƠM DỮ LIỆU LOCALSTORAGE XUỐNG BẢNG LỊCH SỬ NGAY KHI TẢI TRANG
    document.addEventListener("DOMContentLoaded", () => {
        let dynamicCars = JSON.parse(localStorage.getItem('chkIn_parkedCars')) || {};
        let tbody = document.querySelector('.custom-table tbody');

        let filterSelect = document.querySelector('select[name="filterStatus"]');
        let filterStatus = filterSelect ? filterSelect.value : 'Tất cả';

        if (Object.keys(dynamicCars).length > 0 && (filterStatus === 'Tất cả' || filterStatus === 'Đang đậu')) {
            let emptyMsg = tbody.querySelector('td[colspan="6"]');
            if (emptyMsg) emptyMsg.parentElement.remove();

            for (let slotId in dynamicCars) {
                let car = dynamicCars[slotId];
                let timeStr = car.time || new Date().toLocaleTimeString('vi-VN', { hour12: false });

                let tr = document.createElement('tr');
                tr.className = "animate__animated animate__fadeIn bg-success bg-opacity-10";
                tr.innerHTML = `
                    <td class="ps-4 text-start">
                        <div class="fw-bold">${timeStr}</div>
                        <small class="text-success fw-bold"><i class="bi bi-record-circle-fill pulse-animation"></i> Live</small>
                    </td>
                    <td class="text-start">
                        <div class="d-flex align-items-center">
                            <img src="/images/no-avatar.png" class="rounded-circle border shadow-sm me-3" style="width: 40px; height: 40px; object-fit: cover;">
                            <div>
                                <div class="fw-bold text-dark text-capitalize">${car.name}</div>
                                <small class="text-primary fw-bold text-uppercase" style="font-size: 0.7rem;">${car.role}</small>
                            </div>
                        </div>
                    </td>
                    <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-2 py-1">🚗 Ô TÔ</span></td>
                    <td class="font-monospace fw-bold">${car.plate}</td>
                    <td class="text-danger fw-bold">${slotId}</td>
                    <td class="pe-4 text-end"><span class="badge bg-success rounded-pill px-3 shadow-sm">Đang đậu</span></td>
                `;
                tbody.prepend(tr);
            }
        }
    });
</script>

<script src="~/js/smart-parking.js"></script>