@model Quan_Ly_xe_Ra_Vao.Models.NhanVien

@{
    ViewData["Title"] = "Thêm Nhân Viên Mới";
}

<style>
    .square-box, .form-control, .btn, .card {
        border-radius: 0 !important;
    }

        .form-control:focus {
            border-color: #000;
            box-shadow: none;
        }
</style>

<div class="container-fluid mt-5">
    <div class="card square-box border-dark shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-header bg-dark text-white square-box py-3">
            <h5 class="mb-0 fw-bold text-uppercase"><i class="bi bi-person-plus"></i> KHỞI TẠO HỒ SƠ NHÂN SỰ</h5>
        </div>

        <div class="card-body p-4 bg-light">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Mã Nhân Viên (*)</label>
                    <input asp-for="MaNV" class="form-control form-control-lg border-dark" placeholder="VD: NV-099" required />
                </div>

                <div class="mb-3">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Họ và Tên (*)</label>
                    <input asp-for="HoTen" class="form-control form-control-lg border-dark" placeholder="Nhập tên đầy đủ..." required />
                </div>

                <div class="mb-4">
                    <label class="fw-bold text-muted small text-uppercase mb-1">Chức vụ / Phòng ban</label>
                    <input asp-for="ChucVu" class="form-control form-control-lg border-dark" placeholder="VD: Kế toán, IT, Bảo vệ..." />
                </div>

                <div class="d-flex justify-content-between mt-5">
                    <a asp-action="Index" class="btn btn-outline-dark square-box fw-bold px-4">HỦY BỎ</a>
                    <button type="submit" class="btn btn-primary square-box fw-bold px-4">
                        <i class="bi bi-arrow-right-circle"></i> TẠO & LẤY SINH TRẮC HỌC
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>