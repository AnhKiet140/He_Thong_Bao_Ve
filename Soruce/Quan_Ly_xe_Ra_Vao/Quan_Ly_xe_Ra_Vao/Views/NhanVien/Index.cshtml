@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.NhanVien>

@{
    ViewData["Title"] = "Quản Lý Sinh Trắc Học";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-3 animate__animated animate__fadeIn">
    <div class="card shadow-sm border-0 rounded-4 bg-card-custom overflow-hidden">

        <div class="card-header bg-transparent border-bottom p-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <h4 class="fw-bold text-primary mb-0 d-flex align-items-center">
                <i class="bi bi-fingerprint me-2 fs-3"></i> DANH SÁCH NHÂN SỰ
            </h4>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <form id="filterForm" asp-action="Index" method="get" class="d-flex gap-2 mb-0 align-items-center">
                    <select name="chucVu" class="form-select border-secondary shadow-sm rounded-3 bg-transparent text-body" style="width: 200px;" onchange="document.getElementById('filterForm').submit();">
                        <option value="">-- Tất cả chức vụ --</option>
                        <option value="Khach" selected="@(ViewData["CurrentChucVu"]?.ToString() == "Khach")">Khách vãng lai</option>
                        @if (ViewBag.ListChucVu != null)
                        {
                            foreach (var cv in ViewBag.ListChucVu)
                            {
                                if (!string.IsNullOrEmpty(cv))
                                {
                                    <option value="@cv" selected="@(ViewData["CurrentChucVu"]?.ToString() == cv)">@cv</option>
                                }
                            }
                        }
                    </select>

                    <div class="input-group shadow-sm rounded-3 input-custom-group">
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 bg-transparent text-body shadow-none" placeholder="Tìm Tên, Mã NV..." style="width: 220px;">
                        <button type="submit" class="btn btn-dark fw-bold px-3"><i class="bi bi-search me-1"></i> Lọc</button>
                    </div>

                    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-3 btn-refresh-custom ms-1" title="Làm mới"><i class="bi bi-arrow-clockwise"></i></a>

                    <button type="submit" asp-action="ExportExcel" formmethod="get" class="btn btn-success fw-bold shadow-sm rounded-3 px-3 ms-2 text-nowrap d-flex align-items-center">
                        <i class="bi bi-file-earmark-excel-fill me-2"></i> Xuất Excel
                    </button>
                </form>

                <a asp-action="Create" class="btn btn-primary fw-bold px-4 shadow-sm rounded-3 ms-xl-2 text-nowrap">
                    <i class="bi bi-person-plus-fill"></i> THÊM MỚI
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 650px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 custom-table">
                    <thead class="table-light text-muted text-uppercase small fw-bold sticky-top custom-thead">
                        <tr>
                            <th class="ps-4">Mã NV/Khách</th>
                            <th>Họ Tên</th>
                            <th>Chức Vụ / Ghi Chú</th>
                            <th class="text-center">Dữ Liệu Khuôn Mặt</th>
                            <th class="text-center">Dữ Liệu Vân Tay</th>
                            <th class="text-end pe-4">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody class="text-body">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var nv in Model)
                            {
                                <tr class="animate__animated animate__fadeIn">
                                    <td class="ps-4 fw-bold text-muted font-monospace">@nv.MaNV</td>
                                    <td class="fw-bold text-body text-capitalize">@nv.HoTen</td>
                                    <td>
                                        <div class="text-primary fw-bold">@nv.ChucVu</div>
                                        @if (!string.IsNullOrEmpty(nv.BienSoXe))
                                        {
                                            <small class="text-muted"><i class="bi bi-car-front"></i> Xe: @nv.BienSoXe</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(nv.FaceDataPath) && nv.FaceDataPath != "chua_co_anh.jpg" && nv.FaceDataPath != "/images/no-avatar.png")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-check-circle"></i> Đã cập nhật</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-x-circle"></i> Chưa có</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (nv.HasFingerprint)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-fingerprint"></i> Đã nạp</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-3 py-2 shadow-sm"><i class="bi bi-dash-circle"></i> Trống</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm rounded-3">
                                            <a asp-action="Details" asp-route-id="@nv.Id" class="btn btn-sm btn-outline-info" title="Xem hồ sơ">
                                                <i class="bi bi-person-vcard"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@nv.Id" class="btn btn-sm btn-outline-primary" title="Cập nhật">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a href="javascript:void(0)" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="confirmDelete('@nv.Id', '@nv.HoTen')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <div class="py-4">
                                        <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                                        <h5 class="fw-bold text-body">Chưa có dữ liệu nhân sự / khách vãng lai.</h5>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS CHUNG (Light Mode) */
    .bg-card-custom {
        background-color: #ffffff;
    }

    .input-custom-group {
        background-color: #ffffff;
        border: 1px solid #dee2e6;
    }

    .btn-refresh-custom {
        background-color: #ffffff;
        color: #212529;
        border: 1px solid #dee2e6;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
        border-left: 4px solid transparent;
    }

        .custom-table tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.03);
            border-left-color: #0d6efd;
        }

    .custom-table td {
        padding: 15px 10px;
        border-bottom: 1px solid #f1f3f5;
    }

    .sticky-top {
        top: 0;
        z-index: 10;
    }

    .font-monospace {
        letter-spacing: 1px;
    }

    /* =========================================
           CSS TƯƠNG THÍCH DARK MODE ĐỒNG BỘ
        ========================================= */
    [data-bs-theme="dark"] .bg-card-custom {
        background-color: #1e1e1e !important;
        border-color: #333 !important;
    }

    [data-bs-theme="dark"] .text-body {
        color: #e0e0e0 !important;
    }

    [data-bs-theme="dark"] .input-custom-group {
        background-color: #2c2c2c !important;
        border-color: #444 !important;
    }

    [data-bs-theme="dark"] .form-control::placeholder {
        color: #888 !important;
    }

    [data-bs-theme="dark"] .form-select option {
        background-color: #2c2c2c;
        color: #e0e0e0;
    }

    [data-bs-theme="dark"] .btn-refresh-custom {
        background-color: transparent !important;
        color: #e0e0e0 !important;
        border-color: #444 !important;
    }

        [data-bs-theme="dark"] .btn-refresh-custom:hover {
            background-color: #2c2c2c !important;
        }

    [data-bs-theme="dark"] .custom-table {
        color: #e0e0e0;
    }

    [data-bs-theme="dark"] .custom-thead th {
        background-color: #2c2c2c !important;
        color: #ccc !important;
        border-bottom: 2px solid #444 !important;
    }

    [data-bs-theme="dark"] .custom-table td {
        border-bottom: 1px solid #333 !important;
    }

    [data-bs-theme="dark"] .custom-table tbody tr:hover {
        background-color: rgba(255,255,255,0.05);
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1. HIỂN THỊ THÔNG BÁO THÀNH CÔNG TỪ CONTROLLER
    document.addEventListener("DOMContentLoaded", function() {
        var successMsg = '@Html.Raw(TempData["Success"])';
        if (successMsg !== "") {
            Swal.fire({
                title: 'Thành công!',
                text: successMsg,
                icon: 'success',
                timer: 2500,
                showConfirmButton: false,
                toast: true,
                position: 'top-end',
                background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#000'
            });
        }
    });

    // 2. HÀM XÁC NHẬN XÓA CHUYÊN NGHIỆP
    function confirmDelete(id, tenNV) {
        Swal.fire({
            title: 'XÓA HỒ SƠ?',
            html: "Bạn có chắc chắn muốn xóa nhân sự <b>" + tenNV + "</b>?<br/>Toàn bộ dữ liệu khuôn mặt và vân tay sẽ bị mất vĩnh viễn!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Vâng, Xóa Ngay!',
            cancelButtonText: 'Hủy Bỏ',
            background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
            color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#000'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Đang xóa dữ liệu...',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading() },
                    background: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#1e1e1e' : '#fff',
                    color: document.documentElement.getAttribute('data-bs-theme') === 'dark' ? '#fff' : '#000'
                });
                // CHÚ Ý: Đường dẫn gọi về action Delete (nếu bạn dùng phương thức POST, cần dùng form ẩn thay vì href)
                window.location.href = '/NhanVien/Delete/' + id;
            }
        });
    }
</script>