@model IEnumerable<Quan_Ly_xe_Ra_Vao.Models.NhanVien>

@{
    ViewData["Title"] = "Quản Lý Sinh Trắc Học";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-3 animate__animated animate__fadeIn">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white border-bottom p-4 d-flex flex-wrap justify-content-between align-items-center gap-3">
            <h4 class="fw-bold text-primary mb-0"><i class="bi bi-fingerprint me-2"></i> DANH SÁCH NHÂN SỰ</h4>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <form asp-action="Index" method="get" class="d-flex gap-2 mb-0">
                    <select name="searchChucVu" class="form-select border-secondary shadow-sm rounded-3" style="width: 200px;">
                        <option value="">-- Tất cả chức vụ --</option>
                        <option value="Khach" selected="@(ViewData["CurrentChucVu"]?.ToString() == "Khach")">Khách vãng lai</option>
                        @if (ViewBag.ListChucVu != null)
                        {
                            foreach (var cv in ViewBag.ListChucVu)
                            {
                                if (!string.IsNullOrEmpty(cv))
                                {
                                    <option value="@cv" selected="@(ViewData["CurrentChucVu"]?.ToString() == cv)">@cv</option>
                                }
                            }
                        }
                    </select>

                    <div class="input-group shadow-sm rounded-3">
                        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-secondary" placeholder="Tìm Tên, Mã NV..." style="width: 220px;">
                        <button type="submit" class="btn btn-dark fw-bold"><i class="bi bi-search"></i> Lọc</button>
                    </div>

                    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-3" title="Làm mới"><i class="bi bi-arrow-clockwise"></i></a>
                </form>

                <a asp-action="Create" class="btn btn-primary fw-bold px-4 shadow-sm rounded-3 ms-xl-2">
                    <i class="bi bi-person-plus-fill"></i> THÊM MỚI
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-table">
                    <thead class="table-light text-muted text-uppercase small fw-bold">
                        <tr>
                            <th class="ps-4">Mã NV/Khách</th>
                            <th>Họ Tên</th>
                            <th>Chức Vụ / Ghi Chú</th>
                            <th class="text-center">Dữ Liệu Khuôn Mặt</th>
                            <th class="text-center">Dữ Liệu Vân Tay</th>
                            <th class="text-end pe-4">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var nv in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted font-monospace">@nv.MaNV</td>
                                    <td class="text-dark fw-bold">@nv.HoTen</td>
                                    <td class="text-secondary">@nv.ChucVu</td>

                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(nv.FaceDataPath) && nv.FaceDataPath != "chua_co_anh.jpg" && nv.FaceDataPath != "/images/no-avatar.png")
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2"><i class="bi bi-check-circle"></i> Đã cập nhật</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2"><i class="bi bi-x-circle"></i> Chưa có</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (nv.HasFingerprint)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2"><i class="bi bi-check-circle"></i> Đã nạp</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary rounded-pill px-3 py-2"><i class="bi bi-dash-circle"></i> Trống</span>
                                        }
                                    </td>

                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm rounded-3">
                                            <a asp-action="Details" asp-route-id="@nv.Id" class="btn btn-sm btn-outline-info" title="Xem hồ sơ">
                                                <i class="bi bi-person-vcard"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@nv.Id" class="btn btn-sm btn-outline-primary" title="Cập nhật">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a href="javascript:void(0)" class="btn btn-sm btn-outline-danger" title="Xóa" onclick="confirmDelete('@nv.Id', '@nv.HoTen')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Chưa có dữ liệu nhân sự / khách vãng lai.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
    }

        .custom-table tbody tr:hover {
            background-color: #f8f9fa;
            transform: translateY(-1px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
        }

    .custom-table td {
        padding: 15px 10px;
        border-bottom: 1px solid #f1f3f5;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1. HIỂN THỊ THÔNG BÁO THÀNH CÔNG TỪ CONTROLLER
    document.addEventListener("DOMContentLoaded", function() {
        var successMsg = '@Html.Raw(TempData["Success"])';
        if (successMsg !== "") {
            Swal.fire({
                title: 'Thành công!',
                text: successMsg,
                icon: 'success',
                timer: 2500,
                showConfirmButton: false,
                toast: true,
                position: 'top-end' // Hiển thị góc trên bên phải cho đỡ che màn hình
            });
        }
    });

    // 2. HÀM XÁC NHẬN XÓA CHUYÊN NGHIỆP
    function confirmDelete(id, tenNV) {
        Swal.fire({
            title: 'XÓA HỒ SƠ?',
            html: "Bạn có chắc chắn muốn xóa nhân sự <b>" + tenNV + "</b>?<br/>Toàn bộ dữ liệu khuôn mặt và vân tay sẽ bị mất vĩnh viễn!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Vâng, Xóa Ngay!',
            cancelButtonText: 'Hủy Bỏ'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire({ title: 'Đang xóa dữ liệu...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                window.location.href = '/NhanVien/Delete/' + id;
            }
        });
    }
</script>