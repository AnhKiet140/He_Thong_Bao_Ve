@model Quan_Ly_xe_Ra_Vao.Models.NhanVien

@{
    ViewData["Title"] = "Cập Nhật Hồ Sơ Sinh Trắc Học";
    // Biến kiểm tra xem nhân viên đã có ảnh hay chưa
    bool hasFaceId = !string.IsNullOrEmpty(Model.FaceDataPath) && Model.FaceDataPath != "chua_co_anh.jpg" && Model.FaceDataPath != "/images/no-avatar.png";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<div class="container-fluid mt-3 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
        <h4 class="fw-bold text-primary mb-0"><i class="bi bi-person-gear me-2"></i> CẬP NHẬT HỒ SƠ & SINH TRẮC</h4>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm"><i class="bi bi-arrow-left"></i> Quay lại danh sách</a>
    </div>

    <form id="formEditNhanVien" asp-action="Edit" method="post" class="row g-3">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FaceDataPath" id="FaceDataInput" />
        <div class="d-none"><input class="form-check-input" type="checkbox" asp-for="HasFingerprint" id="HasFingerprint"></div>

        <div class="col-lg-4 d-flex flex-column gap-3">
            <div class="card border-0 shadow-sm rounded-3 flex-grow-1">
                <div class="card-header bg-dark text-white fw-bold py-2 text-center text-uppercase small">
                    <i class="bi bi-camera-fill text-info"></i> Ảnh chân dung (Face ID)
                </div>
                <div class="card-body p-3 d-flex flex-column align-items-center justify-content-center bg-light">
                    
                    <div class="position-relative bg-dark rounded-3 overflow-hidden shadow-sm w-100 mb-3 d-flex align-items-center justify-content-center" style="height: 260px;">
                        
                        <img id="capturedPhoto" src="@(hasFaceId ? Model.FaceDataPath : "/images/no-avatar.png")" class="w-100 h-100 position-absolute top-0 start-0 @(hasFaceId ? "" : "opacity-50")" style="object-fit: cover; z-index: 2;" onerror="this.src='/images/no-avatar.png'" />
                        
                        <div id="noFacePlaceholder" class="text-center text-white opacity-25 @(hasFaceId ? "d-none" : "")" style="z-index: 1;">
                            <i class="bi bi-person-bounding-box" style="font-size: 6rem;"></i>
                        </div>

                        <div class="position-absolute bottom-0 start-0 w-100 p-2 text-center" style="background: rgba(0,0,0,0.6); z-index: 3;">
                            <span class="text-white small fw-bold" id="camStatus">
                                @if(!hasFaceId) { 
                                    <i class="bi bi-x-circle text-danger"></i> <span>Chưa có FaceID</span> 
                                } else { 
                                    <i class="bi bi-check-circle text-success"></i> <span>Đã có dữ liệu FaceID</span> 
                                }
                            </span>
                        </div>
                    </div>
                    
                    <button type="button" class="btn btn-warning w-100 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#cameraModal" onclick="startCamera()">
                        <i class="bi bi-camera-reels"></i> Thay đổi ảnh nhận diện
                    </button>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3 cursor-pointer" id="boxFinger" onclick="simulateFingerScan()" style="transition: 0.3s; border: 2px solid @(Model.HasFingerprint ? "#198754" : "transparent") !important;">
                <div class="card-header bg-dark text-white fw-bold py-2 text-center text-uppercase small"><i class="bi bi-fingerprint text-info"></i> Dữ liệu Vân tay</div>
                <div class="card-body p-4 text-center bg-light">
                    <i class="bi @(Model.HasFingerprint ? "bi-check-circle-fill text-success" : "bi-fingerprint text-secondary opacity-25") display-1 mb-2" id="iconFinger"></i>
                    <h6 class="fw-bold @(Model.HasFingerprint ? "text-success" : "text-primary mt-2")" id="textFinger">@(Model.HasFingerprint ? "ĐÃ LẤY MẪU VÂN TAY" : "BẤM ĐỂ QUÉT VÂN TAY")</h6>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white border-bottom py-3"><h5 class="fw-bold text-primary mb-0 text-uppercase"><i class="bi bi-card-list"></i> THÔNG TIN HÀNH CHÍNH</h5></div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-4"><label class="form-label fw-bold text-muted small">MÃ NHÂN VIÊN</label><input asp-for="MaNV" class="form-control bg-light fw-bold text-primary font-monospace shadow-none" readonly /></div>
                        <div class="col-md-8"><label class="form-label fw-bold text-muted small">HỌ VÀ TÊN <span class="text-danger">*</span></label><input asp-for="HoTen" class="form-control shadow-none fw-bold" required /></div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted small">PHÒNG BAN / CHỨC VỤ <span class="text-danger">*</span></label>
                            <select asp-for="ChucVu" class="form-select shadow-none fw-bold text-dark" required>
                                <option value="Ban Giám đốc">Ban Giám đốc</option>
                                <option value="Phòng Nhân sự">Phòng Nhân sự</option>
                                <option value="Phòng Kế toán">Phòng Kế toán</option>
                                <option value="Phòng Công nghệ (IT)">Phòng Công nghệ (IT)</option>
                                <option value="Phòng Kinh doanh">Phòng Kinh doanh</option>
                                <option value="Bảo vệ / An ninh">Bảo vệ / An ninh</option>
                            </select>
                        </div>

                        <div class="col-12"><hr class="text-muted opacity-25 my-1"></div>
                        <div class="col-12 mb-1"><h6 class="fw-bold text-dark"><i class="bi bi-car-front-fill text-primary"></i> ĐĂNG KÝ PHƯƠNG TIỆN</h6></div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">LOẠI PHƯƠNG TIỆN</label>
                            <select asp-for="LoaiXe" id="loaiXeSelect" class="form-select shadow-none fw-bold" onchange="toggleBienSo()">
                                <option value="Không có">🚶 Không có phương tiện</option>
                                <option value="Xe máy">🛵 Xe máy</option>
                                <option value="Ô tô">🚗 Ô tô</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">BIỂN SỐ XE</label>
                            <input asp-for="BienSoXe" id="bienSoInput" type="text" class="form-control shadow-none font-monospace fw-bold text-uppercase bg-light text-muted" readonly>
                        </div>

                        <div class="col-12"><hr class="text-muted opacity-25 my-1"></div>
                        <div class="col-12 mb-1"><h6 class="fw-bold text-dark"><i class="bi bi-clock-history text-primary"></i> CÀI ĐẶT CHẤM CÔNG</h6></div>

                        <div class="col-md-6"><label class="form-label fw-bold text-muted small">GIỜ VÀO CA MẶC ĐỊNH</label><input asp-for="GioVaoCa" type="time" class="form-control shadow-none fw-bold" /></div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small">ĐƯỢC PHÉP ĐI MUỘN ĐẾN</label>
                            <input asp-for="GioXinDiMuon" type="time" class="form-control shadow-none fw-bold text-danger border-danger border-opacity-50" />
                            <small class="text-danger" style="font-size:0.7rem;">* AI sẽ bỏ qua giờ vào ca nếu có ô này.</small>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light border-top p-4 text-end">
                    <button type="button" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm" onclick="confirmSave()">
                        <i class="bi bi-save2-fill me-1"></i> CẬP NHẬT HỒ SƠ
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="cameraModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-3 border-0 rounded-top-4">
                <h5 class="modal-title fw-bold text-uppercase small"><i class="bi bi-person-bounding-box"></i> Cập Nhật Hình Ảnh Nhận Diện</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" onclick="stopCamera()"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <ul class="nav nav-pills nav-fill mb-3 bg-white p-1 rounded-3 shadow-sm border" role="tablist">
                    <li class="nav-item"><button class="nav-link active fw-bold rounded-3" data-bs-toggle="tab" data-bs-target="#tab-camera" type="button" onclick="startCamera()">Sử dụng Camera</button></li>
                    <li class="nav-item"><button class="nav-link fw-bold rounded-3" data-bs-toggle="tab" data-bs-target="#tab-upload" type="button" onclick="stopCamera()">Tải file ảnh</button></li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active text-center" id="tab-camera">
                        <div class="rounded-3 overflow-hidden shadow-sm border mb-3" style="background:#000;">
                            <video id="webcamVideo" width="100%" height="280" autoplay playsinline style="transform: scaleX(-1); object-fit: cover;"></video>
                        </div>
                        <canvas id="webcamCanvas" style="display:none;"></canvas>
                        <button type="button" class="btn btn-primary w-100 fw-bold fs-6 shadow-sm" onclick="captureImage()"><i class="bi bi-camera-fill"></i> CHỤP NGAY</button>
                    </div>
                    <div class="tab-pane fade" id="tab-upload">
                        <div class="mb-3"><label class="form-label fw-bold text-muted small">CHỌN FILE ẢNH (JPG, PNG)</label><input class="form-control form-control-lg shadow-none" type="file" id="fileUpload" accept="image/*" onchange="previewFile()"></div>
                    </div>
                </div>
                <div class="text-center mt-4">
                    <h6 class="fw-bold text-muted d-none small mb-2 text-uppercase" id="previewTitle">Kết quả thu nhận:</h6>
                    <img id="modalPreview" src="" class="rounded-3 shadow-sm border" style="display:none; width: 100%; max-height: 200px; object-fit: cover;" />
                </div>
            </div>
            <div class="modal-footer bg-white border-top-0 rounded-bottom-4">
                <button type="button" class="btn btn-outline-secondary fw-bold" data-bs-dismiss="modal" onclick="stopCamera()">Hủy Bỏ</button>
                <button type="button" class="btn btn-success fw-bold px-4 shadow-sm" onclick="saveFaceDataToForm()" data-bs-dismiss="modal"><i class="bi bi-check-lg"></i> XÁC NHẬN ẢNH</button>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f4f7f6; }
    .cursor-pointer { cursor: pointer; }
    .cursor-pointer:hover { background-color: #e9ecef !important; }
    .form-control:focus, .form-select:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15); }
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    window.onload = function() { toggleBienSo(); }

    function toggleBienSo() {
        const loaiXe = document.getElementById('loaiXeSelect').value;
        const bienSo = document.getElementById('bienSoInput');
        if (loaiXe === "Không có") {
            bienSo.value = "N/A"; bienSo.setAttribute('readonly', true); bienSo.classList.add('bg-light', 'text-muted');
        } else {
            if(bienSo.value === "N/A" || bienSo.value === "---") bienSo.value = "";
            bienSo.removeAttribute('readonly'); bienSo.classList.remove('bg-light', 'text-muted');
            bienSo.placeholder = (loaiXe === "Ô tô") ? "VD: 30F-123.45" : "VD: 59A1-123.45";
        }
    }

    let video = document.getElementById('webcamVideo'); let streamRef = null;
    function startCamera() { navigator.mediaDevices.getUserMedia({ video: true }).then(s => { video.srcObject = s; streamRef = s; }).catch(err => alert("Lỗi Camera")); }
    function stopCamera() { if(streamRef) { streamRef.getTracks().forEach(t => t.stop()); streamRef = null; } }
    
    function captureImage() { 
        let canvas = document.getElementById('webcamCanvas'); 
        canvas.width = video.videoWidth; 
        canvas.height = video.videoHeight; 
        let ctx = canvas.getContext('2d'); 
        ctx.translate(canvas.width, 0); 
        ctx.scale(-1, 1); 
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height); 
        showPreview(canvas.toDataURL('image/jpeg')); 
    }
    
    function previewFile() { 
        let file = document.getElementById('fileUpload').files[0]; 
        let reader = new FileReader(); 
        reader.onloadend = function() { showPreview(reader.result); }; 
        if(file) reader.readAsDataURL(file); 
    }
    
    function showPreview(url) { 
        document.getElementById('modalPreview').src = url; 
        document.getElementById('modalPreview').style.display = 'block'; 
        document.getElementById('previewTitle').classList.remove('d-none'); 
    }
    
    function saveFaceDataToForm() { 
        let url = document.getElementById('modalPreview').src; 
        if(url && url.startsWith("data:image")) { 
            document.getElementById('FaceDataInput').value = url; 
            
            document.getElementById('capturedPhoto').src = url; 
            document.getElementById('capturedPhoto').classList.remove('d-none');
            document.getElementById('noFacePlaceholder').classList.add('d-none');
            
            document.getElementById('camStatus').innerHTML = "<i class='bi bi-check-circle text-success'></i> Đã có dữ liệu FaceID mới"; 
        } 
        stopCamera(); 
    }
    
    function simulateFingerScan() { 
        document.getElementById("iconFinger").className = "bi bi-check-circle-fill display-1 text-success mb-2"; 
        document.getElementById("textFinger").innerText = "ĐÃ LẤY MẪU VÂN TAY"; 
        document.getElementById("textFinger").className = "fw-bold text-success mt-2"; 
        document.getElementById("boxFinger").style.borderColor = "#198754"; 
        document.getElementById("HasFingerprint").checked = true; 
    }

    // ĐÃ THÊM: HÀM XÁC NHẬN LƯU BẰNG SWEETALERT2
    function confirmSave() {
        Swal.fire({
            title: 'CẬP NHẬT HỒ SƠ?',
            text: "Dữ liệu sinh trắc học mới sẽ được ghi đè.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'Cập Nhật Ngay',
            confirmButtonColor: '#0d6efd',
            cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                // Hiện thông báo đang lưu để người dùng biết
                Swal.fire({ title: 'Đang xử lý...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                // Submit form
                document.getElementById('formEditNhanVien').submit();
            }
        });
    }

    // HIỂN THỊ THÔNG BÁO LỖI TỪ SERVER (Nếu có)
    document.addEventListener("DOMContentLoaded", function() {
        var errorMsg = '@Html.Raw(TempData["Error"])';
        if (errorMsg !== "") {
            Swal.fire({
                title: 'Lỗi cập nhật!',
                text: errorMsg,
                icon: 'error',
                confirmButtonColor: '#0d6efd'
            });
        }
    });
</script>