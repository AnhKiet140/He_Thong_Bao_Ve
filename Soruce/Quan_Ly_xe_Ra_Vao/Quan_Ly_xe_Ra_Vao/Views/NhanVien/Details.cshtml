@model Quan_Ly_xe_Ra_Vao.Models.NhanVien

@{
    ViewData["Title"] = "Chi Tiết Hồ Sơ Sinh Trắc Học";
}

<style>
    .square-box, .btn, .card {
        border-radius: 0 !important;
    }
</style>

<div class="container mt-4">
    <div class="card square-box border-dark shadow-sm mx-auto" style="max-width: 650px;">
        <div class="card-header bg-dark text-white square-box py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-uppercase"><i class="bi bi-person-vcard"></i> HỒ SƠ ĐỊNH DANH</h5>
            <span class="badge bg-light text-dark fs-6 square-box px-3 border border-2 border-dark">@Model.MaNV</span>
        </div>

        <div class="card-body p-5 bg-light">
            <div class="row align-items-center">
                <div class="col-md-5 text-center border-end border-2 border-dark">
                    @if (!string.IsNullOrEmpty(Model.FaceDataPath) && Model.FaceDataPath != "chua_co_anh.jpg")
                    {
                        <img src="@Model.FaceDataPath" class="img-fluid border border-4 border-success p-1 shadow mb-3" style="width: 160px; height: 160px; object-fit: cover; border-radius: 50%;" />
                        <div class="badge bg-success square-box w-100 py-2 fs-6 shadow-sm"><i class="bi bi-check-circle"></i> Đã có FaceID</div>
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center border border-4 border-dark p-1 shadow mb-3 mx-auto" style="width: 160px; height: 160px; border-radius: 50%;">
                            <i class="bi bi-person text-light" style="font-size: 5rem;"></i>
                        </div>
                        <div class="badge bg-danger square-box w-100 py-2 fs-6 shadow-sm"><i class="bi bi-x-circle"></i> Chưa có FaceID</div>
                    }
                </div>

                <div class="col-md-7 ps-4">
                    <p class="text-muted small text-uppercase fw-bold mb-1">Họ và Tên</p>
                    <h3 class="fw-bold text-primary mb-3 text-uppercase">@Model.HoTen</h3>

                    <p class="text-muted small text-uppercase fw-bold mb-1">Chức vụ / Bộ phận</p>
                    <h5 class="fw-bold text-dark mb-4 border-bottom border-dark pb-2">@Model.ChucVu</h5>

                    <div class="row">
                        <div class="col-6">
                            <p class="text-muted small text-uppercase fw-bold mb-1">Giờ Vào Ca</p>
                            <h6 class="fw-bold text-dark"><i class="bi bi-clock"></i> @Model.GioVaoCa.ToString(@"hh\:mm")</h6>
                        </div>
                        <div class="col-6">
                            <p class="text-muted small text-uppercase fw-bold mb-1">Trạng thái Vân Tay</p>
                            @if (Model.HasFingerprint)
                            {
                                <h6 class="fw-bold text-success"><i class="bi bi-fingerprint"></i> Đã lấy mẫu</h6>
                            }
                            else
                            {
                                <h6 class="fw-bold text-danger"><i class="bi bi-fingerprint"></i> Chưa có</h6>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-white border-top border-dark border-2 d-flex justify-content-between py-3">
            <a asp-action="Index" class="btn btn-outline-dark square-box fw-bold px-4"><i class="bi bi-arrow-left"></i> QUAY LẠI</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark square-box fw-bold px-4"><i class="bi bi-pencil-square"></i> CẬP NHẬT DATA</a>
        </div>
    </div>
</div>