@model Quan_Ly_xe_Ra_Vao.Models.NhanVien

@{
    ViewData["Title"] = "Chi Tiết Hồ Sơ Sinh Trắc Học";
    // Kiểm tra ảnh FaceID hợp lệ
    bool hasFaceId = !string.IsNullOrEmpty(Model.FaceDataPath) && Model.FaceDataPath != "chua_co_anh.jpg";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
        <h4 class="fw-bold text-primary mb-0">
            <i class="bi bi-person-vcard-fill me-2"></i> CHI TIẾT HỒ SƠ NHÂN SỰ
        </h4>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold shadow-sm">
                <i class="bi bi-pencil-square"></i> Cập nhật Data
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-4 d-flex flex-column gap-3">

            <div class="card border-0 shadow-sm rounded-3 flex-grow-1">
                <div class="card-header bg-dark text-white fw-bold py-2 text-center text-uppercase small">
                    <i class="bi bi-person-bounding-box text-info"></i> Dữ liệu Khuôn mặt
                </div>
                <div class="card-body p-4 text-center bg-light">
                    <div class="avatar-container border border-3 rounded-circle bg-white mb-4 d-flex align-items-center justify-content-center overflow-hidden shadow-sm mx-auto" style="height: 220px; width: 220px;">
                        @if (hasFaceId)
                        {
                            <img src="@Model.FaceDataPath" class="img-fluid" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='/images/no-avatar.png'" />
                        }
                        else
                        {
                            <i class="bi bi-person text-secondary opacity-25" style="font-size: 8rem;"></i>
                        }
                    </div>

                    @if (!hasFaceId)
                    {
                        <div class="badge bg-danger px-4 py-2 fs-6 shadow-sm w-100 rounded-pill">
                            <i class="bi bi-x-circle-fill"></i> Chưa có FaceID
                        </div>
                    }
                    else
                    {
                        <div class="badge bg-success px-4 py-2 fs-6 shadow-sm w-100 rounded-pill">
                            <i class="bi bi-check-circle-fill"></i> Đã đăng ký FaceID
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-dark text-white fw-bold py-2 text-center text-uppercase small">
                    <i class="bi bi-fingerprint text-info"></i> Dữ liệu Vân tay
                </div>
                <div class="card-body p-3 text-center bg-light">
                    @if (Model.HasFingerprint)
                    {
                        <div class="badge bg-success bg-opacity-25 text-success px-4 py-2 border border-success shadow-sm w-100 fs-6">
                            <i class="bi bi-check-circle"></i> Đã lấy mẫu vân tay
                        </div>
                    }
                    else
                    {
                        <div class="badge bg-secondary bg-opacity-25 text-secondary px-4 py-2 border border-secondary shadow-sm w-100 fs-6">
                            <i class="bi bi-x-circle"></i> Chưa thu thập vân tay
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 h-100">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-primary mb-0 text-uppercase"><i class="bi bi-card-text"></i> THÔNG TIN CÁ NHÂN</h5>
                    <span class="badge bg-light text-dark border border-2 fs-6 px-3 py-1 font-monospace shadow-sm">@Model.MaNV</span>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">

                        <div class="col-md-7">
                            <small class="text-muted d-block fw-bold mb-1 small">HỌ VÀ TÊN</small>
                            <h2 class="fw-bold text-dark mb-0 text-uppercase">@Model.HoTen</h2>
                        </div>

                        <div class="col-md-5">
                            <small class="text-muted d-block fw-bold mb-1 small">PHÒNG BAN / CHỨC VỤ</small>
                            <div class="fs-4 fw-bold text-primary">@Model.ChucVu</div>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="d-flex align-items-center bg-light p-3 rounded-3 border border-primary border-opacity-25 shadow-sm">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                                    <i class="bi bi-clock-fill fs-4"></i>
                                </div>
                                <div>
                                    <small class="fw-bold text-muted d-block text-uppercase">Giờ Vào Ca Đăng Ký</small>
                                    <span class="fw-bold text-dark fs-4">@Model.GioVaoCa.ToString(@"hh\:mm")</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12"><hr class="text-muted opacity-25 my-2"></div>

                        <div class="col-12 mb-0">
                            <h6 class="fw-bold text-dark mb-0"><i class="bi bi-car-front-fill text-primary"></i> THÔNG TIN PHƯƠNG TIỆN</h6>
                        </div>

                        <div class="col-md-5">
                            <small class="text-muted d-block fw-bold mb-2 small">LOẠI PHƯƠNG TIỆN</small>
                            @if (Model.LoaiXe == "Xe máy")
                            {
                                <span class="badge bg-info bg-opacity-10 text-info border border-info px-4 py-2 fs-5 shadow-sm">🛵 XE MÁY</span>
                            }
                            else if (Model.LoaiXe == "Ô tô")
                            {
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-4 py-2 fs-5 shadow-sm">🚗 Ô TÔ</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-4 py-2 fs-6 shadow-sm">🚶 KHÔNG CÓ</span>
                            }
                        </div>

                        <div class="col-md-7">
                            <small class="text-muted d-block fw-bold mb-2 small">BIỂN SỐ ĐĂNG KÝ</small>
                            <div class="font-monospace fs-2 fw-bold text-dark border-bottom border-4 border-primary d-inline-block pb-1">
                                @(string.IsNullOrEmpty(Model.BienSoXe) || Model.BienSoXe == "---" || Model.BienSoXe == "N/A" ? "CHƯA ĐĂNG KÝ" : Model.BienSoXe)
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f7f6;
    }

    .font-monospace {
        letter-spacing: 2px;
    }
</style>